def normalize_model_value(value: str | None) -> str | None:
    if value is None:
        return None

    normalized = str(value).strip()
    if not normalized:
        return None

    if normalized.lower() in {"default", "none", "null", "reset"}:
        return None

    return normalized


def default_model_choice() -> str | None:
    return normalize_model_value(os.getenv("OLLAMA_MODEL"))


def get_user_config_path() -> Path:
    return Path.home() / USER_CONFIG_FILE


def load_config_file(path: Path) -> dict[str, str | None] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        print(c(f"Unable to read {path}: {exc}", YELLOW), file=sys.stderr)
        return None

    if not isinstance(data, dict):
        print(c(f"{path} does not contain a valid JSON object.", YELLOW), file=sys.stderr)
        return None

    config = build_runtime_config()

    config["model"] = normalize_model_value(data.get("model"))
    return config


def load_config(root: Path) -> dict[str, str | None]:
    config = build_runtime_config()
    for path in (
        get_user_config_path(),
        Path.home() / LEGACY_USER_CONFIG_FILE,
        root / LEGACY_PROJECT_CONFIG_FILE,
    ):
        if not path.exists():
            continue

        loaded = load_config_file(path)
        if loaded is not None:
            config = loaded
            break

    return config


def save_config(_root: Path, config: dict[str, str | None]) -> None:
    payload = {
        "model": normalize_model_value(config.get("model")),
    }
    path = get_user_config_path()

    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(
            json.dumps(payload, indent=2, ensure_ascii=True) + "\n",
            encoding="utf-8",
        )
    except Exception as exc:
        print(c(f"Unable to save {path}: {exc}", RED), file=sys.stderr)


def format_model_name(model: str | None) -> str:
    normalized = normalize_model_value(model)
    if normalized:
        return normalized

    default_model = default_model_choice()
    if default_model:
        return f"automatic ({default_model})"

    return "automatic"


def default_ollama_url(raw: str | None = None) -> str:
    value = (raw or os.getenv("OLLAMA_HOST") or "127.0.0.1:11434").strip()
    if not value:
        value = "127.0.0.1:11434"
    if "://" not in value:
        value = "http://" + value
    return value.rstrip("/")


def is_cloud_model(model: str) -> bool:
    lowered = model.strip().lower()
    return lowered.endswith(":cloud") or lowered.endswith("-cloud")


def is_ollama_cloud_url(ollama_url: str | None) -> bool:
    host = (urllib.parse.urlparse(default_ollama_url(ollama_url)).hostname or "").lower()
    return host == "ollama.com" or host.endswith(".ollama.com")


def is_cloud_target(model: str | None, ollama_url: str | None) -> bool:
    normalized = normalize_model_value(model)
    return bool(normalized and is_cloud_model(normalized)) or is_ollama_cloud_url(ollama_url)


def sync_session_usage_target(model: str | None, ollama_url: str | None) -> None:
    global _SESSION_USAGE

    resolved = normalize_model_value(model) or default_model_choice()
    _SESSION_USAGE.last_resolved_model = resolved
    _SESSION_USAGE.last_target_was_cloud = is_cloud_target(resolved, ollama_url)
    if (
        resolved
        and _SESSION_USAGE.last_cloud_usage is not None
        and _SESSION_USAGE.last_cloud_usage.model
        and _SESSION_USAGE.last_cloud_usage.model != resolved
    ):
        _SESSION_USAGE.last_cloud_usage = None


def pick_auto_model(models: list[str]) -> str | None:
    available = unique_preserve(models)
    if not available:
        return None

    by_lower = {model.lower(): model for model in available}
    for candidate in OLLAMA_FALLBACK_MODELS:
        matched = by_lower.get(candidate.lower())
        if matched and not is_cloud_model(matched):
            return matched

    for model in available:
        if not is_cloud_model(model):
            return model

    return available[0]


def resolve_active_model(model: str | None, ollama_url: str | None = None) -> str | None:
    normalized = normalize_model_value(model)
    if normalized:
        return normalized

    env_model = default_model_choice()
    if env_model:
        return env_model

    return pick_auto_model(discover_ollama_models(ollama_url or default_ollama_url()))


def format_ollama_target(model: str | None, ollama_url: str | None = None) -> str:
    active_model = resolve_active_model(model, ollama_url)
    if active_model:
        return f"engine: ollama, model: {active_model}"
    return "engine: ollama, model: not configured"


