THINK_BLOCK_RE = re.compile(r"\s*", re.IGNORECASE | re.DOTALL)


def strip_thinking_sections(text: str) -> str:
    return THINK_BLOCK_RE.sub("", text)


def clean_ollama_output(text: str) -> str:
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    text = strip_thinking_sections(text)

    cleaned = []
    for line in text.splitlines():
        s = line.strip().lower()
            continue
        if s.startswith("warning:"):
            continue
        if s in {""}:
            continue
        cleaned.append(line)

    text = "\n".join(cleaned).strip()

    if text.startswith("```text"):
        text = text[len("```text"):].lstrip()
    elif text.startswith("```markdown"):
        text = text[len("```markdown"):].lstrip()
    elif text.startswith("```"):
        text = text[3:].lstrip()

    if text.endswith("```"):
        text = text[:-3].rstrip()

    if text.strip() == "NO_CHANGES":
        return "NO_CHANGES"

    pos = text.find("===FILE:")
    if pos != -1:
        text = text[pos:]

    stripped = text.strip()
    if not stripped:
        return ""
    return stripped + "\n"


def clean_plan_output(text: str) -> str:
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    text = strip_thinking_sections(text)

    cleaned = []
    for line in text.splitlines():
        s = line.strip().lower()

            continue
        if s.startswith("warning:"):
            continue
        if s == "```":
            continue
        if s.startswith("```text"):
            continue
        if s.startswith("```markdown"):
            continue

        cleaned.append(line)

    return "\n".join(cleaned).strip()


def should_retry_ollama(error_text: str) -> bool:
    text = error_text.lower()

    retry_markers = (
        "timeout",
        "timed out",
        "temporar",
        "unavailable",
        "connection reset",
        "connection refused",
        "connection aborted",
        "i/o timeout",
        "try again",
        "eof",
        "upstream",
        "server busy",
        "busy",
    )

    return any(marker in text for marker in retry_markers)


class Spinner:
    def __init__(self, label: str = "Waiting for Ollama", detail: str = ""):
        self.label = label
        self.detail = detail
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None

    def _run(self) -> None:
        i = 0
        start = time.time()
        last_len = 0

        while not self._stop.is_set():
            frame = SPINNER_FRAMES[i % len(SPINNER_FRAMES)]
            elapsed = int(time.time() - start)
            detail = f" | {self.detail}" if self.detail else ""
            plain = f"{frame} {self.label}{detail} | {elapsed}s"
            padding = " " * max(0, last_len - len(plain))
            print(f"\r{CYAN}{plain}{RESET}{padding}", end="", flush=True)
            last_len = len(plain)
            time.sleep(0.1)
            i += 1
        print("\r" + " " * last_len + "\r", end="", flush=True)

    def __enter__(self):
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        return self

    def __exit__(self, exc_type, exc, tb):
        self._stop.set()
        if self._thread is not None:
            self._thread.join(timeout=1)


def call_ollama(
    prompt: str,
    ollama_url: str,
    model: str | None,
    plan_mode: bool = False,
) -> str:
    active_model = resolve_active_model(model, ollama_url)
    last_error = ""
    base_url = default_ollama_url(ollama_url)
    headers = build_ollama_headers(base_url)

    _SESSION_USAGE.last_resolved_model = normalize_model_value(active_model)
    _SESSION_USAGE.last_target_was_cloud = is_cloud_target(active_model, ollama_url)

    if not active_model:
        print(c("Error while running Ollama.", RED), file=sys.stderr)
        print(
            c(
                "No model configured or available. Use /model or set OLLAMA_MODEL.",
                YELLOW,
            ),
            file=sys.stderr,
        )
        return ""

    if is_ollama_cloud_url(base_url) and headers is None:
        print(c("Error while running Ollama.", RED), file=sys.stderr)
        print(
            c(
                "Direct requests to ollama.com require OLLAMA_API_KEY. Set it or use a local Ollama instance.",
                YELLOW,
            ),
            file=sys.stderr,
        )
        return ""

    print(c(
        (
            f"Running Ollama on {base_url} with model {active_model}. "
            f"Prompt: {format_count(len(prompt))} characters."
        ),
        MUTED,
    ))

    payload = {
        "model": active_model,
        "prompt": prompt,
        "stream": False,
    }

    for attempt in range(1, OLLAMA_MAX_ATTEMPTS + 1):
        start = time.time()
        print(c(f"Ollama attempt {attempt}/{OLLAMA_MAX_ATTEMPTS}...", CYAN))
        with Spinner("Talking to Ollama", detail=f"attempt {attempt}/{OLLAMA_MAX_ATTEMPTS}"):
            data, error = request_json(
                build_ollama_api_url(base_url, "/generate"),
                payload=payload,
                headers=headers,
                timeout=OLLAMA_TIMEOUT_SECONDS,
            )
        elapsed = time.time() - start
        print(c(f"Ollama time: {elapsed:.1f}s", MUTED))

        if error is None and isinstance(data, dict):
            record_response_usage(data, active_model, ollama_url)
            raw = str(data.get("response") or "")
            cleaned = clean_plan_output(raw) if plan_mode else clean_ollama_output(raw)
            if cleaned.strip():
                return cleaned

            response_error = str(data.get("error") or "").strip()
            last_error = response_error or "Ollama returned an empty response."
        else:
            last_error = error or "Invalid response from Ollama."

        print(c(
            (
                "Ollama did not return a usable response. "
                f"Detail: {preview_text(last_error, max_chars=240)}"
            ),
            YELLOW,
        ))

        if attempt < OLLAMA_MAX_ATTEMPTS and should_retry_ollama(last_error):
            print(c(
                (
                    f"Ollama attempt {attempt}/{OLLAMA_MAX_ATTEMPTS} failed, "
                    f"retrying in {OLLAMA_RETRY_DELAY_SECONDS}s..."
                ),
                YELLOW,
            ))
            time.sleep(OLLAMA_RETRY_DELAY_SECONDS)
            continue

        break

    print(c("Error while running Ollama.", RED), file=sys.stderr)
    lowered = last_error.lower()
    if "not found" in lowered or "model" in lowered and "not found" in lowered:
        print(
            c(
                f"Ollama model not found: {active_model}. Use /model or run `ollama pull {active_model}`.",
                YELLOW,
            ),
            file=sys.stderr,
        )
    elif any(marker in lowered for marker in ("connection refused", "connect", "timeout")):
        print(
            c(
                f"Ollama is not responding on {base_url}. Start `ollama serve` and try again.",
                YELLOW,
            ),
            file=sys.stderr,
        )
    if last_error:
        print(preview_text(last_error, max_chars=800), file=sys.stderr)
    return ""


def parse_file_blocks(text: str) -> Dict[str, str]:
    result: Dict[str, str] = {}
    for path, content in BLOCK_RE.findall(text):
        path = path.strip()
        if path:
            result[path] = content.rstrip("\n") + "\n"
    return result


def read_text_snapshot(path: Path) -> str | None:
    if not path.exists():
        return None

    try:
        return path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        try:
            return path.read_text(encoding="latin-1")
        except Exception:
            return None
    except Exception:
        return None


def backup_files(root: Path, rel_paths: list[str]) -> dict[str, str | None]:
    backup: dict[str, str | None] = {}
    for rel in rel_paths:
        p = root / rel
        backup[rel] = read_text_snapshot(p)
    return backup


def restore_files(root: Path, backup: dict[str, str | None]) -> None:
    for rel, content in backup.items():
        p = root / rel
        try:
            if content is None:
                if p.exists():
                    p.unlink()
            else:
                p.parent.mkdir(parents=True, exist_ok=True)
                p.write_text(content, encoding="utf-8")
        except Exception as exc:
            print(c(f"Unable to restore {rel}: {exc}", RED), file=sys.stderr)


def extend_backup(root: Path, backup: dict[str, str | None], rel_paths: list[str]) -> None:
    for rel in rel_paths:
        if rel not in backup:
            backup[rel] = read_text_snapshot(root / rel)


def compute_changed_files(root: Path, backup: dict[str, str | None]) -> list[str]:
    changed: list[str] = []

    for rel, original in backup.items():
        current = read_text_snapshot(root / rel)
        if current != original:
            changed.append(rel)

    return sorted(changed)


def build_session_diff(root: Path, backup: dict[str, str | None], rel_paths: list[str]) -> str:
    if not rel_paths:
        return ""

    chunks: list[str] = []

    for rel in rel_paths:
        before = backup.get(rel)
        after = read_text_snapshot(root / rel)

        before_lines = [] if before is None else before.splitlines(keepends=True)
        after_lines = [] if after is None else after.splitlines(keepends=True)

        diff = "".join(
            difflib.unified_diff(
                before_lines,
                after_lines,
                fromfile=f"a/{rel}",
                tofile=f"b/{rel}",
                lineterm="\n",
            )
        )
        if diff.strip():
            chunks.append(diff)

    text = "\n\n".join(chunks).strip()
    if len(text) > MAX_SUMMARY_DIFF_CHARS:
        text = text[:MAX_SUMMARY_DIFF_CHARS].rstrip() + "\n...[DIFF TRUNCATED]...\n"
    return text


def write_files(root: Path, files_map: Dict[str, str]) -> tuple[list[str], list[str]]:
    written: list[str] = []
    rejected: list[str] = []

    for rel, content in files_map.items():
        if not is_valid_relpath(rel):
            rejected.append(rel)
            continue

        dest = root / rel
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(content, encoding="utf-8")
        written.append(rel)

    return written, rejected


def git_add_written_files(written: list[str]) -> None:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if files:
        run(["git", "add", "--", *files], check=False)


def git_reset_written_files(written: list[str]) -> None:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if files:
        run(["git", "reset", "--", *files], check=False)


def has_staged_changes() -> bool:
    cp = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        text=True,
        capture_output=True,
    )
    return cp.returncode != 0


def has_any_changes_excluding_internal_files() -> bool:
    cp = run(["git", "status", "--porcelain"], check=False)
    for line in cp.stdout.splitlines():
        if any(internal in line for internal in INTERNAL_STATE_FILES):
            continue
        return True
    return False


def detect_file_kind(path: Path) -> str | None:
    suffix = path.suffix.lower()

    if suffix == ".py":
        return "python"
    if suffix == ".php":
        return "php"
    if suffix in {".js", ".mjs", ".cjs"}:
        return "javascript"
    if suffix in {".sh", ".bash"}:
        return "bash"

    if path.name in {"bashrc", "profile", ".bashrc", ".profile"}:
        return "bash"

    return None


def tool_exists(name: str) -> bool:
    cp = run(["sh", "-c", f"command -v {shlex.quote(name)}"], check=False)
    return cp.returncode == 0 and bool((cp.stdout or "").strip())


def validate_python(path: Path) -> tuple[bool, str]:
    if not tool_exists("python3"):
        return False, "python3 not found on the system"
    cp = run(["python3", "-m", "py_compile", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_php(path: Path) -> tuple[bool, str]:
    if not tool_exists("php"):
        return False, "php not found on the system"
    cp = run(["php", "-l", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_javascript(path: Path) -> tuple[bool, str]:
    if not tool_exists("node"):
        return False, "node not found on the system"
    cp = run(["node", "--check", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_bash(path: Path) -> tuple[bool, str]:
    if not tool_exists("bash"):
        return False, "bash not found on the system"
    cp = run(["bash", "-n", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_file(path: Path) -> tuple[str | None, bool, str]:
    kind = detect_file_kind(path)
    if kind is None:
        return None, True, "skip"

    if kind == "python":
        ok, msg = validate_python(path)
    elif kind == "php":
        ok, msg = validate_php(path)
    elif kind == "javascript":
        ok, msg = validate_javascript(path)
    elif kind == "bash":
        ok, msg = validate_bash(path)
    else:
        return None, True, "skip"

    return kind, ok, msg or "ok"


def validate_written_files(root: Path, written: list[str]) -> tuple[bool, list[str], list[str]]:
    reports: list[str] = []
    failures: list[str] = []

    for rel in written:
        if rel in INTERNAL_STATE_FILES:
            continue

        full = root / rel
        kind, ok, msg = validate_file(full)

        if kind is None:
            continue

        label = f"{rel} [{kind}]"
        if ok:
            reports.append(f"{label}: OK")
        else:
            failure_text = msg.strip() or "unknown error"
            reports.append(f"{label}: ERROR")
            failures.append(f"{label}\n{failure_text}")

    return len(failures) == 0, reports, failures


def show_validation_results(
    reports: list[str],
    ok: bool,
    failures: list[str] | None = None,
) -> None:
    print(c("\n--- SYNTAX VALIDATION ---\n", BOLD + BLUE))

    if reports:
        for row in reports:
            color = GREEN if row.endswith("OK") else RED
            print(c(row, color))
    else:
        print(c("No validatable files among the modified files.", YELLOW))

    print(c(
        f"Validation completed: {'OK' if ok else 'ERRORS'}",
        GREEN if ok else RED,
    ))

    if not ok and failures:
        print(c("\n--- VALIDATION ERRORS ---\n", BOLD + RED), file=sys.stderr)
        for err in failures:
            print(err, file=sys.stderr)
            print(file=sys.stderr)


def apply_code_response(
    root: Path,
    response: str,
    session_backup: dict[str, str | None],
) -> AppliedPassResult:
    result = AppliedPassResult(response=response)

    if response.strip() == "NO_CHANGES":
        result.no_changes = True
        result.changed_files = compute_changed_files(root, session_backup)
        ok, reports, failures = validate_written_files(root, result.changed_files)
        result.validation_ok = ok
        result.validation_reports = reports
        result.validation_failures = failures
        return result

    files_map = parse_file_blocks(response)
    result.files_map = files_map

    if not files_map:
        result.valid_response = False
        return result

    candidate_paths = [rel for rel in files_map if is_valid_relpath(rel)]
    extend_backup(root, session_backup, candidate_paths)

    written, rejected = write_files(root, files_map)
    result.written = written
    result.rejected = rejected
    result.changed_files = compute_changed_files(root, session_backup)

    ok, reports, failures = validate_written_files(root, result.changed_files)
    result.validation_ok = ok
    result.validation_reports = reports
    result.validation_failures = failures
    return result


def build_report(
    request: str,
    written: list[str],
    rejected: list[str],
    validation_ok: bool,
    validation_failures: list[str],
    dry_run: bool,
) -> str:
    lines: list[str] = []

    lines.append(c("✨ REQUEST COMPLETED ✨", BOLD + MAGENTA))
    lines.append("")

    if written:
        lines.append(c(f"Files written: {len(written)}", GREEN))
        for f in written:
            lines.append(f"  + {f}")
    else:
        lines.append(c("No files were modified.", YELLOW))

    if rejected:
        lines.append("")
        lines.append(c(f"Files rejected: {len(rejected)}", RED))
        for f in rejected:
            lines.append(f"  - {f}")

    if validation_failures:
        lines.append("")
        lines.append(c("Validation failures:", RED))
        for f in validation_failures:
            lines.append(f"  ! {f}")

    if dry_run:
        lines.append("")
        lines.append(c("⚠️  DRY RUN - changes will be reverted", YELLOW))

    return "\n".join(lines)


def create_commit_message(root: Path, request: str, written: list[str]) -> str:
    cp = run(["git", "diff", "--cached"], check=False)
    diff_text = cp.stdout.strip()

    if not diff_text:
        return request

    prompt = build_change_summary_prompt(request, diff_text)
    summary = call_ollama(prompt, default_ollama_url(), None, plan_mode=False)

    if summary.strip():
        lines = summary.strip().splitlines()
        first_line = lines[0].replace("SUMMARY:", "").strip() if lines else request
        return first_line[:72]

    return request[:72]


def commit_changes(root: Path, request: str, written: list[str]) -> bool:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not files:
        return False

    git_add_written_files(written)

    if not has_staged_changes():
        return False

    message = create_commit_message(root, request, written)

    cp = run(["git", "commit", "-m", message], check=False)
    if cp.returncode == 0:
        print(c(f"Committed: {message}", GREEN))
        return True
    else:
        print(c("Git commit failed.", RED), file=sys.stderr)
        if cp.stderr:
            print(cp.stderr, file=sys.stderr)
        return False


def run_five_pass_engine(
    root: Path,
    request: str,
    project_text: str,
    ollama_url: str,
    model: str | None,
    request_history: str,
    dry_run: bool,
    auto_commit: bool,
) -> None:
    print(c("\n🎯 FIVE-PASS ENGINE ACTIVATED", BOLD + MAGENTA))
    print(c("─" * 60, DIM))

    session_backup: dict[str, str | None] = {}

    print(c("\n[1/5] PLANNING", BOLD + CYAN))
    plan_prompt = build_plan_prompt(project_text, request, request_history)
    plan_response = call_ollama(plan_prompt, ollama_url, model, plan_mode=True)

    if not plan_response.strip():
        print(c("Planning failed. Aborting.", RED), file=sys.stderr)
        return

    print(c("\nPlan:", GREEN))
    print(plan_response)

    print(c("\n[2/5] DRAFTING", BOLD + CYAN))
    draft_prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective="create a first draft implementation",
        plan_text=plan_response,
        request_history=request_history,
    )
    draft_response = call_ollama(draft_prompt, ollama_url, model, plan_mode=False)

    draft_result = apply_code_response(root, draft_response, session_backup)

    if not draft_result.valid_response:
        print(c("Draft response invalid. Aborting.", RED), file=sys.stderr)
        if dry_run:
            restore_files(root, session_backup)
        return

    print(c("\n[3/5] REVIEWING", BOLD + CYAN))
    review_project_text, _ = collect_project_context(root)
    session_diff = build_session_diff(root, session_backup, draft_result.changed_files)
    validation_text = build_validation_feedback(
        draft_result.validation_ok,
        draft_result.validation_reports,
        draft_result.validation_failures,
    )

    review_prompt = build_review_prompt(
        project_text=review_project_text,
        request=request,
        plan_text=plan_response,
        request_history=request_history,
        validation_text=validation_text,
        session_diff=session_diff,
    )
    review_response = call_ollama(review_prompt, ollama_url, model, plan_mode=False)

    print(c("\nReview:", GREEN))
    print(review_response)

    needs_fix = "VERDICT: FIX" in review_response.upper()

    if needs_fix:
        print(c("\n[4/5] FIXING", BOLD + CYAN))
        fix_prompt = build_code_prompt(
            project_text=review_project_text,
            request=request,
            objective="fix the issues identified in the review",
            plan_text=plan_response,
            request_history=request_history,
            review_text=review_response,
            validation_text=validation_text,
            session_diff=session_diff,
        )
        fix_response = call_ollama(fix_prompt, ollama_url, model, plan_mode=False)

        fix_result = apply_code_response(root, fix_response, session_backup)

        if fix_result.valid_response:
            print(c("\n[5/5] POLISHING", BOLD + CYAN))
            polish_project_text, _ = collect_project_context(root)
            polish_diff = build_session_diff(root, session_backup, fix_result.changed_files)

            polish_prompt = build_code_prompt(
                project_text=polish_project_text,
                request=request,
                objective="polish and finalize the implementation",
                plan_text=plan_response,
                request_history=request_history,
                review_text=review_response,
                validation_text=validation_text,
                session_diff=polish_diff,
            )
            polish_response = call_ollama(polish_prompt, ollama_url, model, plan_mode=False)

            apply_code_response(root, polish_response, session_backup)
    else:
        print(c("\n[4/5] SKIPPED (no fixes needed)", BOLD + CYAN))
        print(c("\n[5/5] POLISHING", BOLD + CYAN))
        polish_project_text, _ = collect_project_context(root)
        polish_diff = build_session_diff(root, session_backup, draft_result.changed_files)

        polish_prompt = build_code_prompt(
            project_text=polish_project_text,
            request=request,
            objective="polish and finalize the implementation",
            plan_text=plan_response,
            request_history=request_history,
            review_text=review_response,
            validation_text=validation_text,
            session_diff=polish_diff,
        )
        polish_response = call_ollama(polish_prompt, ollama_url, model, plan_mode=False)

        apply_code_response(root, polish_response, session_backup)

    final_changed = compute_changed_files(root, session_backup)

    if final_changed:
        print(c("\n" + "═" * 60, BOLD + MAGENTA))
        print(c("FINAL CHANGES", BOLD + WHITE))
        print(c("═" * 60, BOLD + MAGENTA))

        for rel in final_changed:
            before = session_backup.get(rel)
            after = read_text_snapshot(root / rel)
            show_colored_file_diff(before, after, rel)

        print(c("═" * 60, BOLD + MAGENTA))

    show_validation_results(
        draft_result.validation_reports + (fix_result.validation_reports if needs_fix else []),
        draft_result.validation_ok and (fix_result.validation_ok if needs_fix else True),
        draft_result.validation_failures + (fix_result.validation_failures if needs_fix else []),
    )

    if dry_run:
        print(c("\n🔄 Restoring original files (dry run)...", YELLOW))
        restore_files(root, session_backup)
    else:
        if auto_commit:
            commit_changes(root, request, final_changed)

    print(c("\n✅ Five-pass engine completed!", GREEN))


def handle_request(
    root: Path,
    request: str,
    ollama_url: str,
    model: str | None,
    plan_mode: bool,
    dry_run: bool,
    auto_commit: bool,
    five_pass_engine: bool,
) -> None:
    print(c("\n📚 Collecting project context...", CYAN))
    project_text, stats = collect_project_context(root)
    show_context_summary(stats)

    request_history = build_request_history_context(root)

    if five_pass_engine:
        run_five_pass_engine(
            root=root,
            request=request,
            project_text=project_text,
            ollama_url=ollama_url,
            model=model,
            request_history=request_history,
            dry_run=dry_run,
            auto_commit=auto_commit,
        )
        return

    session_backup: dict[str, str | None] = {}

    if plan_mode:
        print(c("\n📋 Generating plan...", CYAN))
        plan_prompt = build_plan_prompt(project_text, request, request_history)
        plan_response = call_ollama(plan_prompt, ollama_url, model, plan_mode=True)

        if plan_response.strip():
            print(c("\nPlan:", GREEN))
            print(plan_response)
        else:
            print(c("Plan generation failed.", RED), file=sys.stderr)

    print(c("\n🤖 Generating code...", CYAN))
    code_prompt = build_prompt(project_text, request, plan_response if plan_mode else "", request_history)
    response = call_ollama(code_prompt, ollama_url, model, plan_mode=False)

    if not response.strip():
        print(c("No response from Ollama.", RED), file=sys.stderr)
        return

    result = apply_code_response(root, response, session_backup)

    if not result.valid_response:
        print(c("Invalid response format from Ollama.", RED), file=sys.stderr)
        if dry_run:
            restore_files(root, session_backup)
        return

    if result.no_changes:
        print(c("\nNo changes needed.", YELLOW))
    else:
        print(c("\n" + "═" * 60, BOLD + MAGENTA))
        print(c("CHANGES PREVIEW", BOLD + WHITE))
        print(c("═" * 60, BOLD + MAGENTA))

        for rel in result.changed_files:
            before = session_backup.get(rel)
            after = read_text_snapshot(root / rel)
            show_colored_file_diff(before, after, rel)

        print(c("═" * 60, BOLD + MAGENTA))

    show_validation_results(
        result.validation_reports,
        result.validation_ok,
        result.validation_failures,
    )

    if not result.validation_ok:
        print(c("\n⚠️  Validation failed. Restoring original files...", YELLOW))
        restore_files(root, session_backup)
        return

    if dry_run:
        print(c("\n🔄 Restoring original files (dry run)...", YELLOW))
        restore_files(root, session_backup)
    else:
        if auto_commit and result.changed_files:
            commit_changes(root, request, result.changed_files)

    print(build_report(
        request=request,
        written=result.written,
        rejected=result.rejected,
        validation_ok=result.validation_ok,
        validation_failures=result.validation_failures,
        dry_run=dry_run,
    ))


def main() -> None:
    parser = argparse.ArgumentParser(
        description="ollama-code: Terminal coding agent powered by Ollama",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--ollama-url",
        help="Custom Ollama endpoint (default: OLLAMA_HOST or http://127.0.0.1:11434)",
    )
    parser.add_argument(
        "--plan",
        action="store_true",
        help="Ask Ollama for a plan before generating code",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show changes but restore the working tree afterward",
    )
    parser.add_argument(
        "--no-commit",
        action="store_true",
        help="Disable automatic Git commits",
    )
    parser.add_argument(
        "--no-engine",
        action="store_true",
        help="Disable the five-pass engine",
    )

    args = parser.parse_args()

    setup_readline()

    root = ensure_git_repo()

    config = load_config(root)

    ollama_url = args.ollama_url or default_ollama_url()
    model = config.get("model")
    plan_mode = args.plan or DEFAULT_PLAN_MODE
    dry_run = args.dry_run or DEFAULT_DRY_RUN
    auto_commit = not args.no_commit and DEFAULT_AUTO_COMMIT
    five_pass_engine = not args.no_engine and DEFAULT_FIVE_PASS_ENGINE

    print(c("\n👋 Welcome to ollama-code!", BOLD + GREEN))
    print(c("Your AI pair programmer for the terminal.", MUTED))
    print(c(f"Model: {format_model_name(model)}", CYAN))
    print(c(f"Ollama: {ollama_url}", CYAN))
    if PYGMENTS_AVAILABLE:
        print(c("Syntax highlighting: enabled ✨", GREEN))
    else:
        print(c("Syntax highlighting: disabled (install pygments for colors)", YELLOW))
    print()

    completer = SlashCommandCompleter(config, ollama_url)

    last_request = ""

    while True:
        try:
            user_input = prompt_input("ollama-code> ", CYAN, completer)
        except (EOFError, KeyboardInterrupt):
            print("\n")
            break

        user_input = user_input.strip()
        if not user_input:
            continue

        if user_input.startswith("/"):
            parts = user_input.split()
            command = parts[0].lower()
            arg = " ".join(parts[1:]) if len(parts) > 1 else None

            if command == "/f":
                list_files(root)
                continue

            if command == "/s":
                run_shell_command(arg)
                continue

            if command == "/diff":
                show_git_diff()
                continue

            if command == "/model":
                if arg:
                    ok, selected = resolve_model_choice(
                        arg,
                        discover_ollama_models(ollama_url),
                        allow_custom=True,
                    )
                    if ok:
                        model = selected
                        config["model"] = model
                        save_config(root, config)
                        if model:
                            print(c(f"Model set to: {model}", GREEN))
                        else:
                            print(c("Model reset to automatic", GREEN))
                    else:
                        print(c("Invalid model.", RED))
                else:
                    ok, selected = prompt_model_selection(ollama_url, model)
                    if ok:
                        model = selected
                        config["model"] = model
                        save_config(root, config)
                        if model:
                            print(c(f"Model set to: {model}", GREEN))
                        else:
                            print(c("Model reset to automatic", GREEN))
                continue

            if command == "/plan":
                if arg and arg.lower() in {"on", "off"}:
                    plan_mode = arg.lower() == "on"
                else:
                    plan_mode = not plan_mode
                print(c(f"Plan mode: {'ON' if plan_mode else 'OFF'}", GREEN))
                continue

            if command == "/dry":
                if arg and arg.lower() in {"on", "off"}:
                    dry_run = arg.lower() == "on"
                else:
                    dry_run = not dry_run
                print(c(f"Dry run: {'ON' if dry_run else 'OFF'}", GREEN))
                continue

            if command == "/commit":
                if arg and arg.lower() in {"on", "off"}:
                    auto_commit = arg.lower() == "on"
                else:
                    auto_commit = not auto_commit
                print(c(f"Auto commit: {'ON' if auto_commit else 'OFF'}", GREEN))
                continue

            if command == "/engine":
                if arg and arg.lower() in {"on", "off"}:
                    five_pass_engine = arg.lower() == "on"
                else:
                    five_pass_engine = not five_pass_engine
                print(c(f"Five-pass engine: {'ON' if five_pass_engine else 'OFF'}", GREEN))
                continue

            if command == "/retry":
                if last_request:
                    handle_request(
                        root=root,
                        request=last_request,
                        ollama_url=ollama_url,
                        model=model,
                        plan_mode=plan_mode,
                        dry_run=dry_run,
                        auto_commit=auto_commit,
                        five_pass_engine=five_pass_engine,
                    )
                else:
                    print(c("No previous request to retry.", YELLOW))
                continue

            if command == "/last":
                p = first_existing_state_path(root, LAST_RESPONSE_FILE, LEGACY_LAST_RESPONSE_FILE)
                if p.exists():
                    content = p.read_text(encoding="utf-8")
                    print(c("--- Last Response ---\n", BOLD + BLUE))
                    print(content)
                else:
                    print(c("No saved response.", YELLOW))
                continue

            if command == "/history":
                show_request_history(root)
                continue

            if command == "/q":
                print(c("Goodbye! 👋", GREEN))
                break

            print(c(f"Unknown command: {command}", RED))
            print(c("Type /q to quit or just ask me to code something!", MUTED))
            continue

        last_request = user_input
        append_request_history(root, user_input)

        handle_request(
            root=root,
            request=user_input,
            ollama_url=ollama_url,
            model=model,
            plan_mode=plan_mode,
            dry_run=dry_run,
            auto_commit=auto_commit,
            five_pass_engine=five_pass_engine,
        )

        p = root / LAST_RESPONSE_FILE
        p.write_text(last_request, encoding="utf-8")


if __name__ == "__main__":
    main()
