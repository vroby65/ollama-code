def show_context_summary(stats: ProjectContextStats, context_info: ModelContextInfo | None = None) -> None:
    included = len(stats.included_files)
    print(c(
        f"Project context ready: {included} files included, {format_count(stats.total_chars)} characters.",
        CYAN,
    ))

    if context_info is not None and context_info.model:
        print(c(
            (
                f"Prompt budget for {context_info.model}: about "
                f"{format_count(context_info.prompt_budget_chars)} characters "
                f"from {format_count(context_info.context_window_tokens)} context tokens "
                f"({format_context_source(context_info.source)})."
            ),
            MUTED,
        ))

    if stats.included_files:
        print(c(f"Included files: {summarize_items(stats.included_files, max_items=6)}", MUTED))

    if stats.truncated_files:
        print(c(
            f"Files truncated to {format_count(MAX_FILE_CHARS)} characters: {summarize_items(stats.truncated_files)}",
            YELLOW,
        ))

    for reason in sorted(stats.skipped_counts):
        count = stats.skipped_counts[reason]
