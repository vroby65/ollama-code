    if stats.context_truncated:
        limit = MAX_PROMPT_CHARS
        if context_info is not None:
            limit = min(MAX_PROMPT_CHARS, context_info.prompt_budget_chars)
        print(c(
            f"Total context truncated to about {format_count(limit)} characters.",
            YELLOW,
        ))


def build_runtime_config() -> dict[str, ConfigValue]:
    return {
        "main_model": DEFAULT_MAIN_MODEL,
        "review_model": DEFAULT_REVIEW_MODEL,
        "ollama_url": None,
        "plan_mode": DEFAULT_PLAN_MODE,
        "dry_run": DEFAULT_DRY_RUN,
        "auto_commit": DEFAULT_AUTO_COMMIT,
        "auto_readme": DEFAULT_AUTO_README,
    }


def normalize_model_value(value: object) -> str | None:
    if value is None:
        return None

    normalized = str(value).strip()
    if not normalized:
        return None

    if normalized.lower() in {"default", "none", "null", "reset"}:
        return None

    return normalized


def default_model_choice() -> str | None:
    return normalize_model_value(os.getenv("OLLAMA_MODEL"))


def normalize_bool_value(value: object, default: bool) -> bool:
    if isinstance(value, bool):
        return value

    if value is None:
        return default

    if isinstance(value, (int, float)):
        return bool(value)

    if isinstance(value, str):
        normalized = value.strip().lower()
        if normalized in {"1", "true", "yes", "on"}:
            return True
        if normalized in {"0", "false", "no", "off"}:
            return False

    return default


def normalize_ollama_url_value(value: object) -> str | None:
    if value is None:
        return None

    text = str(value).strip()
    if not text:
        return None

    return default_ollama_url(text)


def resolve_runtime_bool_setting(cli_value: bool | None, config_value: object, default: bool) -> bool:
    if cli_value is not None:
        return bool(cli_value)
    return normalize_bool_value(config_value, default)


def load_config_file(path: Path) -> dict[str, ConfigValue] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        print(c(f"Unable to read {path}: {exc}", YELLOW), file=sys.stderr)
        return None

    if not isinstance(data, dict):
        print(c(f"{path} does not contain a valid JSON object.", YELLOW), file=sys.stderr)
        return None

    config = build_runtime_config()

    config["main_model"] = normalize_model_value(data.get("main_model", data.get("model")))
    config["review_model"] = normalize_model_value(data.get("review_model", data.get("fallback_model")))
    config["ollama_url"] = normalize_ollama_url_value(data.get("ollama_url"))
    config["plan_mode"] = normalize_bool_value(data.get("plan_mode"), DEFAULT_PLAN_MODE)
    config["dry_run"] = normalize_bool_value(data.get("dry_run"), DEFAULT_DRY_RUN)
    config["auto_commit"] = normalize_bool_value(data.get("auto_commit"), DEFAULT_AUTO_COMMIT)
    config["auto_readme"] = normalize_bool_value(data.get("auto_readme"), DEFAULT_AUTO_README)
    return config


def load_config(root: Path) -> dict[str, ConfigValue]:
    config = build_runtime_config()
    for path in (
        get_user_config_path(),
        get_legacy_user_config_path(),
        Path.home() / LEGACY_USER_CONFIG_FILE,
        root / LEGACY_PROJECT_CONFIG_FILE,
    ):
        if not path.exists() or not path.is_file():
            continue

        loaded = load_config_file(path)
        if loaded is not None:
            config = loaded
            break

    return config


def save_config(_root: Path, config: dict[str, ConfigValue]) -> None:
