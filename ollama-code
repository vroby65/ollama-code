def load_last_request(root: Path) -> str | None:
    p = root / LAST_REQUEST_FILE
    if not p.exists():
        return None

    try:
        text = p.read_text(encoding="utf-8").strip()
    except Exception:
        return None

    return text or None


def parse_request_history_entries(root: Path) -> list[tuple[str, str]]:
    p = first_existing_state_path(root, REQUEST_HISTORY_FILE, LEGACY_REQUEST_HISTORY_FILE)
    if not p.exists():
        return []

    try:
        raw = p.read_text(encoding="utf-8")
    except Exception:
        return []

    blocks = [b.strip() for b in raw.split(REQUEST_SEPARATOR) if b.strip()]
    entries: list[tuple[str, str]] = []

    for block in blocks:
        if not block.startswith("TIME: "):
            continue

        lines = block.splitlines()
        if not lines:
            continue

        timestamp = lines[0][len("TIME: "):].strip()

        if len(lines) >= 2 and lines[1].strip() == "TEXT:":
            text = "\n".join(lines[2:]).strip()
        else:
            text = "\n".join(lines[1:]).strip()

        if text:
            entries.append((timestamp, text))

    return entries


def one_line_summary(text: str, max_chars: int = MAX_SUMMARY_ITEM_CHARS) -> str:
    s = " ".join(text.split())
    if len(s) <= max_chars:
        return s
    return s[:max_chars].rstrip() + "..."


def build_request_history_context(root: Path) -> str:
    entries = parse_request_history_entries(root)
    if not entries:
        return ""

    parts: list[str] = []
    parts.append("RECENT REQUEST SUMMARIES:")
    for ts, text in entries[-MAX_HISTORY_SUMMARY_ITEMS:]:
        parts.append(f"- [{ts}] {one_line_summary(text)}")

    result = "\n".join(parts).strip()

    if len(result) > MAX_HISTORY_CHARS:
        result = result[-MAX_HISTORY_CHARS:]
        nl = result.find("\n")
        if nl != -1:
            result = result[nl + 1:].lstrip()

    return result


def show_request_history(root: Path) -> None:
    entries = parse_request_history_entries(root)
    if not entries:
        print(c("No request history available.", YELLOW))
        return

    history_path = first_existing_state_path(root, REQUEST_HISTORY_FILE, LEGACY_REQUEST_HISTORY_FILE)
    print(c(f"--- {history_path.name} ---\n", BOLD + BLUE))
    for ts, text in entries:
        print(c(f"[{ts}]", CYAN))
        print(text)
        print()


def preview_text(text: str, max_chars: int = 280) -> str:
    normalized = " ".join(text.split())
    if len(normalized) <= max_chars:
        return normalized
    return normalized[:max_chars].rstrip() + "..."


def show_context_summary(stats: ProjectContextStats) -> None:
    included = len(stats.included_files)
    print(c(
        f"Project context ready: {included} files included, {format_count(stats.total_chars)} characters.",
        CYAN,
    ))

    if stats.included_files:
        print(c(f"Included files: {summarize_items(stats.included_files, max_items=6)}", MUTED))

    if stats.truncated_files:
        print(c(
            f"Files truncated to {format_count(MAX_FILE_CHARS)} characters: {summarize_items(stats.truncated_files)}",
            YELLOW,
        ))

    for reason in sorted(stats.skipped_counts):
        count = stats.skipped_counts[reason]
        label = SKIP_REASON_LABELS.get(reason, reason)
        examples = summarize_items(stats.skipped_examples.get(reason, []))
        if examples:
            print(c(f"Skipped {count} {label}: {examples}", MUTED))
        else:
            print(c(f"Skipped {count} {label}.", MUTED))

    if stats.context_truncated:
        print(c(
            f"Total context truncated to about {format_count(MAX_PROMPT_CHARS)} characters.",
            YELLOW,
        ))


def build_runtime_config() -> dict[str, ConfigValue]:
    return {
        "model": DEFAULT_MODEL,
        "fallback_model": DEFAULT_FALLBACK_MODEL,
        "ollama_url": None,
        "plan_mode": DEFAULT_PLAN_MODE,
        "dry_run": DEFAULT_DRY_RUN,
        "auto_commit": DEFAULT_AUTO_COMMIT,
        "five_pass_engine": DEFAULT_FIVE_PASS_ENGINE,
        "auto_readme": DEFAULT_AUTO_README,
    }


def normalize_model_value(value: object) -> str | None:
    if value is None:
        return None

    normalized = str(value).strip()
    if not normalized:
        return None

    if normalized.lower() in {"default", "none", "null", "reset"}:
        return None

    return normalized


def default_model_choice() -> str | None:
    return normalize_model_value(os.getenv("OLLAMA_MODEL"))


def configured_fallback_model_choice() -> str | None:
    return normalize_model_value(_CONFIGURED_FALLBACK_MODEL)


def set_configured_fallback_model(value: str | None) -> None:
    global _CONFIGURED_FALLBACK_MODEL
    _CONFIGURED_FALLBACK_MODEL = normalize_model_value(value)


def normalize_bool_value(value: object, default: bool) -> bool:
    if isinstance(value, bool):
        return value

    if value is None:
        return default

    if isinstance(value, (int, float)):
        return bool(value)

    if isinstance(value, str):
        normalized = value.strip().lower()
        if normalized in {"1", "true", "yes", "on"}:
            return True
        if normalized in {"0", "false", "no", "off"}:
            return False

    return default


def normalize_ollama_url_value(value: object) -> str | None:
    if value is None:
        return None

    text = str(value).strip()
    if not text:
        return None

    return default_ollama_url(text)


def resolve_runtime_bool_setting(cli_value: bool | None, config_value: object, default: bool) -> bool:
    if cli_value is not None:
        return bool(cli_value)
    return normalize_bool_value(config_value, default)


def load_config_file(path: Path) -> dict[str, ConfigValue] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        print(c(f"Unable to read {path}: {exc}", YELLOW), file=sys.stderr)
        return None

    if not isinstance(data, dict):
        print(c(f"{path} does not contain a valid JSON object.", YELLOW), file=sys.stderr)
        return None

    config = build_runtime_config()

    config["model"] = normalize_model_value(data.get("model"))
    config["fallback_model"] = normalize_model_value(data.get("fallback_model"))
    config["ollama_url"] = normalize_ollama_url_value(data.get("ollama_url"))
    config["plan_mode"] = normalize_bool_value(data.get("plan_mode"), DEFAULT_PLAN_MODE)
    config["dry_run"] = normalize_bool_value(data.get("dry_run"), DEFAULT_DRY_RUN)
    config["auto_commit"] = normalize_bool_value(data.get("auto_commit"), DEFAULT_AUTO_COMMIT)
    config["five_pass_engine"] = normalize_bool_value(
        data.get("five_pass_engine"),
        DEFAULT_FIVE_PASS_ENGINE,
    )
    config["auto_readme"] = normalize_bool_value(data.get("auto_readme"), DEFAULT_AUTO_README)
    return config


def load_config(root: Path) -> dict[str, ConfigValue]:
    config = build_runtime_config()
    for path in (
        get_user_config_path(),
        get_legacy_user_config_path(),
        Path.home() / LEGACY_USER_CONFIG_FILE,
        root / LEGACY_PROJECT_CONFIG_FILE,
    ):
        if not path.exists() or not path.is_file():
            continue

        loaded = load_config_file(path)
        if loaded is not None:
            config = loaded
            break

    return config


def save_config(_root: Path, config: dict[str, ConfigValue]) -> None:
    payload = {
        "model": normalize_model_value(config.get("model")),
        "fallback_model": normalize_model_value(config.get("fallback_model")),
        "ollama_url": normalize_ollama_url_value(config.get("ollama_url")),
        "plan_mode": normalize_bool_value(config.get("plan_mode"), DEFAULT_PLAN_MODE),
        "dry_run": normalize_bool_value(config.get("dry_run"), DEFAULT_DRY_RUN),
        "auto_commit": normalize_bool_value(config.get("auto_commit"), DEFAULT_AUTO_COMMIT),
        "five_pass_engine": normalize_bool_value(
            config.get("five_pass_engine"),
            DEFAULT_FIVE_PASS_ENGINE,
        ),
