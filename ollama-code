def resolve_toggle_choice(raw: str) -> bool | None:
    normalized = raw.strip().lower()
    if normalized in {"on", "1", "true", "yes"}:
        return True
    if normalized in {"off", "0", "false", "no"}:
        return False
    return None


def prompt_toggle_selection(command: str, current_value: bool) -> tuple[bool, bool]:
    completion_menu_available = Completion is not None and get_prompt_session() is not None

    if completion_menu_available:
        while True:
            choice = prompt_input(
                f"{command}> ",
                YELLOW,
                completer=ChoiceCompleter(["on", "off"]),
                open_completion_menu=True,
            ).strip()
            if not choice:
                return False, current_value

            selected = resolve_toggle_choice(choice)
            if selected is not None:
                return True, selected

            continue

    print(" 1. on")
    print(" 0. off")
    while True:
        choice = input(cprompt(f"{command}> ", YELLOW)).strip()
        if not choice:
            return False, current_value

        if choice == "1":
            return True, True
        if choice == "0":
            return True, False

        selected = resolve_toggle_choice(choice)
        if selected is not None:
            return True, selected

        continue


