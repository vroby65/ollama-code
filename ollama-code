def is_valid_relpath(name: str) -> bool:
    if not name.strip():
        return False
    p = Path(name)
    if p.is_absolute():
        return False
    if ".." in p.parts:
        return False
    if ".git" in p.parts:
        return False
    if p.name in INTERNAL_STATE_FILES:
        return False
    return True


def skip_reason_for_path(path: Path) -> str | None:
    if path.name in INTERNAL_STATE_FILES:
        return "internal_state"
    if path.is_symlink():
        return "symlink"
    if any(part in EXCLUDED_DIRS for part in path.parts):
        return "excluded_dir"
    if any(part in BACKUP_DIRS for part in path.parts):
        return "backup_dir"
    if path.suffix.lower() in BINARY_SUFFIXES:
        return "binary_suffix"
    try:
        if path.stat().st_size > MAX_FILE_CHARS * 4:
            return "too_large"
    except Exception:
        return "stat_error"
    return None


def should_skip_file(path: Path) -> bool:
    return skip_reason_for_path(path) is not None


def is_probably_binary(path: Path) -> bool:
    if path.suffix.lower() in BINARY_SUFFIXES:
        return True
    try:
        data = path.read_bytes()[:4096]
    except Exception:
        return True
    return b"\x00" in data


def read_file_safely(path: Path) -> tuple[str, bool]:
    if is_probably_binary(path):
        return "[NON-TEXT OR BINARY FILE]", False

    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        try:
            text = path.read_text(encoding="latin-1")
        except Exception:
            return "[NON-TEXT OR UNREADABLE FILE]", False
    except Exception:
        return "[UNREADABLE FILE]", False

    truncated = False
    if len(text) > MAX_FILE_CHARS:
        text = text[:MAX_FILE_CHARS] + "\n...[TRUNCATED]...\n"
        truncated = True
    return text, truncated


def bump_stat(stats: dict[str, int], key: str) -> None:
    stats[key] = stats.get(key, 0) + 1


def add_skip_example(store: dict[str, list[str]], reason: str, rel_path: str) -> None:
    examples = store.setdefault(reason, [])
    if len(examples) < 3:
        examples.append(rel_path)


def summarize_items(items: list[str], max_items: int = 3) -> str:
    if not items:
        return ""

    visible = items[:max_items]
    suffix = ""
    if len(items) > max_items:
        suffix = f", +{len(items) - max_items} altri"

    return ", ".join(visible) + suffix


def format_count(value: int) -> str:
    return f"{value:,}".replace(",", ".")


def safe_int(value: object) -> int:
    try:
        parsed = int(value)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        return 0
    return max(parsed, 0)


def format_duration_ns(value: int) -> str:
    if value <= 0:
        return "0s"

    seconds = value / 1_000_000_000
    if seconds < 10:
        return f"{seconds:.1f}s"
    if seconds < 60:
        return f"{seconds:.0f}s"

    minutes, seconds = divmod(int(round(seconds)), 60)
    if minutes < 60:
        return f"{minutes}m{seconds:02d}s"

    hours, minutes = divmod(minutes, 60)
    return f"{hours}h{minutes:02d}m"


def cloud_usage_duration_ns(snapshot: UsageSnapshot | None) -> int:
    if snapshot is None:
        return 0

    component_total = (
        snapshot.load_duration_ns
        + snapshot.prompt_duration_ns
        + snapshot.completion_duration_ns
    )
    if component_total > 0:
        return component_total
    return snapshot.total_duration_ns


def iter_project_files(root: Path) -> list[Path]:
    files, _, _ = scan_project_files(root)
    return files


def scan_project_files(root: Path) -> tuple[list[Path], dict[str, int], dict[str, list[str]]]:
    files = []
    skipped_counts: dict[str, int] = {}
    skipped_examples: dict[str, list[str]] = {}

    for path in root.rglob("*"):
        if not path.is_file():
            continue

        reason = skip_reason_for_path(path)
        if reason is not None:
            rel = str(path.relative_to(root))
            bump_stat(skipped_counts, reason)
            add_skip_example(skipped_examples, reason, rel)
            continue

        files.append(path)
    return sorted(files, key=lambda p: str(p.relative_to(root))), skipped_counts, skipped_examples


def collect_project_context(root: Path) -> tuple[str, ProjectContextStats]:
    chunks = []
    total = 0
    files, skipped_counts, skipped_examples = scan_project_files(root)
    stats = ProjectContextStats(
        skipped_counts=skipped_counts,
        skipped_examples=skipped_examples,
    )

    for path in files:
        rel = str(path.relative_to(root))
        content, truncated = read_file_safely(path)
        chunk = f"===FILE: {rel}===\n{content}\n===END===\n\n"

        if total + len(chunk) > MAX_PROMPT_CHARS:
            remaining = MAX_PROMPT_CHARS - total
            if remaining > 200:
                chunk = chunk[:remaining] + "\n...[CONTEXT TRUNCATED]...\n"
                chunks.append(chunk)
                total += len(chunk)
            stats.context_truncated = True
            break

        chunks.append(chunk)
        total += len(chunk)
        stats.included_files.append(rel)
        if truncated:
            stats.truncated_files.append(rel)

    stats.total_chars = total
    return "".join(chunks).rstrip(), stats


def first_existing_state_path(root: Path, current_name: str, *legacy_names: str) -> Path:
    candidates = [root / current_name, *((root / name) for name in legacy_names)]
    for path in candidates:
        if path.exists():
            return path
    return candidates[0]


def append_request_history(root: Path, request: str) -> None:
    p = root / REQUEST_HISTORY_FILE
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    entry = (
        f"TIME: {timestamp}\n"
        f"TEXT:\n{request.rstrip()}\n"
        f"{REQUEST_SEPARATOR}"
    )
    with p.open("a", encoding="utf-8") as f:
        f.write(entry)


def parse_request_history_entries(root: Path) -> list[tuple[str, str]]:
    p = first_existing_state_path(root, REQUEST_HISTORY_FILE, LEGACY_REQUEST_HISTORY_FILE)
    if not p.exists():
        return []

    try:
        raw = p.read_text(encoding="utf-8")
    except Exception:
        return []

    blocks = [b.strip() for b in raw.split(REQUEST_SEPARATOR) if b.strip()]
    entries: list[tuple[str, str]] = []

    for block in blocks:
        if not block.startswith("TIME: "):
            continue

        lines = block.splitlines()
        if not lines:
            continue

        timestamp = lines[0][len("TIME: "):].strip()

        if len(lines) >= 2 and lines[1].strip() == "TEXT:":
            text = "\n".join(lines[2:]).strip()
        else:
            text = "\n".join(lines[1:]).strip()

        if text:
            entries.append((timestamp, text))

    return entries


def one_line_summary(text: str, max_chars: int = MAX_SUMMARY_ITEM_CHARS) -> str:
    s = " ".join(text.split())
    if len(s) <= max_chars:
        return s
    return s[:max_chars].rstrip() + "..."


def build_request_history_context(root: Path) -> str:
    entries = parse_request_history_entries(root)
    if not entries:
        return ""

    last_timestamp, last_text = entries[-1]
    older = entries[:-1]

    parts: list[str] = []

    if older:
        recent_older = older[-MAX_HISTORY_SUMMARY_ITEMS:]
        parts.append("SUMMARIZED PREVIOUS REQUEST HISTORY:")
        for ts, text in recent_older:
            parts.append(f"- [{ts}] {one_line_summary(text)}")

    parts.append("")
    parts.append("LAST FULL PREVIOUS REQUEST:")
    parts.append(f"[{last_timestamp}]")
    parts.append(last_text)

    result = "\n".join(parts).strip()

    if len(result) > MAX_HISTORY_CHARS:
        result = result[-MAX_HISTORY_CHARS:]
        nl = result.find("\n")
        if nl != -1:
            result = result[nl + 1:].lstrip()

    return result


