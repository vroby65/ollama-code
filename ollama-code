def run_five_pass_code_step(
    root: Path,
    ollama_url: str,
    model: str | None,
    session_backup: dict[str, str | None],
    step_title: str,
    prompt: str,
) -> AppliedPassResult:
    print(c(f"{step_title}\n", BOLD + BLUE))
    response = call_ollama(prompt, ollama_url, model)
    save_last_response(root, response)

    if response == "":
        print(c("Errore: ollama non ha restituito una risposta valida.", RED))
        print(c(f"La risposta completa è stata salvata in {LAST_RESPONSE_FILE}", MUTED))
        return AppliedPassResult(response=response, valid_response=False)

    result = apply_code_response(root, response, session_backup)

    if not result.valid_response:
        preview = response[:1000]
        print(c("Errore: ollama non ha restituito blocchi file validi in questa passata.", RED))
        print(c("Anteprima risposta:", YELLOW))
        print(preview)
        print()
        print(c(f"La risposta completa è stata salvata in {LAST_RESPONSE_FILE}", MUTED))
        return result

    print(c(f"Risposta ollama ricevuta: {format_count(len(response))} caratteri.", MUTED))
    print(c(f"Blocchi file trovati: {len(result.files_map)}", MUTED))

    if result.no_changes:
        print(c("Nessuna nuova modifica proposta in questa passata.", YELLOW))
    else:
        print(c(
            f"File scritti su disco: {len(result.written)}. Percorsi rifiutati: {len(result.rejected)}.",
            MUTED,
        ))

    if result.changed_files and not result.no_changes:
        show_written_files_diff(result.changed_files)
    elif not result.changed_files:
        print(c("Nessuna modifica effettiva rilevata nella sessione.", YELLOW))

    show_validation_results(
        reports=result.validation_reports,
        ok=result.validation_ok,
        failures=result.validation_failures,
    )
    return result


def handle_request_single_pass(
    root: Path,
    ollama_url: str,
    request: str,
    plan_mode_enabled: bool,
    dry_run_enabled: bool,
    auto_commit_enabled: bool,
    model: str | None,
) -> None:
    request_history = build_request_history_context(root)
    append_request_history(root, request)
    target_label = format_ollama_target(model, ollama_url)

    print()
    print(c(f"Richiesta in lavorazione: {preview_text(request, max_chars=180)}", BOLD + CYAN))
    print(c(f"Target attivo: {target_label}", MUTED))
    print(c("\nLeggo i file del progetto...\n", CYAN))
    project_text, context_stats = collect_project_context(root)
    show_context_summary(context_stats)

    if request_history.strip():
        print(c(
            f"Contesto richieste precedenti: {format_count(len(request_history))} caratteri.",
            MUTED,
        ))
    else:
        print(c("Contesto richieste precedenti: nessuno.", MUTED))

    plan_text = ""
    if plan_mode_enabled:
        print(c(f"Chiedo un piano a Ollama ({target_label})...\n", CYAN))
        plan_prompt = build_plan_prompt(project_text, request, request_history=request_history)
        plan_text = call_ollama(plan_prompt, ollama_url, model, plan_mode=True)

        if plan_text:
            show_text_block("--- PIANO PROPOSTO ---", plan_text)
        else:
            print(c("Nessun piano disponibile, continuo comunque.\n", YELLOW))

    prompt = build_prompt(
        project_text,
        request,
        plan_text=plan_text,
        request_history=request_history,
    )

    print(c(f"Invio a Ollama ({target_label})...\n", CYAN))
    response = call_ollama(prompt, ollama_url, model)
    save_last_response(root, response)

    if response == "":
        print(c(f"Richiesta: {request}", BOLD))
        print()
        print(c("Errore: ollama non ha restituito una risposta valida.", RED))
        return

    if response.strip() == "NO_CHANGES":
        print(c(f"Richiesta: {request}", BOLD))
        print()
        print(c("Nessuna modifica proposta.", YELLOW))
        return

    files_map = parse_file_blocks(response)
    print(c(f"Risposta ollama ricevuta: {format_count(len(response))} caratteri.", MUTED))
    print(c(f"Blocchi file trovati: {len(files_map)}", MUTED))

    if not files_map:
        preview = response[:1000]
        print(c(f"Richiesta: {request}", BOLD))
        print()
        print(c("Errore: ollama non ha restituito blocchi file validi.", RED))
        print()
        print(c("Anteprima risposta:", YELLOW))
        print(preview)
        print()
        print(c(f"La risposta completa è stata salvata in {LAST_RESPONSE_FILE}", MUTED))
        return

    candidate_paths = [rel for rel in files_map if is_valid_relpath(rel)]
    backup = backup_files(root, candidate_paths)

    written, rejected = write_files(root, files_map)
    print(c(
        f"File scritti su disco: {len(written)}. Percorsi rifiutati: {len(rejected)}.",
        MUTED,
    ))

    if not written and not rejected:
        print(c(f"Richiesta: {request}", BOLD))
        print()
        print(c("Nessuna modifica proposta.", YELLOW))
        return

    if not has_any_changes_excluding_internal_files():
        print(c(f"Richiesta: {request}", BOLD))
        print()
        print(c("File ricevuti ma nessuna modifica rilevata.", YELLOW))
        return

    show_written_files_diff(written)
    ok, validation_reports, failures = validate_written_files(root, written)
    show_validation_results(validation_reports, ok, failures)

    if not ok:
        restore_files(root, backup)
        git_reset_written_files(written)
        print(c("Modifiche ripristinate automaticamente per errore di validazione.", RED))
        print(c(f"La risposta completa è stata salvata in {LAST_RESPONSE_FILE}", MUTED))
        return

    report = build_report(
        request=request,
        written=written,
        rejected=rejected,
        plan_text=plan_text,
        validation_reports=validation_reports,
    )

    print()
    print(c(report, BOLD))

    if dry_run_enabled:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=written,
            use_last_commit=False,
            model=model,
        )
        git_reset_written_files(written)
        restore_files(root, backup)
        print(c("\nDry-run attivo: modifiche mostrate ma non salvate.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=written,
            rejected=rejected,
            validation_reports=validation_reports,
            commit_done=False,
            summary_text=summary_text,
        )
        return

    if auto_commit_enabled:
        commit_ok = commit_written_files(written, request)
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=written,
            use_last_commit=commit_ok,
            model=model,
        )
        show_final_summary(
            root=root,
            request=request,
            written=written,
            rejected=rejected,
            validation_reports=validation_reports,
            commit_done=commit_ok,
            summary_text=summary_text,
        )
    else:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=written,
            use_last_commit=False,
            model=model,
        )
        print(c("Commit automatico disattivato: modifiche lasciate nel working tree.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=written,
            rejected=rejected,
            validation_reports=validation_reports,
            commit_done=False,
            summary_text=summary_text,
        )


