THINK_BLOCK_RE = re.compile(r"<think>.*?</think>\s*", re.IGNORECASE | re.DOTALL)


def strip_thinking_sections(text: str) -> str:
    return THINK_BLOCK_RE.sub("", text)


def clean_ollama_output(text: str) -> str:
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    text = strip_thinking_sections(text)

    cleaned = []
    for line in text.splitlines():
        s = line.strip().lower()
        if "loading" in s:
            continue
        if s.startswith("warning:"):
            continue
        if s in {"<think>", "</think>"}:
            continue
        cleaned.append(line)

    text = "\n".join(cleaned).strip()

    if text.startswith("```text"):
        text = text[len("```text"):].lstrip()
    elif text.startswith("```markdown"):
        text = text[len("```markdown"):].lstrip()
    elif text.startswith("```"):
        text = text[3:].lstrip()

    if text.endswith("```"):
        text = text[:-3].rstrip()

    if text.strip() == "NO_CHANGES":
        return "NO_CHANGES"

    pos = text.find("===FILE:")
    if pos != -1:
        text = text[pos:]

    stripped = text.strip()
    if not stripped:
        return ""
    return stripped + "\n"


def clean_plan_output(text: str) -> str:
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    text = strip_thinking_sections(text)

    cleaned = []
    for line in text.splitlines():
        s = line.strip().lower()

        if "loading" in s:
            continue
        if s.startswith("warning:"):
            continue
        if s == "```":
            continue
        if s.startswith("```text"):
            continue
        if s.startswith("```markdown"):
            continue

        cleaned.append(line)

    return "\n".join(cleaned).strip()


def should_retry_ollama(error_text: str) -> bool:
    text = error_text.lower()

    retry_markers = (
        "timeout",
        "timed out",
        "temporar",
        "unavailable",
        "connection reset",
        "connection refused",
        "connection aborted",
        "i/o timeout",
        "try again",
        "eof",
        "upstream",
        "server busy",
        "busy",
    )

    return any(marker in text for marker in retry_markers)


class Spinner:
    def __init__(self, label: str = "Attendo ollama", detail: str = ""):
        self.label = label
        self.detail = detail
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None

    def _run(self) -> None:
        i = 0
        start = time.time()
        last_len = 0

        while not self._stop.is_set():
            frame = SPINNER_FRAMES[i % len(SPINNER_FRAMES)]
            elapsed = int(time.time() - start)
            detail = f" | {self.detail}" if self.detail else ""
            plain = f"{frame} {self.label}{detail} | {elapsed}s"
            padding = " " * max(0, last_len - len(plain))
            print(f"\r{CYAN}{plain}{RESET}{padding}", end="", flush=True)
            last_len = len(plain)
            time.sleep(0.1)
            i += 1
        print("\r" + " " * last_len + "\r", end="", flush=True)

    def __enter__(self):
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        return self

    def __exit__(self, exc_type, exc, tb):
        self._stop.set()
        if self._thread is not None:
            self._thread.join(timeout=1)


def call_ollama(
    prompt: str,
    ollama_url: str,
    model: str | None,
    plan_mode: bool = False,
) -> str:
    active_model = resolve_active_model(model, ollama_url)
    last_error = ""
    base_url = default_ollama_url(ollama_url)

    if not active_model:
        print(c("Errore eseguendo ollama.", RED), file=sys.stderr)
        print(
            c(
                "Nessun modello configurato o disponibile. Usa /model oppure imposta OLLAMA_MODEL.",
                YELLOW,
            ),
            file=sys.stderr,
        )
        return ""

    print(c(
        (
            f"Eseguo Ollama su {base_url} con modello {active_model}. "
            f"Prompt: {format_count(len(prompt))} caratteri."
        ),
        MUTED,
    ))

    payload = {
        "model": active_model,
        "prompt": prompt,
        "stream": False,
    }

    for attempt in range(1, OLLAMA_MAX_ATTEMPTS + 1):
        start = time.time()
        print(c(f"Tentativo ollama {attempt}/{OLLAMA_MAX_ATTEMPTS}...", CYAN))
        with Spinner("Interagisco con ollama", detail=f"tentativo {attempt}/{OLLAMA_MAX_ATTEMPTS}"):
            data, error = request_json(
                f"{base_url}/api/generate",
                payload=payload,
                timeout=OLLAMA_TIMEOUT_SECONDS,
            )
        elapsed = time.time() - start
        print(c(f"Tempo ollama: {elapsed:.1f}s", MUTED))

        if error is None and isinstance(data, dict):
            raw = str(data.get("response") or "")
            cleaned = clean_plan_output(raw) if plan_mode else clean_ollama_output(raw)
            if cleaned.strip():
                return cleaned

            response_error = str(data.get("error") or "").strip()
            last_error = response_error or "Ollama ha restituito una risposta vuota."
        else:
            last_error = error or "Risposta non valida da Ollama."

        print(c(
            (
                "Ollama non ha restituito una risposta utile. "
                f"Dettaglio: {preview_text(last_error, max_chars=240)}"
            ),
            YELLOW,
        ))

        if attempt < OLLAMA_MAX_ATTEMPTS and should_retry_ollama(last_error):
            print(c(
                (
                    f"Tentativo ollama {attempt}/{OLLAMA_MAX_ATTEMPTS} fallito, "
                    f"ritento tra {OLLAMA_RETRY_DELAY_SECONDS}s..."
                ),
                YELLOW,
            ))
            time.sleep(OLLAMA_RETRY_DELAY_SECONDS)
            continue

        break

    print(c("Errore eseguendo ollama.", RED), file=sys.stderr)
    lowered = last_error.lower()
    if "not found" in lowered or "model" in lowered and "not found" in lowered:
        print(
            c(
                f"Modello Ollama non trovato: {active_model}. Usa /model oppure esegui `ollama pull {active_model}`.",
                YELLOW,
            ),
            file=sys.stderr,
        )
    elif any(marker in lowered for marker in ("connection refused", "connect", "timeout")):
        print(
            c(
                f"Ollama non risponde su {base_url}. Avvia `ollama serve` e riprova.",
                YELLOW,
            ),
            file=sys.stderr,
        )
    if last_error:
        print(preview_text(last_error, max_chars=800), file=sys.stderr)
    return ""


def parse_file_blocks(text: str) -> Dict[str, str]:
    result: Dict[str, str] = {}
    for path, content in BLOCK_RE.findall(text):
        path = path.strip()
        if path:
            result[path] = content.rstrip("\n") + "\n"
    return result


def read_text_snapshot(path: Path) -> str | None:
    if not path.exists():
        return None

    try:
        return path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        try:
            return path.read_text(encoding="latin-1")
        except Exception:
            return None
    except Exception:
        return None


def backup_files(root: Path, rel_paths: list[str]) -> dict[str, str | None]:
    backup: dict[str, str | None] = {}
    for rel in rel_paths:
        p = root / rel
        backup[rel] = read_text_snapshot(p)
    return backup


def restore_files(root: Path, backup: dict[str, str | None]) -> None:
    for rel, content in backup.items():
        p = root / rel
        try:
            if content is None:
                if p.exists():
                    p.unlink()
            else:
                p.parent.mkdir(parents=True, exist_ok=True)
                p.write_text(content, encoding="utf-8")
        except Exception as exc:
            print(c(f"Impossibile ripristinare {rel}: {exc}", RED), file=sys.stderr)


def extend_backup(root: Path, backup: dict[str, str | None], rel_paths: list[str]) -> None:
    for rel in rel_paths:
        if rel not in backup:
            backup[rel] = read_text_snapshot(root / rel)


def compute_changed_files(root: Path, backup: dict[str, str | None]) -> list[str]:
    changed: list[str] = []

    for rel, original in backup.items():
        current = read_text_snapshot(root / rel)
        if current != original:
            changed.append(rel)

    return sorted(changed)


def build_session_diff(root: Path, backup: dict[str, str | None], rel_paths: list[str]) -> str:
    if not rel_paths:
        return ""

    chunks: list[str] = []

    for rel in rel_paths:
        before = backup.get(rel)
        after = read_text_snapshot(root / rel)

        before_lines = [] if before is None else before.splitlines(keepends=True)
        after_lines = [] if after is None else after.splitlines(keepends=True)

        diff = "".join(
            difflib.unified_diff(
                before_lines,
                after_lines,
                fromfile=f"a/{rel}",
                tofile=f"b/{rel}",
                lineterm="\n",
            )
        )
        if diff.strip():
            chunks.append(diff)

    text = "\n\n".join(chunks).strip()
    if len(text) > MAX_SUMMARY_DIFF_CHARS:
        text = text[:MAX_SUMMARY_DIFF_CHARS].rstrip() + "\n...[DIFF TRONCATO]...\n"
    return text


def write_files(root: Path, files_map: Dict[str, str]) -> tuple[list[str], list[str]]:
    written: list[str] = []
    rejected: list[str] = []

    for rel, content in files_map.items():
        if not is_valid_relpath(rel):
            rejected.append(rel)
            continue

        dest = root / rel
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(content, encoding="utf-8")
        written.append(rel)

    return written, rejected


def git_add_written_files(written: list[str]) -> None:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if files:
        run(["git", "add", "--", *files], check=False)


def git_reset_written_files(written: list[str]) -> None:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if files:
        run(["git", "reset", "--", *files], check=False)


def has_staged_changes() -> bool:
    cp = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        text=True,
        capture_output=True,
    )
    return cp.returncode != 0


def has_any_changes_excluding_internal_files() -> bool:
    cp = run(["git", "status", "--porcelain"], check=False)
    for line in cp.stdout.splitlines():
        if any(internal in line for internal in INTERNAL_STATE_FILES):
            continue
        return True
    return False


def detect_file_kind(path: Path) -> str | None:
    suffix = path.suffix.lower()

    if suffix == ".py":
        return "python"
    if suffix == ".php":
        return "php"
    if suffix in {".js", ".mjs", ".cjs"}:
        return "javascript"
    if suffix in {".sh", ".bash"}:
        return "bash"

    if path.name in {"bashrc", "profile", ".bashrc", ".profile"}:
        return "bash"

    return None


def tool_exists(name: str) -> bool:
    cp = run(["sh", "-c", f"command -v {shlex.quote(name)}"], check=False)
    return cp.returncode == 0 and bool((cp.stdout or "").strip())


def validate_python(path: Path) -> tuple[bool, str]:
    if not tool_exists("python3"):
        return False, "python3 non trovato nel sistema"
    cp = run(["python3", "-m", "py_compile", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_php(path: Path) -> tuple[bool, str]:
    if not tool_exists("php"):
        return False, "php non trovato nel sistema"
    cp = run(["php", "-l", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_javascript(path: Path) -> tuple[bool, str]:
    if not tool_exists("node"):
        return False, "node non trovato nel sistema"
    cp = run(["node", "--check", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_bash(path: Path) -> tuple[bool, str]:
    if not tool_exists("bash"):
        return False, "bash non trovato nel sistema"
    cp = run(["bash", "-n", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_file(path: Path) -> tuple[str | None, bool, str]:
    kind = detect_file_kind(path)
    if kind is None:
        return None, True, "skip"

    if kind == "python":
        ok, msg = validate_python(path)
    elif kind == "php":
        ok, msg = validate_php(path)
    elif kind == "javascript":
        ok, msg = validate_javascript(path)
    elif kind == "bash":
        ok, msg = validate_bash(path)
    else:
        return None, True, "skip"

    return kind, ok, msg or "ok"


def validate_written_files(root: Path, written: list[str]) -> tuple[bool, list[str], list[str]]:
    reports: list[str] = []
    failures: list[str] = []

    for rel in written:
        if rel in INTERNAL_STATE_FILES:
            continue

        full = root / rel
        kind, ok, msg = validate_file(full)

        if kind is None:
            continue

        label = f"{rel} [{kind}]"
        if ok:
            reports.append(f"{label}: OK")
        else:
            failure_text = msg.strip() or "errore sconosciuto"
            reports.append(f"{label}: ERRORE")
            failures.append(f"{label}\n{failure_text}")

    return len(failures) == 0, reports, failures


def show_validation_results(
    reports: list[str],
    ok: bool,
    failures: list[str] | None = None,
) -> None:
    print(c("\n--- VALIDAZIONE SINTATTICA ---\n", BOLD + BLUE))

    if reports:
        for row in reports:
            color = GREEN if row.endswith("OK") else RED
            print(c(row, color))
    else:
        print(c("Nessun file validabile tra quelli modificati.", YELLOW))

    print(c(
        f"Validazione completata: {'OK' if ok else 'ERRORI'}",
        GREEN if ok else RED,
    ))

    if not ok and failures:
        print(c("\n--- ERRORI DI VALIDAZIONE ---\n", BOLD + RED), file=sys.stderr)
        for err in failures:
            print(err, file=sys.stderr)
            print(file=sys.stderr)


def apply_code_response(
    root: Path,
    response: str,
    session_backup: dict[str, str | None],
) -> AppliedPassResult:
    result = AppliedPassResult(response=response)

    if response.strip() == "NO_CHANGES":
        result.no_changes = True
        result.changed_files = compute_changed_files(root, session_backup)
        ok, reports, failures = validate_written_files(root, result.changed_files)
        result.validation_ok = ok
        result.validation_reports = reports
        result.validation_failures = failures
        return result

    files_map = parse_file_blocks(response)
    result.files_map = files_map

    if not files_map:
        result.valid_response = False
        return result

    candidate_paths = [rel for rel in files_map if is_valid_relpath(rel)]
    extend_backup(root, session_backup, candidate_paths)

    written, rejected = write_files(root, files_map)
    result.written = written
    result.rejected = rejected
    result.changed_files = compute_changed_files(root, session_backup)

    ok, reports, failures = validate_written_files(root, result.changed_files)
    result.validation_ok = ok
    result.validation_reports = reports
    result.validation_failures = failures
    return result


def build_report(
    request: str,
    written: list[str],
    rejected: list[str],
    plan_text: str = "",
    validation_reports: list[str] | None = None,
) -> str:
    git_add_written_files(written)
    visible_written = [f for f in written if f not in INTERNAL_STATE_FILES]

    if visible_written:
        stats_cp = run(["git", "diff", "--cached", "--stat", "--", *visible_written], check=False)
        summary_cp = run(["git", "diff", "--cached", "--summary", "--", *visible_written], check=False)
    else:
        stats_cp = run(["git", "diff", "--cached", "--stat"], check=False)
        summary_cp = run(["git", "diff", "--cached", "--summary"], check=False)

    pieces = [f"Richiesta: {request}"]

    if plan_text.strip():
        pieces.append("Piano:\n" + plan_text.strip())

    if visible_written:
        pieces.append("File scritti: " + ", ".join(visible_written))
    else:
        pieces.append("File scritti: nessuno")

    if rejected:
        pieces.append("Percorsi rifiutati: " + ", ".join(rejected))

    if validation_reports:
        pieces.append("Validazione:\n" + "\n".join(validation_reports))

    stat_text = stats_cp.stdout.strip()
    summary_text = summary_cp.stdout.strip()

    if stat_text:
        pieces.append("Stat:\n" + stat_text)
    if summary_text:
        pieces.append("Summary:\n" + summary_text)

    return "\n\n".join(pieces).strip()


def build_commit_subject(request: str) -> str:
    msg = f"ollama-code: {request.strip().replace(chr(10), ' ')}"
    if len(msg) > 72:
        msg = msg[:72].rstrip()
    return msg


def has_staged_changes_for_files(written: list[str]) -> bool:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not files:
        return False

    cp = subprocess.run(
        ["git", "diff", "--cached", "--quiet", "--", *files],
        text=True,
        capture_output=True,
    )
    return cp.returncode != 0


def commit_written_files(written: list[str], request: str) -> bool:
    git_add_written_files(written)

    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not has_staged_changes_for_files(written):
        print(c("Niente da committare.", YELLOW))
        return False

    subject = build_commit_subject(request)
    cp = run(["git", "commit", "--only", "-m", subject, "--", *files], check=False)

    if cp.stdout:
        print(cp.stdout, end="" if cp.stdout.endswith("\n") else "\n")
    if cp.stderr:
        print(cp.stderr, end="" if cp.stderr.endswith("\n") else "\n", file=sys.stderr)

    if cp.returncode == 0:
        print(c("Commit completato.", GREEN))
    else:
        print(c("Commit fallito.", RED), file=sys.stderr)

    return cp.returncode == 0


def get_diff_text_for_summary(root: Path, written: list[str], use_last_commit: bool) -> str:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not files:
        return ""

    if use_last_commit:
        cp = run(
            ["git", "show", "--format=", "--stat", "--summary", "--patch", "HEAD", "--", *files],
            check=False,
        )
    else:
        cp = run(
            ["git", "diff", "--cached", "--stat", "--summary", "--patch", "--", *files],
            check=False,
        )

    text = (cp.stdout or "").strip()
    if not text:
        return ""

    if len(text) > MAX_SUMMARY_DIFF_CHARS:
        text = text[:MAX_SUMMARY_DIFF_CHARS].rstrip() + "\n...[DIFF TRONCATO]...\n"

    return text


def generate_change_summary(
    root: Path,
    ollama_url: str,
    request: str,
    written: list[str],
    use_last_commit: bool,
    model: str | None,
) -> str:
    diff_text = get_diff_text_for_summary(root, written, use_last_commit=use_last_commit)
    if not diff_text:
        return ""

    prompt = build_change_summary_prompt(request, diff_text)
    return call_ollama(prompt, ollama_url, model, plan_mode=True).strip()


def show_final_summary(
    root: Path,
    request: str,
    written: list[str],
    rejected: list[str],
    validation_reports: list[str] | None = None,
    commit_done: bool = False,
    summary_text: str = "",
) -> None:
    print()
    print(c("=== RIEPILOGO FINALE DELLE MODIFICHE ===", BOLD + GREEN))

    if summary_text.strip():
        print(summary_text.strip())
    else:
        print(c("Nessun riepilogo testuale disponibile.", YELLOW))

    print()
    print(c("Dettagli tecnici:", BOLD))
    print(c(f"Richiesta: {request}", CYAN))

    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if files:
        print(c("File modificati:", BOLD))
        for f in files:
            print(f" - {f}")
    else:
        print(c("File modificati: nessuno", YELLOW))

    if rejected:
        print(c("Percorsi rifiutati:", YELLOW))
        for f in rejected:
            print(f" - {f}")

    if validation_reports:
        print(c("Validazione:", BOLD))
        for row in validation_reports:
            color = GREEN if row.endswith("OK") else RED
            print(c(f" - {row}", color))

    if commit_done:
        cp_hash = run(["git", "rev-parse", "--short", "HEAD"], check=False)
        commit_hash = cp_hash.stdout.strip()

        cp_subject = run(["git", "log", "-1", "--pretty=%s"], check=False)
        commit_subject = cp_subject.stdout.strip()

        if commit_hash:
            print(c(f"Commit: {commit_hash}", GREEN))
        if commit_subject:
            print(c(f"Messaggio: {commit_subject}", GREEN))


def save_last_response(root: Path, response: str) -> None:
    (root / LAST_RESPONSE_FILE).write_text(response, encoding="utf-8")


def show_last_response(root: Path) -> None:
    p = first_existing_state_path(root, LAST_RESPONSE_FILE, LEGACY_LAST_RESPONSE_FILE)
