def format_model_name(model: str | None) -> str:
    normalized = normalize_model_value(model)
    if normalized:
        return normalized

    default_model = default_model_choice()
    if default_model:
        return f"automatic ({default_model})"

    return "automatic"


def format_fallback_model_name(model: str | None) -> str:
    normalized = normalize_model_value(model)
    if normalized:
        return normalized
    return "automatic (built-in fallback order)"


def default_ollama_url(raw: str | None = None) -> str:
    value = (raw or os.getenv("OLLAMA_HOST") or "127.0.0.1:11434").strip()
    if not value:
        value = "127.0.0.1:11434"
    if "://" not in value:
        value = "http://" + value
    return value.rstrip("/")


def is_cloud_model(model: str) -> bool:
    lowered = model.strip().lower()
    return lowered.endswith(":cloud") or lowered.endswith("-cloud")


def is_ollama_cloud_url(ollama_url: str | None) -> bool:
    host = (urllib.parse.urlparse(default_ollama_url(ollama_url)).hostname or "").lower()
    return host == "ollama.com" or host.endswith(".ollama.com")


def is_cloud_target(model: str | None, ollama_url: str | None) -> bool:
    normalized = normalize_model_value(model)
    return bool(normalized and is_cloud_model(normalized)) or is_ollama_cloud_url(ollama_url)


def sync_session_usage_target(model: str | None, ollama_url: str | None) -> None:
    global _SESSION_USAGE

    resolved = normalize_model_value(model) or default_model_choice() or configured_fallback_model_choice()
    _SESSION_USAGE.last_resolved_model = resolved
    _SESSION_USAGE.last_target_was_cloud = is_cloud_target(resolved, ollama_url)
    if (
        resolved
        and _SESSION_USAGE.last_cloud_usage is not None
        and _SESSION_USAGE.last_cloud_usage.model
        and _SESSION_USAGE.last_cloud_usage.model != resolved
    ):
        _SESSION_USAGE.last_cloud_usage = None


def pick_auto_model(models: list[str]) -> str | None:
    available = unique_preserve(models)
    configured_fallback = configured_fallback_model_choice()

    if configured_fallback:
        if not available:
            return configured_fallback
        for model in available:
            if model.lower() == configured_fallback.lower():
                return model
        return configured_fallback

    if not available:
        return None

    by_lower = {model.lower(): model for model in available}
    for candidate in OLLAMA_FALLBACK_MODELS:
        matched = by_lower.get(candidate.lower())
        if matched and not is_cloud_model(matched):
            return matched

    for model in available:
        if not is_cloud_model(model):
            return model

    return available[0]


def resolve_active_model(model: str | None, ollama_url: str | None = None) -> str | None:
    normalized = normalize_model_value(model)
    if normalized:
        return normalized

    env_model = default_model_choice()
    if env_model:
        return env_model

    return pick_auto_model(discover_ollama_models(ollama_url or default_ollama_url()))


def format_ollama_target(model: str | None, ollama_url: str | None = None) -> str:
    active_model = resolve_active_model(model, ollama_url)
    if active_model:
        return f"engine: ollama, model: {active_model}"
    return "engine: ollama, model: not configured"


def show_model_status(model: str | None, ollama_url: str | None = None) -> None:
    explicit_model = normalize_model_value(model)
    active_model = resolve_active_model(model, ollama_url)

    if explicit_model:
        print(c(f"Model: {explicit_model}", GREEN))
        return

    if active_model:
        print(c(f"Model: automatic ({active_model})", YELLOW))
        return

    print(c("Model: automatic (no Ollama model available)", RED))


def usage_snapshot_from_response(data: object, active_model: str | None) -> UsageSnapshot | None:
    if not isinstance(data, dict):
        return None

    snapshot = UsageSnapshot(
        model=normalize_model_value(data.get("model")) or normalize_model_value(active_model) or "",
        prompt_tokens=safe_int(data.get("prompt_eval_count")),
        completion_tokens=safe_int(data.get("eval_count")),
        total_duration_ns=safe_int(data.get("total_duration")),
        load_duration_ns=safe_int(data.get("load_duration")),
        prompt_duration_ns=safe_int(data.get("prompt_eval_duration")),
        completion_duration_ns=safe_int(data.get("eval_duration")),
    )

    if not any((
        snapshot.prompt_tokens,
        snapshot.completion_tokens,
        snapshot.total_duration_ns,
        snapshot.load_duration_ns,
        snapshot.prompt_duration_ns,
        snapshot.completion_duration_ns,
    )):
        return None

    return snapshot


def record_response_usage(data: object, active_model: str | None, ollama_url: str | None) -> None:
    global _SESSION_USAGE

    _SESSION_USAGE.last_resolved_model = normalize_model_value(active_model)
    _SESSION_USAGE.last_target_was_cloud = is_cloud_target(active_model, ollama_url)

    snapshot = usage_snapshot_from_response(data, active_model)
    if snapshot is None or not _SESSION_USAGE.last_target_was_cloud:
        return

    _SESSION_USAGE.last_cloud_usage = snapshot
    _SESSION_USAGE.cloud_calls += 1
    _SESSION_USAGE.cloud_usage_duration_ns += cloud_usage_duration_ns(snapshot)


def build_prompt_toolbar() -> ANSI | None:
    if ANSI is None:
        return None

    usage = _SESSION_USAGE
    if not usage.last_target_was_cloud:
        return None

    model_label = usage.last_resolved_model or "automatic"
    snapshot = usage.last_cloud_usage

    if snapshot is None:
        if usage.cloud_calls > 0:
            text = (
                f" cloud {model_label}"
                " | current model: no usage yet"
                f" | session usage {format_duration_ns(usage.cloud_usage_duration_ns)}"
                f" | {usage.cloud_calls} calls "
            )
        else:
            text = f" cloud {model_label} | usage: no data yet "
        return ANSI(cansi(text, MUTED))

    last_usage = cloud_usage_duration_ns(snapshot)
    text = (
        f" cloud {snapshot.model or model_label}"
        f" | last usage {format_duration_ns(last_usage)}"
        f" | session usage {format_duration_ns(usage.cloud_usage_duration_ns)}"
        f" | {usage.cloud_calls} calls "
    )
    return ANSI(cansi(text, CYAN))


def unique_preserve(values: list[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []

    for value in values:
        normalized = str(value).strip()
        if not normalized:
            continue

        key = normalized.lower()
        if key in seen:
            continue

        seen.add(key)
        result.append(normalized)

    return result


def fetch_json(url: str, headers: dict[str, str] | None = None) -> object | None:
    data, _ = request_json(url, headers=headers)
    return data


def build_ollama_headers(ollama_url: str | None = None) -> dict[str, str] | None:
    if not is_ollama_cloud_url(ollama_url):
        return None

    api_key = os.getenv("OLLAMA_API_KEY", "").strip()
    if not api_key:
        return None

    return {"Authorization": f"Bearer {api_key}"}


def build_ollama_api_url(ollama_url: str | None, endpoint: str) -> str:
    base_url = default_ollama_url(ollama_url)
    parsed = urllib.parse.urlparse(base_url)
    base_path = parsed.path.rstrip("/")
    endpoint_path = endpoint if endpoint.startswith("/") else f"/{endpoint}"

    if base_path.endswith("/api"):
        path = base_path + endpoint_path
    else:
        path = f"{base_path}/api{endpoint_path}" if base_path else f"/api{endpoint_path}"

    return urllib.parse.urlunparse(parsed._replace(path=path))


def request_json(
    url: str,
    payload: object | None = None,
    headers: dict[str, str] | None = None,
    timeout: int = MODEL_DISCOVERY_TIMEOUT_SECONDS,
) -> tuple[object | None, str | None]:
    body: bytes | None = None
    if payload is not None:
        body = json.dumps(payload, ensure_ascii=True).encode("utf-8")

    req = urllib.request.Request(url, data=body)
    req.add_header("Accept", "application/json")
    req.add_header("User-Agent", "ollama-code/1.0")

    if body is not None:
        req.add_header("Content-Type", "application/json")

    if headers:
        for name, value in headers.items():
            req.add_header(name, value)

    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            charset = response.headers.get_content_charset() or "utf-8"
            raw_text = response.read().decode(charset)
    except urllib.error.HTTPError as exc:
        try:
            charset = exc.headers.get_content_charset() or "utf-8"
            raw_error = exc.read().decode(charset)
        except Exception:
            raw_error = str(exc)

        try:
            parsed_error = json.loads(raw_error)
        except Exception:
            parsed_error = None

        if isinstance(parsed_error, dict) and parsed_error.get("error"):
            return None, str(parsed_error.get("error"))
        return None, raw_error or str(exc)
    except (OSError, TimeoutError, urllib.error.URLError) as exc:
        return None, str(exc)

    try:
        return json.loads(raw_text), None
    except json.JSONDecodeError:
        return None, raw_text or "Invalid JSON response"


def discover_ollama_models(ollama_url: str | None = None) -> list[str]:
    url = default_ollama_url(ollama_url)
    data = fetch_json(build_ollama_api_url(url, "/tags"), headers=build_ollama_headers(url))
    models: list[str] = []

    if isinstance(data, dict):
        items = data.get("models")
        if isinstance(items, list):
            for item in items:
                if not isinstance(item, dict):
                    continue

                name = str(item.get("name", "")).strip()
                if name:
                    models.append(name)

    if models:
        return unique_preserve(models)

    if tool_exists("ollama"):
        cp = run(["ollama", "list"], check=False, timeout=MODEL_DISCOVERY_TIMEOUT_SECONDS)
        if cp.returncode == 0:
            for idx, line in enumerate(cp.stdout.splitlines()):
                if idx == 0 or not line.strip():
                    continue
                models.append(line.split()[0])

    return unique_preserve(models)


def discover_model_choices(
    ollama_url: str | None,
    current_model: str | None,
) -> tuple[list[str], str | None, bool]:
    discovered = discover_ollama_models(ollama_url)
    env_model = default_model_choice()
    note: str | None = None

    if not discovered:
        note = (
            "Ollama is not responding or is not exposing installed models. "
            "You can enter a model name manually or set OLLAMA_MODEL."
        )

    combined = unique_preserve(
        discovered
        + ([env_model] if env_model else [])
        + ([current_model] if current_model else [])
        + OLLAMA_FALLBACK_MODELS
    )

    return combined, note, True


def resolve_model_choice(
    raw: str,
    models: list[str],
    allow_custom: bool,
) -> tuple[bool, str | None]:
    choice = raw.strip()
    if not choice:
        return False, None

    if choice.lower() in {"0", "default", "none", "null", "reset"}:
        return True, None

    if choice.isdigit():
        index = int(choice) - 1
        if 0 <= index < len(models):
            return True, models[index]
        return False, None

    for model in models:
        if model.lower() == choice.lower():
            return True, model

    if allow_custom:
        return True, normalize_model_value(choice)

    return False, None


def prompt_model_selection(
    ollama_url: str | None,
    current_model: str | None,
    title: str = "Available Ollama models:",
    default_label: str | None = None,
    default_tag: str = "automatic",
    prompt_label: str = "model",
    include_env_tag: bool = True,
) -> tuple[bool, str | None]:
    models, note, allow_custom = discover_model_choices(ollama_url, current_model)

    print(c(title, BOLD + BLUE))

    default_tags: list[str] = [default_tag]
    if current_model is None:
        default_tags.append("current")
    if default_label is None:
        default_label = format_model_name(None)
    print(f" 0. {default_label} ({', '.join(default_tags)})")

    env_model = default_model_choice() if include_env_tag else None
    for idx, model in enumerate(models, start=1):
        tags: list[str] = []
        if model == current_model:
            tags.append("current")
        if env_model and model == env_model:
            tags.append("OLLAMA_MODEL")

        suffix = f" ({', '.join(tags)})" if tags else ""
        print(f" {idx}. {model}{suffix}")

    if note:
        print(c(note, MUTED))

    print(c("Type a name, number, or 'default'. You can also enter a custom model name. Press enter to cancel.", MUTED))

    while True:
        choice = input(cprompt(f"{prompt_label}> ", YELLOW)).strip()
        if not choice:
