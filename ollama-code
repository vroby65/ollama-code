    print(c("\n--- MOTORE 5 PASSI: 1/5 PIANO ---\n", BOLD + BLUE))
    plan_prompt = build_plan_prompt(project_text, request, request_history=request_history)
    plan_text = call_ollama(plan_prompt, ollama_url, model, plan_mode=True)
    save_last_response(root, plan_text)

    if plan_text:
        show_text_block("Output del passo 1", plan_text)
    else:
        print(c("Nessun piano disponibile, continuo comunque.", YELLOW))

    session_backup: dict[str, str | None] = {}
    rejected_all: list[str] = []
    last_valid_snapshot: dict[str, str | None] | None = None
    last_valid_reports: list[str] = []
    last_valid_failures: list[str] = []
    last_valid_label = ""

    current_validation_ok = True
    current_validation_reports: list[str] = []
    current_validation_failures: list[str] = []

    project_text, _ = collect_project_context(root)
    draft_prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective=(
            "realizza una prima implementazione completa seguendo richiesta e piano; "
            "preferisci modifiche semplici, robuste e valide sintatticamente"
        ),
        plan_text=plan_text,
        request_history=request_history,
    )
    draft_result = run_five_pass_code_step(
        root=root,
        ollama_url=ollama_url,
        model=model,
        session_backup=session_backup,
        step_title="--- MOTORE 5 PASSI: 2/5 BOZZA ---",
        prompt=draft_prompt,
    )
    rejected_all.extend(draft_result.rejected)

    if draft_result.valid_response and draft_result.validation_ok:
        last_valid_snapshot = backup_files(root, list(session_backup.keys()))
        last_valid_reports = draft_result.validation_reports[:]
        last_valid_failures = draft_result.validation_failures[:]
        last_valid_label = "2/5 bozza"

    current_validation_ok = draft_result.validation_ok
    current_validation_reports = draft_result.validation_reports[:]
    current_validation_failures = draft_result.validation_failures[:]

    if not draft_result.valid_response:
        restore_files(root, session_backup)
        print(c("Il motore si ferma al passo 2 per risposta non valida.", RED))
        return

    if not draft_result.changed_files:
        print(c("Il motore non ha prodotto modifiche effettive.", YELLOW))
        return

    project_text, _ = collect_project_context(root)
    session_diff = build_session_diff(root, session_backup, draft_result.changed_files)
    review_prompt = build_review_prompt(
        project_text=project_text,
        request=request,
        plan_text=plan_text,
        request_history=request_history,
        validation_text=build_validation_feedback(
            current_validation_ok,
            current_validation_reports,
            current_validation_failures,
        ),
        session_diff=session_diff,
    )

    print(c("\n--- MOTORE 5 PASSI: 3/5 REVISIONE ---\n", BOLD + BLUE))
    review_text = call_ollama(review_prompt, ollama_url, model, plan_mode=True)
    save_last_response(root, review_text)

    if review_text:
        print(review_text)
        print()
    else:
        review_text = (
            "VERDETTO: FIX\n"
            "PROBLEMI:\n"
            "- revisione non disponibile\n"
            "CORREZIONI:\n"
            "- ricontrolla correttezza, completezza e validazione\n"
            "FILE:\n"
            "- nessuno"
        )
        print(c("Revisione non disponibile, continuo con una passata correttiva prudente.", YELLOW))

    project_text, _ = collect_project_context(root)
    session_diff = build_session_diff(root, session_backup, compute_changed_files(root, session_backup))
    fix_prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective=(
            "correggi i problemi emersi da revisione e validazione senza allargare inutilmente il perimetro"
        ),
        plan_text=plan_text,
        request_history=request_history,
        review_text=review_text,
        validation_text=build_validation_feedback(
            current_validation_ok,
            current_validation_reports,
            current_validation_failures,
        ),
        session_diff=session_diff,
    )
    fix_result = run_five_pass_code_step(
        root=root,
        ollama_url=ollama_url,
        model=model,
        session_backup=session_backup,
        step_title="--- MOTORE 5 PASSI: 4/5 CORREZIONI ---",
        prompt=fix_prompt,
    )
    rejected_all.extend(fix_result.rejected)

    if last_valid_snapshot is not None:
        for rel, original in session_backup.items():
            last_valid_snapshot.setdefault(rel, original)

    if fix_result.valid_response:
        current_validation_ok = fix_result.validation_ok
        current_validation_reports = fix_result.validation_reports[:]
        current_validation_failures = fix_result.validation_failures[:]

        if fix_result.validation_ok:
            last_valid_snapshot = backup_files(root, list(session_backup.keys()))
            last_valid_reports = fix_result.validation_reports[:]
            last_valid_failures = fix_result.validation_failures[:]
            last_valid_label = "4/5 correzioni"
    else:
        print(c("Passo 4 ignorato: mantengo lo stato corrente.", YELLOW))

    project_text, _ = collect_project_context(root)
    session_diff = build_session_diff(root, session_backup, compute_changed_files(root, session_backup))
    polish_prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective=(
            "fai una rifinitura finale minima: robustezza, coerenza, nomi chiari e piccole mancanze residue; "
            "se il codice e gia buono rispondi NO_CHANGES"
        ),
        plan_text=plan_text,
        request_history=request_history,
        review_text=review_text,
        validation_text=build_validation_feedback(
            current_validation_ok,
            current_validation_reports,
            current_validation_failures,
        ),
        session_diff=session_diff,
    )
    polish_result = run_five_pass_code_step(
        root=root,
        ollama_url=ollama_url,
        model=model,
        session_backup=session_backup,
        step_title="--- MOTORE 5 PASSI: 5/5 RIFINITURA ---",
        prompt=polish_prompt,
    )
    rejected_all.extend(polish_result.rejected)

    if last_valid_snapshot is not None:
        for rel, original in session_backup.items():
            last_valid_snapshot.setdefault(rel, original)

    if polish_result.valid_response:
        current_validation_ok = polish_result.validation_ok
        current_validation_reports = polish_result.validation_reports[:]
        current_validation_failures = polish_result.validation_failures[:]

        if polish_result.validation_ok:
            last_valid_snapshot = backup_files(root, list(session_backup.keys()))
            last_valid_reports = polish_result.validation_reports[:]
            last_valid_failures = polish_result.validation_failures[:]
            last_valid_label = "5/5 rifinitura"
    else:
        print(c("Passo 5 ignorato: mantengo lo stato corrente.", YELLOW))

    final_changed = compute_changed_files(root, session_backup)
    rejected = unique_preserve(rejected_all)

    if not final_changed:
        print(c("Il motore non ha prodotto modifiche effettive.", YELLOW))
        return

    final_ok, final_reports, final_failures = validate_written_files(root, final_changed)
    if not final_ok:
        if last_valid_snapshot is not None:
            restore_files(root, last_valid_snapshot)
            final_changed = compute_changed_files(root, session_backup)
            final_reports = last_valid_reports[:]
            final_failures = last_valid_failures[:]
            print(c(
                f"Stato finale non valido: ripristino l'ultimo stato valido ({last_valid_label}).",
                YELLOW,
            ))
        else:
            restore_files(root, session_backup)
            print(c("Nessuno stato valido prodotto dal motore: modifiche ripristinate.", RED))
            print(c(f"La risposta completa è stata salvata in {LAST_RESPONSE_FILE}", MUTED))
            return

    report = build_report(
        request=request,
        written=final_changed,
        rejected=rejected,
        plan_text=plan_text,
        validation_reports=final_reports,
    )

    print()
    print(c(report, BOLD))

    if dry_run_enabled:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=final_changed,
            use_last_commit=False,
            model=model,
        )
        git_reset_written_files(final_changed)
        restore_files(root, session_backup)
        print(c("\nDry-run attivo: modifiche mostrate ma non salvate.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=final_changed,
            rejected=rejected,
            validation_reports=final_reports,
            commit_done=False,
            summary_text=summary_text,
        )
        return

    if auto_commit_enabled:
        commit_ok = commit_written_files(final_changed, request)
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=final_changed,
            use_last_commit=commit_ok,
            model=model,
        )
        show_final_summary(
            root=root,
            request=request,
            written=final_changed,
            rejected=rejected,
            validation_reports=final_reports,
            commit_done=commit_ok,
            summary_text=summary_text,
        )
    else:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=final_changed,
            use_last_commit=False,
            model=model,
        )
        print(c("Commit automatico disattivato: modifiche lasciate nel working tree.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=final_changed,
            rejected=rejected,
            validation_reports=final_reports,
            commit_done=False,
            summary_text=summary_text,
        )


def handle_request(
    root: Path,
    ollama_url: str,
    request: str,
    plan_mode_enabled: bool,
    dry_run_enabled: bool,
    auto_commit_enabled: bool,
    model: str | None,
    engine_enabled: bool,
) -> None:
    if engine_enabled:
        handle_request_five_pass(
            root=root,
            ollama_url=ollama_url,
            request=request,
            plan_mode_enabled=plan_mode_enabled,
            dry_run_enabled=dry_run_enabled,
            auto_commit_enabled=auto_commit_enabled,
            model=model,
        )
        return

    handle_request_single_pass(
        root=root,
        ollama_url=ollama_url,
        request=request,
        plan_mode_enabled=plan_mode_enabled,
        dry_run_enabled=dry_run_enabled,
        auto_commit_enabled=auto_commit_enabled,
        model=model,
    )


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="ollama-code - coding agent da terminale")
    parser.add_argument(
        "--ollama-url",
        default=os.getenv("OLLAMA_HOST"),
        help="Endpoint Ollama (default: OLLAMA_HOST oppure 127.0.0.1:11434)",
    )
    parser.add_argument("--plan", action="store_true", default=DEFAULT_PLAN_MODE, help="Abilita piano automatico")
    parser.add_argument("--dry-run", action="store_true", default=DEFAULT_DRY_RUN, help="Non salva modifiche finali")
    parser.add_argument("--no-commit", action="store_true", help="Disabilita commit automatico")
    parser.add_argument("--no-engine", action="store_true", help="Disabilita il motore a 5 passi")
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    ollama_url = default_ollama_url(args.ollama_url)
    plan_mode_enabled = args.plan
    dry_run_enabled = args.dry_run
    auto_commit_enabled = not args.no_commit
    engine_enabled = DEFAULT_FIVE_PASS_ENGINE and not args.no_engine
    last_request = ""

    setup_readline()

    root = ensure_git_repo()
    os.chdir(root)
    config = load_config(root)
    config["model"] = normalize_model_value(config.get("model"))
    request_completer = SlashCommandCompleter(config, ollama_url)

    show_ls(root)
    print(c(f"Backend: Ollama ({ollama_url})", GREEN))
    show_model_status(config["model"], ollama_url)
    show_plan_status(plan_mode_enabled)
    show_dry_status(dry_run_enabled)
    show_commit_status(auto_commit_enabled)
    show_engine_status(engine_enabled)
    print(c("Comandi: /f  /s  /diff  /model [nome|numero|default]  /plan [on|off]  /dry [on|off]  /commit [on|off]  /engine [on|off]  /retry  /last  /history  /q", YELLOW) + "\n")

    while True:
        try:
            request = prompt_input("ollama-code> ", CYAN, completer=request_completer).strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not request:
            continue

        if request.startswith("/"):
            if request == "/q":
                break
            elif request == "/f":
                list_files(root)
            elif request == "/diff":
                show_git_diff()
            elif request == "/model" or request.startswith("/model "):
                model_arg = request[len("/model"):].lstrip()

                if not model_arg:
                    selected, next_model = prompt_model_selection(
                        ollama_url=ollama_url,
                        current_model=config["model"],
                    )
                    if not selected:
                        print()
                        continue
                else:
                    models, note, allow_custom = discover_model_choices(
                        ollama_url=ollama_url,
                        current_model=config["model"],
                    )
                    ok, next_model = resolve_model_choice(model_arg, models, allow_custom)
                    if not ok:
                        print(c("Modello non valido. Usa /model per vedere le opzioni disponibili.", RED))
                        if note:
                            print(c(note, MUTED))
                        print()
                        continue

                config["model"] = next_model
                save_config(root, config)
                show_model_status(next_model, ollama_url)
            elif request.startswith("/plan"):
                next_value = parse_toggle_command(request, "/plan", plan_mode_enabled)
                if next_value is None:
                    print(c("Uso: /plan [on|off]", RED))
                else:
                    plan_mode_enabled = next_value
                    show_plan_status(plan_mode_enabled)
            elif request.startswith("/dry"):
                next_value = parse_toggle_command(request, "/dry", dry_run_enabled)
                if next_value is None:
                    print(c("Uso: /dry [on|off]", RED))
                else:
                    dry_run_enabled = next_value
                    show_dry_status(dry_run_enabled)
            elif request.startswith("/commit"):
                next_value = parse_toggle_command(request, "/commit", auto_commit_enabled)
                if next_value is None:
                    print(c("Uso: /commit [on|off]", RED))
                else:
                    auto_commit_enabled = next_value
                    show_commit_status(auto_commit_enabled)
            elif request.startswith("/engine"):
                next_value = parse_toggle_command(request, "/engine", engine_enabled)
                if next_value is None:
                    print(c("Uso: /engine [on|off]", RED))
                else:
                    engine_enabled = next_value
                    show_engine_status(engine_enabled)
            elif request == "/retry":
                if not last_request:
                    print(c("Nessuna richiesta precedente da ripetere.", YELLOW))
                else:
                    try:
                        handle_request(
                            root=root,
                            ollama_url=ollama_url,
                            request=last_request,
                            plan_mode_enabled=plan_mode_enabled,
                            dry_run_enabled=dry_run_enabled,
                            auto_commit_enabled=auto_commit_enabled,
                            model=config["model"],
                            engine_enabled=engine_enabled,
                        )
                    except KeyboardInterrupt:
                        print()
                        print(c("Richiesta interrotta.", YELLOW))
            elif request == "/last":
                show_last_response(root)
            elif request == "/history":
                show_request_history(root)
            elif request == "/s":
                run_shell_command()
            elif request.startswith("/s "):
                run_shell_command(request[3:])
            else:
                print(c("Comando sconosciuto.", RED))
            print()
            continue

        last_request = request
        try:
            handle_request(
                root=root,
                ollama_url=ollama_url,
                request=request,
                plan_mode_enabled=plan_mode_enabled,
                dry_run_enabled=dry_run_enabled,
                auto_commit_enabled=auto_commit_enabled,
                model=config["model"],
                engine_enabled=engine_enabled,
            )
        except KeyboardInterrupt:
            print()
            print(c("Richiesta interrotta.", YELLOW))
        print()

    print(c("Uscita.", MUTED))


if __name__ == "__main__":
    main()
