def run_five_pass_code_step(
    root: Path,
    ollama_url: str,
    model: str | None,
    session_backup: dict[str, str | None],
    step_title: str,
    prompt: str,
) -> AppliedPassResult:
    print(c(f"{step_title}\n", BOLD + BLUE))
    response = call_ollama(prompt, ollama_url, model)
    save_last_response(root, response)

    if response == "":
        print(c("Error: Ollama did not return a valid response.", RED))
        print(c(f"The full response was saved to {LAST_RESPONSE_FILE}", MUTED))
        return AppliedPassResult(response=response, valid_response=False)

    result = apply_code_response(root, response, session_backup)

    if not result.valid_response:
        preview = response[:1000]
        print(c("Error: Ollama did not return valid file blocks in this pass.", RED))
        print(c("Response preview:", YELLOW))
        print(preview)
        print()
        print(c(f"The full response was saved to {LAST_RESPONSE_FILE}", MUTED))
        return result

    print(c(f"Ollama response received: {format_count(len(response))} characters.", MUTED))
    print(c(f"File blocks found: {len(result.files_map)}", MUTED))

    if result.no_changes:
        print(c("No new changes proposed in this pass.", YELLOW))
    else:
        print(c(
            f"Files written to disk: {len(result.written)}. Rejected paths: {len(result.rejected)}.",
            MUTED,
        ))

    if result.changed_files and not result.no_changes:
        show_written_files_diff(result.changed_files)
    elif not result.changed_files:
        print(c("No effective changes detected in the session.", YELLOW))

    show_validation_results(
        reports=result.validation_reports,
        ok=result.validation_ok,
        failures=result.validation_failures,
    )
    return result


def handle_request_single_pass(
    root: Path,
    ollama_url: str,
    request: str,
    plan_mode_enabled: bool,
    dry_run_enabled: bool,
    auto_commit_enabled: bool,
    model: str | None,
) -> None:
    request_history = build_request_history_context(root)
    append_request_history(root, request)
    target_label = format_ollama_target(model, ollama_url)

    print()
    print(c(f"Request in progress: {preview_text(request, max_chars=180)}", BOLD + CYAN))
    print(c(f"Active target: {target_label}", MUTED))
    print(c("\nReading project files...\n", CYAN))
    project_text, context_stats = collect_project_context(root)
    show_context_summary(context_stats)

    if request_history.strip():
        print(c(
            f"Previous request context: {format_count(len(request_history))} characters.",
            MUTED,
        ))
    else:
        print(c("Previous request context: none.", MUTED))

    plan_text = ""
    if plan_mode_enabled:
        print(c(f"Requesting a plan from Ollama ({target_label})...\n", CYAN))
        plan_prompt = build_plan_prompt(project_text, request, request_history=request_history)
        plan_text = call_ollama(plan_prompt, ollama_url, model, plan_mode=True)

        if plan_text:
            show_text_block("--- PROPOSED PLAN ---", plan_text)
        else:
            print(c("No plan available, continuing anyway.\n", YELLOW))

    prompt = build_prompt(
        project_text,
        request,
        plan_text=plan_text,
        request_history=request_history,
    )

    print(c(f"Sending to Ollama ({target_label})...\n", CYAN))
    response = call_ollama(prompt, ollama_url, model)
    save_last_response(root, response)

    if response == "":
        print(c(f"Request: {request}", BOLD))
        print()
        print(c("Error: Ollama did not return a valid response.", RED))
        return

    if response.strip() == "NO_CHANGES":
        print(c(f"Request: {request}", BOLD))
        print()
        print(c("No changes proposed.", YELLOW))
        return

    files_map = parse_file_blocks(response)
    print(c(f"Ollama response received: {format_count(len(response))} characters.", MUTED))
    print(c(f"File blocks found: {len(files_map)}", MUTED))

    if not files_map:
        preview = response[:1000]
        print(c(f"Request: {request}", BOLD))
        print()
        print(c("Error: Ollama did not return valid file blocks.", RED))
        print()
        print(c("Response preview:", YELLOW))
        print(preview)
        print()
        print(c(f"The full response was saved to {LAST_RESPONSE_FILE}", MUTED))
        return

    candidate_paths = [rel for rel in files_map if is_valid_relpath(rel)]
    backup = backup_files(root, candidate_paths)

    written, rejected = write_files(root, files_map)
    print(c(
        f"Files written to disk: {len(written)}. Rejected paths: {len(rejected)}.",
        MUTED,
    ))

    if not written and not rejected:
        print(c(f"Request: {request}", BOLD))
        print()
        print(c("No changes proposed.", YELLOW))
        return

    if not has_any_changes_excluding_internal_files():
        print(c(f"Request: {request}", BOLD))
        print()
        print(c("Files were returned, but no effective changes were detected.", YELLOW))
        return

    show_written_files_diff(written)
    ok, validation_reports, failures = validate_written_files(root, written)
    show_validation_results(validation_reports, ok, failures)

    if not ok:
        restore_files(root, backup)
        git_reset_written_files(written)
        print(c("Changes were automatically restored because validation failed.", RED))
        print(c(f"The full response was saved to {LAST_RESPONSE_FILE}", MUTED))
        return

    report = build_report(
        request=request,
        written=written,
        rejected=rejected,
        plan_text=plan_text,
        validation_reports=validation_reports,
    )

    print()
    print(c(report, BOLD))

    if dry_run_enabled:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=written,
            use_last_commit=False,
            model=model,
        )
        git_reset_written_files(written)
        restore_files(root, backup)
        print(c("\nDry-run enabled: changes were shown but not kept.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=written,
            rejected=rejected,
            validation_reports=validation_reports,
            commit_done=False,
            summary_text=summary_text,
        )
        return

    if auto_commit_enabled:
        commit_ok = commit_written_files(written, request)
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=written,
            use_last_commit=commit_ok,
            model=model,
        )
        show_final_summary(
            root=root,
            request=request,
            written=written,
            rejected=rejected,
            validation_reports=validation_reports,
            commit_done=commit_ok,
            summary_text=summary_text,
        )
    else:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=written,
            use_last_commit=False,
            model=model,
        )
        print(c("Auto-commit disabled: changes were left in the working tree.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=written,
            rejected=rejected,
            validation_reports=validation_reports,
            commit_done=False,
            summary_text=summary_text,
        )


def handle_request_five_pass(
    root: Path,
    ollama_url: str,
    request: str,
    plan_mode_enabled: bool,
    dry_run_enabled: bool,
    auto_commit_enabled: bool,
    model: str | None,
) -> None:
    request_history = build_request_history_context(root)
    append_request_history(root, request)
    target_label = format_ollama_target(model, ollama_url)

    print()
    print(c(f"Request in progress: {preview_text(request, max_chars=180)}", BOLD + CYAN))
    print(c(f"Active target: {target_label}", MUTED))
    print(c("Execution mode: 5-pass engine.", MUTED))
    print(c("\nReading project files...\n", CYAN))
    project_text, context_stats = collect_project_context(root)
    show_context_summary(context_stats)

    if request_history.strip():
        print(c(
            f"Previous request context: {format_count(len(request_history))} characters.",
            MUTED,
        ))
    else:
        print(c("Previous request context: none.", MUTED))

    print(c("\n--- 5-PASS ENGINE: 1/5 PLAN ---\n", BOLD + BLUE))
    plan_prompt = build_plan_prompt(project_text, request, request_history=request_history)
    plan_text = call_ollama(plan_prompt, ollama_url, model, plan_mode=True)
    save_last_response(root, plan_text)

    if plan_text:
        show_text_block("Step 1 output", plan_text)
    else:
        print(c("No plan available, continuing anyway.", YELLOW))

    session_backup: dict[str, str | None] = {}
    rejected_all: list[str] = []
    last_valid_snapshot: dict[str, str | None] | None = None
    last_valid_reports: list[str] = []
    last_valid_failures: list[str] = []
    last_valid_label = ""

    current_validation_ok = True
    current_validation_reports: list[str] = []
    current_validation_failures: list[str] = []

    project_text, _ = collect_project_context(root)
    draft_prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective=(
            "deliver a complete first implementation that follows the request and plan; "
            "prefer simple, robust, syntactically valid changes"
        ),
        plan_text=plan_text,
        request_history=request_history,
    )
    draft_result = run_five_pass_code_step(
        root=root,
        ollama_url=ollama_url,
        model=model,
        session_backup=session_backup,
        step_title="--- 5-PASS ENGINE: 2/5 DRAFT ---",
        prompt=draft_prompt,
    )
    rejected_all.extend(draft_result.rejected)

    if draft_result.valid_response and draft_result.validation_ok:
        last_valid_snapshot = backup_files(root, list(session_backup.keys()))
        last_valid_reports = draft_result.validation_reports[:]
        last_valid_failures = draft_result.validation_failures[:]
        last_valid_label = "2/5 draft"

    current_validation_ok = draft_result.validation_ok
    current_validation_reports = draft_result.validation_reports[:]
    current_validation_failures = draft_result.validation_failures[:]

    if not draft_result.valid_response:
        restore_files(root, session_backup)
        print(c("The engine stops at step 2 because the response was invalid.", RED))
        return

    if not draft_result.changed_files:
        print(c("The engine did not produce effective changes.", YELLOW))
        return

    project_text, _ = collect_project_context(root)
    session_diff = build_session_diff(root, session_backup, draft_result.changed_files)
    review_prompt = build_review_prompt(
        project_text=project_text,
        request=request,
        plan_text=plan_text,
        request_history=request_history,
        validation_text=build_validation_feedback(
            current_validation_ok,
            current_validation_reports,
            current_validation_failures,
        ),
        session_diff=session_diff,
    )

    print(c("\n--- 5-PASS ENGINE: 3/5 REVIEW ---\n", BOLD + BLUE))
    review_text = call_ollama(review_prompt, ollama_url, model, plan_mode=True)
    save_last_response(root, review_text)

    if review_text:
        print(review_text)
        print()
    else:
        review_text = (
            "VERDICT: FIX\n"
            "ISSUES:\n"
            "- review unavailable\n"
            "FIXES:\n"
            "- recheck correctness, completeness, and validation\n"
            "FILES:\n"
            "- none"
        )
        print(c("Review unavailable, continuing with a conservative fix pass.", YELLOW))

    project_text, _ = collect_project_context(root)
    session_diff = build_session_diff(root, session_backup, compute_changed_files(root, session_backup))
    fix_prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective=(
            "fix the issues found by review and validation without expanding scope unnecessarily"
        ),
        plan_text=plan_text,
        request_history=request_history,
        review_text=review_text,
        validation_text=build_validation_feedback(
            current_validation_ok,
            current_validation_reports,
            current_validation_failures,
        ),
        session_diff=session_diff,
    )
    fix_result = run_five_pass_code_step(
        root=root,
        ollama_url=ollama_url,
        model=model,
        session_backup=session_backup,
        step_title="--- 5-PASS ENGINE: 4/5 FIXES ---",
        prompt=fix_prompt,
    )
    rejected_all.extend(fix_result.rejected)

    if last_valid_snapshot is not None:
        for rel, original in session_backup.items():
            last_valid_snapshot.setdefault(rel, original)

    if fix_result.valid_response:
        current_validation_ok = fix_result.validation_ok
        current_validation_reports = fix_result.validation_reports[:]
        current_validation_failures = fix_result.validation_failures[:]

        if fix_result.validation_ok:
            last_valid_snapshot = backup_files(root, list(session_backup.keys()))
            last_valid_reports = fix_result.validation_reports[:]
            last_valid_failures = fix_result.validation_failures[:]
            last_valid_label = "4/5 fixes"
    else:
        print(c("Step 4 ignored: keeping the current state.", YELLOW))

    project_text, _ = collect_project_context(root)
    session_diff = build_session_diff(root, session_backup, compute_changed_files(root, session_backup))
    polish_prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective=(
            "do a minimal final polish: robustness, consistency, clear naming, and small remaining gaps; "
            "if the code is already good, reply NO_CHANGES"
        ),
        plan_text=plan_text,
        request_history=request_history,
        review_text=review_text,
        validation_text=build_validation_feedback(
            current_validation_ok,
            current_validation_reports,
            current_validation_failures,
        ),
        session_diff=session_diff,
    )
    polish_result = run_five_pass_code_step(
        root=root,
        ollama_url=ollama_url,
        model=model,
        session_backup=session_backup,
        step_title="--- 5-PASS ENGINE: 5/5 POLISH ---",
        prompt=polish_prompt,
    )
    rejected_all.extend(polish_result.rejected)

    if last_valid_snapshot is not None:
        for rel, original in session_backup.items():
            last_valid_snapshot.setdefault(rel, original)

    if polish_result.valid_response:
        current_validation_ok = polish_result.validation_ok
        current_validation_reports = polish_result.validation_reports[:]
        current_validation_failures = polish_result.validation_failures[:]

        if polish_result.validation_ok:
            last_valid_snapshot = backup_files(root, list(session_backup.keys()))
            last_valid_reports = polish_result.validation_reports[:]
            last_valid_failures = polish_result.validation_failures[:]
            last_valid_label = "5/5 polish"
    else:
        print(c("Step 5 ignored: keeping the current state.", YELLOW))

    final_changed = compute_changed_files(root, session_backup)
    rejected = unique_preserve(rejected_all)

    if not final_changed:
        print(c("The engine did not produce effective changes.", YELLOW))
        return

    final_ok, final_reports, final_failures = validate_written_files(root, final_changed)
    if not final_ok:
        if last_valid_snapshot is not None:
            restore_files(root, last_valid_snapshot)
            final_changed = compute_changed_files(root, session_backup)
            final_reports = last_valid_reports[:]
            final_failures = last_valid_failures[:]
            print(c(
                f"Final state is invalid: restoring the last valid state ({last_valid_label}).",
                YELLOW,
            ))
        else:
            restore_files(root, session_backup)
            print(c("The engine did not produce any valid state: changes were restored.", RED))
            print(c(f"The full response was saved to {LAST_RESPONSE_FILE}", MUTED))
            return

    report = build_report(
        request=request,
        written=final_changed,
        rejected=rejected,
        plan_text=plan_text,
        validation_reports=final_reports,
    )

    print()
    print(c(report, BOLD))

    if dry_run_enabled:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=final_changed,
            use_last_commit=False,
            model=model,
        )
        git_reset_written_files(final_changed)
        restore_files(root, session_backup)
        print(c("\nDry-run enabled: changes were shown but not kept.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=final_changed,
            rejected=rejected,
            validation_reports=final_reports,
            commit_done=False,
            summary_text=summary_text,
        )
        return

    if auto_commit_enabled:
        commit_ok = commit_written_files(final_changed, request)
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=final_changed,
            use_last_commit=commit_ok,
            model=model,
        )
        show_final_summary(
            root=root,
            request=request,
            written=final_changed,
            rejected=rejected,
            validation_reports=final_reports,
            commit_done=commit_ok,
            summary_text=summary_text,
        )
    else:
        summary_text = generate_change_summary(
            root=root,
            ollama_url=ollama_url,
            request=request,
            written=final_changed,
            use_last_commit=False,
            model=model,
        )
        print(c("Auto-commit disabled: changes were left in the working tree.", YELLOW))
        show_final_summary(
            root=root,
            request=request,
            written=final_changed,
            rejected=rejected,
            validation_reports=final_reports,
            commit_done=False,
            summary_text=summary_text,
        )


def handle_request(
    root: Path,
    ollama_url: str,
    request: str,
    plan_mode_enabled: bool,
    dry_run_enabled: bool,
    auto_commit_enabled: bool,
    model: str | None,
    engine_enabled: bool,
) -> None:
    if engine_enabled:
        handle_request_five_pass(
            root=root,
            ollama_url=ollama_url,
            request=request,
            plan_mode_enabled=plan_mode_enabled,
            dry_run_enabled=dry_run_enabled,
            auto_commit_enabled=auto_commit_enabled,
            model=model,
        )
        return

    handle_request_single_pass(
        root=root,
        ollama_url=ollama_url,
        request=request,
        plan_mode_enabled=plan_mode_enabled,
        dry_run_enabled=dry_run_enabled,
        auto_commit_enabled=auto_commit_enabled,
        model=model,
    )


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="ollama-code - terminal coding agent")
    parser.add_argument(
        "--ollama-url",
        default=os.getenv("OLLAMA_HOST"),
        help="Ollama endpoint (default: OLLAMA_HOST or 127.0.0.1:11434)",
    )
    parser.add_argument("--plan", action="store_true", default=DEFAULT_PLAN_MODE, help="Enable automatic planning")
    parser.add_argument("--dry-run", action="store_true", default=DEFAULT_DRY_RUN, help="Do not keep final changes")
    parser.add_argument("--no-commit", action="store_true", help="Disable automatic commit")
    parser.add_argument("--no-engine", action="store_true", help="Disable the 5-pass engine")
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    ollama_url = default_ollama_url(args.ollama_url)
    plan_mode_enabled = args.plan
    dry_run_enabled = args.dry_run
    auto_commit_enabled = not args.no_commit
    engine_enabled = DEFAULT_FIVE_PASS_ENGINE and not args.no_engine
    last_request = ""
    global _SESSION_USAGE
    _SESSION_USAGE = SessionUsageState()

    setup_readline()

    root = ensure_git_repo()
    os.chdir(root)
    config = load_config(root)
    config["model"] = normalize_model_value(config.get("model"))
    sync_session_usage_target(config["model"], ollama_url)
    request_completer = SlashCommandCompleter(config, ollama_url)

    show_ls(root)
    print(c(f"Backend: Ollama ({ollama_url})", GREEN))
    show_model_status(config["model"], ollama_url)
    show_plan_status(plan_mode_enabled)
    show_dry_status(dry_run_enabled)
    show_commit_status(auto_commit_enabled)
    show_engine_status(engine_enabled)
    print(c("Commands: /f  /s  /diff  /model [name|number|default]  /plan [on|off]  /dry [on|off]  /commit [on|off]  /engine [on|off]  /retry  /last  /history  /q", YELLOW) + "\n")

    while True:
        try:
            request = prompt_input("ollama-code> ", CYAN, completer=request_completer).strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not request:
            continue

        if request.startswith("/"):
            if request == "/q":
                break
            elif request == "/f":
                list_files(root)
            elif request == "/diff":
                show_git_diff()
            elif request == "/model" or request.startswith("/model "):
                model_arg = request[len("/model"):].lstrip()

                if not model_arg:
                    selected, next_model = prompt_model_selection(
                        ollama_url=ollama_url,
                        current_model=config["model"],
                    )
                    if not selected:
                        print()
                        continue
                else:
                    models, note, allow_custom = discover_model_choices(
                        ollama_url=ollama_url,
                        current_model=config["model"],
                    )
                    ok, next_model = resolve_model_choice(model_arg, models, allow_custom)
                    if not ok:
                        print(c("Invalid model. Use /model to see the available options.", RED))
                        if note:
                            print(c(note, MUTED))
                        print()
                        continue

                config["model"] = next_model
                save_config(root, config)
                sync_session_usage_target(next_model, ollama_url)
                show_model_status(next_model, ollama_url)
            elif request.startswith("/plan"):
                next_value = parse_toggle_command(request, "/plan", plan_mode_enabled)
                if next_value is None:
                    print(c("Usage: /plan [on|off]", RED))
                else:
                    plan_mode_enabled = next_value
                    show_plan_status(plan_mode_enabled)
            elif request.startswith("/dry"):
                next_value = parse_toggle_command(request, "/dry", dry_run_enabled)
                if next_value is None:
                    print(c("Usage: /dry [on|off]", RED))
                else:
                    dry_run_enabled = next_value
                    show_dry_status(dry_run_enabled)
            elif request.startswith("/commit"):
                next_value = parse_toggle_command(request, "/commit", auto_commit_enabled)
                if next_value is None:
                    print(c("Usage: /commit [on|off]", RED))
                else:
                    auto_commit_enabled = next_value
                    show_commit_status(auto_commit_enabled)
            elif request.startswith("/engine"):
                next_value = parse_toggle_command(request, "/engine", engine_enabled)
                if next_value is None:
                    print(c("Usage: /engine [on|off]", RED))
                else:
                    engine_enabled = next_value
                    show_engine_status(engine_enabled)
            elif request == "/retry":
                if not last_request:
                    print(c("No previous request to repeat.", YELLOW))
                else:
                    try:
                        handle_request(
                            root=root,
                            ollama_url=ollama_url,
                            request=last_request,
                            plan_mode_enabled=plan_mode_enabled,
                            dry_run_enabled=dry_run_enabled,
                            auto_commit_enabled=auto_commit_enabled,
                            model=config["model"],
                            engine_enabled=engine_enabled,
                        )
                    except KeyboardInterrupt:
                        print()
                        print(c("Request interrupted.", YELLOW))
            elif request == "/last":
                show_last_response(root)
            elif request == "/history":
                show_request_history(root)
            elif request == "/s":
                run_shell_command()
            elif request.startswith("/s "):
                run_shell_command(request[3:])
            else:
                print(c("Unknown command.", RED))
            print()
            continue

        last_request = request
        try:
            handle_request(
                root=root,
                ollama_url=ollama_url,
                request=request,
                plan_mode_enabled=plan_mode_enabled,
                dry_run_enabled=dry_run_enabled,
                auto_commit_enabled=auto_commit_enabled,
                model=config["model"],
                engine_enabled=engine_enabled,
            )
        except KeyboardInterrupt:
            print()
            print(c("Request interrupted.", YELLOW))
        print()

    print(c("Exit.", MUTED))


if __name__ == "__main__":
    main()
