def ansi_wrap(seq: str) -> str:
    return f"\001{seq}\002"


def c(text: str, color: str) -> str:
    return f"{color}{text}{RESET}"


def cprompt(text: str, color: str) -> str:
    return f"{ansi_wrap(color)}{text}{ansi_wrap(RESET)}"


def cansi(text: str, color: str) -> str:
    return f"{color}{text}{RESET}"


def colorize_code(content: str, filename: str = "") -> str:
    if not PYGMENTS_AVAILABLE:
        return content
    
    try:
        if filename:
            lexer = guess_lexer_for_filename(filename, content)
        else:
            lexer = guess_lexer_for_filename("code.py", content)
        
        formatter = Terminal256Formatter(style="monokai")
        highlighted = highlight(content, lexer, formatter)
        return highlighted.rstrip() + RESET
    except Exception:
        return content


def colorize_diff_line(line: str) -> str:
    if line.startswith("+") and not line.startswith("+++"):
        return f"{GREEN}{line}{RESET}"
    elif line.startswith("-") and not line.startswith("---"):
        return f"{RED}{line}{RESET}"
    elif line.startswith("@@"):
        return f"{CYAN}{line}{RESET}"
    elif line.startswith("diff"):
        return f"{BOLD}{WHITE}{line}{RESET}"
    elif line.startswith("index"):
        return f"{DIM}{line}{RESET}"
    else:
        return line


def colorize_diff(diff_text: str) -> str:
    if not diff_text:
        return diff_text
    
    lines = diff_text.splitlines()
    colored_lines = [colorize_diff_line(line) for line in lines]
    return "\n".join(colored_lines)


def show_colored_file_diff(before: str | None, after: str | None, filename: str) -> None:
    print(c(f"\n📄 {filename}", BOLD + BLUE))
    print(c("─" * 60, DIM))
    
    before_lines = [] if before is None else before.splitlines(keepends=True)
    after_lines = [] if after is None else after.splitlines(keepends=True)
    
    diff = difflib.unified_diff(
        before_lines,
        after_lines,
        fromfile=f"a/{filename}",
        tofile=f"b/{filename}",
        lineterm="",
    )
    
    diff_text = "".join(diff)
    if diff_text.strip():
        print(colorize_diff(diff_text))
    else:
        print(c("  (no changes)", MUTED))


def show_colored_file_content(content: str, filename: str) -> None:
    print(c(f"\n📄 {filename}", BOLD + CYAN))
    print(c("─" * 60, DIM))
    print(colorize_code(content, filename))
    print()


class SlashCommandCompleter(Completer):
    def __init__(self, config: dict[str, str | None], ollama_url: str):
        self.config = config
        self.ollama_url = ollama_url

    def get_completions(self, document, complete_event):
        text = document.text_before_cursor
        if not text.startswith("/"):
            return

        parts = text.split()
        has_trailing_space = text.endswith(" ")
        prefix = parts[0] if parts else text

        if len(parts) <= 1 and not has_trailing_space:
            for command in SLASH_COMMANDS:
                if command.startswith(prefix):
                    yield Completion(
                        command,
                        start_position=-len(prefix),
                        display_meta=SLASH_COMMAND_DESCRIPTIONS.get(command, ""),
                    )
            return

        if not parts:
            return

        command = parts[0]
        current_arg = "" if has_trailing_space else parts[-1]
        current_arg_lower = current_arg.lower()

        if command in SLASH_TOGGLE_COMMANDS:
            for option in ("on", "off"):
                if option.startswith(current_arg_lower):
                    yield Completion(option, start_position=-len(current_arg), display_meta="toggle")
            return

        if command == "/model":
            current_model = normalize_model_value(self.config.get("model"))
            discovered_models, _, _ = discover_model_choices(self.ollama_url, current_model)
            default_model = default_model_choice()
            model_choices = unique_preserve(
                ["default"]
                + ([current_model] if current_model else [])
                + ([default_model] if default_model else [])
                + discovered_models
                + OLLAMA_FALLBACK_MODELS
            )
            for model_name in model_choices:
                if model_name.lower().startswith(current_arg_lower):
                    yield Completion(model_name, start_position=-len(current_arg), display_meta="model")


def get_prompt_session():
    global _PROMPT_SESSION

    if PromptSession is None or InMemoryHistory is None or ANSI is None:
        return None
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        return None

    if _PROMPT_SESSION is None:
        history = InMemoryHistory()
        for index in range(1, readline.get_current_history_length() + 1):
            item = readline.get_history_item(index)
            if item:
                history.append_string(item)
        _PROMPT_SESSION = PromptSession(history=history)

    return _PROMPT_SESSION


def prompt_input(prompt_text: str, color: str, completer=None) -> str:
    session = get_prompt_session()
    if session is None:
        return input(cprompt(prompt_text, color))

    toolbar = build_prompt_toolbar()
    value = session.prompt(
        ANSI(cansi(prompt_text, color)),
        completer=completer,
        complete_while_typing=completer is not None,
        reserve_space_for_menu=8,
        bottom_toolbar=toolbar,
    )
    if value.strip():
        readline.add_history(value)
    return value


def setup_readline() -> None:
    readline.parse_and_bind("tab: complete")
    readline.parse_and_bind("set editing-mode emacs")
    readline.parse_and_bind('"\\e[A": previous-history')
    readline.parse_and_bind('"\\e[B": next-history')
    readline.parse_and_bind('"\\e[C": forward-char')
    readline.parse_and_bind('"\\e[D": backward-char')
    readline.parse_and_bind('"\\C-a": beginning-of-line')
    readline.parse_and_bind('"\\C-e": end-of-line')

    try:
        readline.read_history_file(READLINE_HISTORY_FILE)
    except FileNotFoundError:
        pass

    def save_history() -> None:
        try:
            readline.write_history_file(READLINE_HISTORY_FILE)
        except Exception:
            pass

    atexit.register(save_history)


def run(cmd, check=False, capture=True, shell=False, env=None, timeout=None):
    return subprocess.run(
        cmd,
        check=check,
        text=True,
        capture_output=capture,
        shell=shell,
        env=env,
        timeout=timeout,
    )


def ensure_git_repo() -> Path:
    cwd = Path.cwd().resolve()
    if not (cwd / ".git").exists():
        cp = run(["git", "init"], check=False)
        if cp.returncode != 0:
            print(c("Error during git init", RED), file=sys.stderr)
            if cp.stderr:
                print(cp.stderr, file=sys.stderr)
            sys.exit(1)
        print(c("Git repository initialized.", GREEN))

    try:
        cp = run(["git", "rev-parse", "--show-toplevel"], check=True)
        return Path(cp.stdout.strip()).resolve()
    except subprocess.CalledProcessError:
        return cwd


