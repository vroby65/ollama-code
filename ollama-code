    return ANSI(cansi(text, CYAN))


def unique_preserve(values: list[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []

    for value in values:
        normalized = str(value).strip()
        if not normalized:
            continue

        key = normalized.lower()
        if key in seen:
            continue

        seen.add(key)
        result.append(normalized)

    return result


def fetch_json(url: str, headers: dict[str, str] | None = None) -> object | None:
    data, _ = request_json(url, headers=headers)
    return data


def build_ollama_headers(ollama_url: str | None = None) -> dict[str, str] | None:
    if not is_ollama_cloud_url(ollama_url):
        return None

    api_key = os.getenv("OLLAMA_API_KEY", "").strip()
    if not api_key:
        return None

    return {"Authorization": f"Bearer {api_key}"}


def build_ollama_api_url(ollama_url: str | None, endpoint: str) -> str:
    base_url = default_ollama_url(ollama_url)
    parsed = urllib.parse.urlparse(base_url)
    base_path = parsed.path.rstrip("/")
    endpoint_path = endpoint if endpoint.startswith("/") else f"/{endpoint}"

    if base_path.endswith("/api"):
        path = base_path + endpoint_path
    else:
        path = f"{base_path}/api{endpoint_path}" if base_path else f"/api{endpoint_path}"

    return urllib.parse.urlunparse(parsed._replace(path=path))


def request_json(
    url: str,
    payload: object | None = None,
    headers: dict[str, str] | None = None,
    timeout: int = MODEL_DISCOVERY_TIMEOUT_SECONDS,
) -> tuple[object | None, str | None]:
    body: bytes | None = None
    if payload is not None:
        body = json.dumps(payload, ensure_ascii=True).encode("utf-8")

    req = urllib.request.Request(url, data=body)
    req.add_header("Accept", "application/json")
    req.add_header("User-Agent", "ollama-code/1.0")

    if body is not None:
        req.add_header("Content-Type", "application/json")

    if headers:
        for name, value in headers.items():
            req.add_header(name, value)

    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            charset = response.headers.get_content_charset() or "utf-8"
            raw_text = response.read().decode(charset)
    except urllib.error.HTTPError as exc:
        try:
            charset = exc.headers.get_content_charset() or "utf-8"
            raw_error = exc.read().decode(charset)
        except Exception:
            raw_error = str(exc)

        try:
            parsed_error = json.loads(raw_error)
        except Exception:
            parsed_error = None

        if isinstance(parsed_error, dict) and parsed_error.get("error"):
            return None, str(parsed_error.get("error"))
        return None, raw_error or str(exc)
    except (OSError, TimeoutError, urllib.error.URLError) as exc:
        return None, str(exc)

    try:
        return json.loads(raw_text), None
    except json.JSONDecodeError:
        return None, raw_text or "Invalid JSON response"


def discover_ollama_models(ollama_url: str | None = None) -> list[str]:
    url = default_ollama_url(ollama_url)
    data = fetch_json(build_ollama_api_url(url, "/tags"), headers=build_ollama_headers(url))
    models: list[str] = []

    if isinstance(data, dict):
        items = data.get("models")
        if isinstance(items, list):
            for item in items:
                if not isinstance(item, dict):
                    continue

                name = str(item.get("name", "")).strip()
                if name:
                    models.append(name)

    if models:
        return unique_preserve(models)

    if tool_exists("ollama"):
        cp = run(["ollama", "list"], check=False, timeout=MODEL_DISCOVERY_TIMEOUT_SECONDS)
        if cp.returncode == 0:
            for idx, line in enumerate(cp.stdout.splitlines()):
                if idx == 0 or not line.strip():
                    continue
                models.append(line.split()[0])

    return unique_preserve(models)


def discover_model_choices(
    ollama_url: str | None,
    current_model: str | None,
) -> tuple[list[str], str | None, bool]:
    discovered = discover_ollama_models(ollama_url)
    env_model = default_model_choice()
    note: str | None = None

    if not discovered:
        note = (
            "Ollama is not responding or is not exposing installed models. "
            "You can enter a model name manually or set OLLAMA_MODEL."
        )

    combined = unique_preserve(
        discovered
        + ([env_model] if env_model else [])
        + ([current_model] if current_model else [])
        + OLLAMA_FALLBACK_MODELS
    )

    return combined, note, True


def resolve_model_choice(
    raw: str,
    models: list[str],
    allow_custom: bool,
) -> tuple[bool, str | None]:
    choice = raw.strip()
    if not choice:
        return False, None

    if choice.lower() in {"0", "default", "none", "null", "reset"}:
        return True, None

    if choice.isdigit():
        index = int(choice) - 1
        if 0 <= index < len(models):
            return True, models[index]
        return False, None

    for model in models:
        if model.lower() == choice.lower():
            return True, model

    if allow_custom:
        return True, normalize_model_value(choice)

    return False, None


def prompt_model_selection(
    ollama_url: str | None,
    current_model: str | None,
) -> tuple[bool, str | None]:
    models, note, allow_custom = discover_model_choices(ollama_url, current_model)

    print(c("Available Ollama models:", BOLD + BLUE))

    default_tags: list[str] = ["automatic"]
    if current_model is None:
        default_tags.append("current")
    print(f" 0. {format_model_name(None)} ({', '.join(default_tags)})")

    env_model = default_model_choice()
    for idx, model in enumerate(models, start=1):
        tags: list[str] = []
        if model == current_model:
            tags.append("current")
        if env_model and model == env_model:
            tags.append("OLLAMA_MODEL")

        suffix = f" ({', '.join(tags)})" if tags else ""
        print(f" {idx}. {model}{suffix}")

    if note:
        print(c(note, MUTED))

    print(c("Type a name, number, or 'default'. You can also enter a custom model name. Press enter to cancel.", MUTED))

    while True:
        choice = input(cprompt("model> ", YELLOW)).strip()
        if not choice:
            print(c("Model selection canceled.", YELLOW))
            return False, None

        ok, selected = resolve_model_choice(choice, models, allow_custom)
        if ok:
            return True, selected

        print(c("Invalid model. Try again or press enter to cancel.", RED))


