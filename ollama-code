THINK_BLOCK_RE = re.compile(
    r"<\s*(?:think|thinking)\b[^>]*>.*?<\s*/\s*(?:think|thinking)\s*>",
    re.IGNORECASE | re.DOTALL,
)


def strip_thinking_sections(text: str) -> str:
    return THINK_BLOCK_RE.sub("", text)


def clean_ollama_output(text: str) -> str:
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    text = strip_thinking_sections(text)

    lines = text.splitlines()
    while lines:
        marker = lines[0].strip().lower()
        if marker.startswith("warning:") or marker.startswith("thinking") or marker.startswith("<think"):
            lines.pop(0)
            continue
        if marker in {"```", "```text", "```markdown"}:
            lines.pop(0)
            continue
        break

    while lines:
        marker = lines[-1].strip().lower()
        if marker in {"```"}:
            lines.pop()
            continue
        break

    text = "\n".join(lines).strip()

    if text.startswith("```text"):
        text = text[len("```text"):].lstrip("\n")
    elif text.startswith("```markdown"):
        text = text[len("```markdown"):].lstrip("\n")
    elif text.startswith("```"):
        text = text[3:].lstrip("\n")

    if text.endswith("```"):
        text = text[:-3].rstrip("\n")

    stripped = text.strip()
    if stripped == "NO_CHANGES":
        return "NO_CHANGES"

    first_positions = [
        pos for pos in (
            text.find("===PATCH==="),
            text.find("diff --git "),
            text.find("--- a/"),
            text.find("--- /dev/null"),
            text.find("===FILE:"),
        )
        if pos != -1
    ]
    if first_positions:
        text = text[min(first_positions):]

    stripped = text.strip("\n")
    if not stripped:
        return ""
    return stripped + "\n"


def clean_plan_output(text: str) -> str:
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    text = strip_thinking_sections(text)

    cleaned = []
    for line in text.splitlines():
        s = line.strip().lower()
        if s.startswith("thinking") or s.startswith("<think"):
            continue
        if s.startswith("warning:"):
            continue
        if s == "```":
            continue
        if s.startswith("```text"):
            continue
        if s.startswith("```markdown"):
            continue

        cleaned.append(line)

    return "\n".join(cleaned).strip()


def should_retry_ollama(error_text: str) -> bool:
    text = error_text.lower()

    retry_markers = (
        "timeout",
        "timed out",
        "temporar",
        "unavailable",
        "connection reset",
        "connection refused",
        "connection aborted",
        "i/o timeout",
        "try again",
        "eof",
        "upstream",
        "server busy",
        "busy",
    )

    return any(marker in text for marker in retry_markers)


class Spinner:
    def __init__(self, label: str = "Waiting for Ollama", detail: str = ""):
        self.label = label
        self.detail = detail
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None

    def _run(self) -> None:
        i = 0
        start = time.time()
        last_len = 0

        while not self._stop.is_set():
            frame = SPINNER_FRAMES[i % len(SPINNER_FRAMES)]
            elapsed = int(time.time() - start)
            detail = f" | {self.detail}" if self.detail else ""
            plain = f"{frame} {self.label}{detail} | {elapsed}s"
            padding = " " * max(0, last_len - len(plain))
            print(f"\r{CYAN}{plain}{RESET}{padding}", end="", flush=True)
            last_len = len(plain)
            time.sleep(0.1)
            i += 1
        print("\r" + " " * last_len + "\r", end="", flush=True)

    def __enter__(self):
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        return self

    def __exit__(self, exc_type, exc, tb):
        self._stop.set()
        if self._thread is not None:
            self._thread.join(timeout=1)


def call_ollama(
    prompt: str,
    ollama_url: str,
    model: str | None,
    plan_mode: bool = False,
) -> str:
    active_model = resolve_active_model(model, ollama_url)
    last_error = ""
    base_url = default_ollama_url(ollama_url)
    headers = build_ollama_headers(base_url)

    _SESSION_USAGE.last_resolved_model = normalize_model_value(active_model)
    _SESSION_USAGE.last_target_was_cloud = is_cloud_target(active_model, ollama_url)

    if not active_model:
        print(c("Error while running Ollama.", RED), file=sys.stderr)
        print(
            c(
                "No model configured or available. Use /model, /fallback-model, or set OLLAMA_MODEL.",
                YELLOW,
            ),
            file=sys.stderr,
        )
        return ""

    if is_ollama_cloud_url(base_url) and headers is None:
        print(c("Error while running Ollama.", RED), file=sys.stderr)
        print(
            c(
                "Direct requests to ollama.com require OLLAMA_API_KEY. Set it or use a local Ollama instance.",
                YELLOW,
            ),
            file=sys.stderr,
        )
        return ""

    print(c(
        (
            f"Running Ollama on {base_url} with model {active_model}. "
            f"Prompt: {format_count(len(prompt))} characters."
        ),
        MUTED,
    ))

    payload = {
        "model": active_model,
        "prompt": prompt,
        "stream": False,
    }

    for attempt in range(1, OLLAMA_MAX_ATTEMPTS + 1):
        start = time.time()
        print(c(f"Ollama attempt {attempt}/{OLLAMA_MAX_ATTEMPTS}...", CYAN))
        with Spinner("Talking to Ollama", detail=f"attempt {attempt}/{OLLAMA_MAX_ATTEMPTS}"):
            data, error = request_json(
                build_ollama_api_url(base_url, "/generate"),
                payload=payload,
                headers=headers,
                timeout=OLLAMA_TIMEOUT_SECONDS,
            )
        elapsed = time.time() - start
        print(c(f"Ollama time: {elapsed:.1f}s", MUTED))

        if error is None and isinstance(data, dict):
            record_response_usage(data, active_model, ollama_url)
            raw = str(data.get("response") or "")
            cleaned = clean_plan_output(raw) if plan_mode else clean_ollama_output(raw)
            if cleaned.strip():
                return cleaned

            response_error = str(data.get("error") or "").strip()
            last_error = response_error or "Ollama returned an empty response."
        else:
            last_error = error or "Invalid response from Ollama."

        print(c(
            (
                "Ollama did not return a usable response. "
                f"Detail: {preview_text(last_error, max_chars=240)}"
            ),
            YELLOW,
        ))

        if attempt < OLLAMA_MAX_ATTEMPTS and should_retry_ollama(last_error):
            print(c(
                (
                    f"Ollama attempt {attempt}/{OLLAMA_MAX_ATTEMPTS} failed, "
                    f"retrying in {OLLAMA_RETRY_DELAY_SECONDS}s..."
                ),
                YELLOW,
            ))
            time.sleep(OLLAMA_RETRY_DELAY_SECONDS)
            continue

        break

    print(c("Error while running Ollama.", RED), file=sys.stderr)
    lowered = last_error.lower()
    if "not found" in lowered or "model" in lowered and "not found" in lowered:
        print(
            c(
                f"Ollama model not found: {active_model}. Use /model or run `ollama pull {active_model}`.",
                YELLOW,
            ),
            file=sys.stderr,
        )
    elif any(marker in lowered for marker in ("connection refused", "connect", "timeout")):
        print(
            c(
                f"Ollama is not responding on {base_url}. Start `ollama serve` and try again.",
                YELLOW,
            ),
            file=sys.stderr,
        )
    if last_error:
        print(preview_text(last_error, max_chars=800), file=sys.stderr)
    return ""


def parse_file_blocks(text: str) -> Dict[str, str]:
    result: Dict[str, str] = {}
    for path, content in BLOCK_RE.findall(text):
        path = path.strip()
        if path:
            result[path] = content.rstrip("\n") + "\n"
    return result


def parse_patch_blocks(text: str) -> list[str]:
    blocks = [block.strip("\n") for block in PATCH_BLOCK_RE.findall(text) if block.strip()]
    if blocks:
        return [block + "\n" for block in blocks]

    stripped = text.strip()
    if not stripped:
        return []

    has_unified_markers = (
        stripped.startswith("diff --git ")
        or (
            stripped.startswith("--- ")
            and "\n+++ " in stripped
            and "\n@@" in stripped
        )
    )
    if has_unified_markers:
        return [stripped + "\n"]

    return []


def normalize_patch_header_path(raw_path: str) -> str | None:
    text = raw_path.strip()
    if not text:
        return None

    text = text.split("\t", 1)[0].strip()
    if text == "/dev/null":
        return None

    if text.startswith('"') and text.endswith('"') and len(text) >= 2:
        text = text[1:-1]

    if text.startswith(("a/", "b/")):
        text = text[2:]

    return text.strip() or None


def extract_patch_paths(patch_text: str) -> tuple[list[str], list[str]]:
    touched: list[str] = []
    rejected: list[str] = []

    for _, raw_path in PATCH_HEADER_RE.findall(patch_text):
        rel = normalize_patch_header_path(raw_path)
        if rel is None:
            continue
        if not is_valid_relpath(rel):
            rejected.append(rel)
            continue
        touched.append(rel)

    for old_path, new_path in PATCH_DIFF_GIT_RE.findall(patch_text):
        for raw_path in (old_path, new_path):
            rel = normalize_patch_header_path(raw_path)
            if rel is None:
                continue
            if not is_valid_relpath(rel):
                rejected.append(rel)
                continue
            touched.append(rel)

    return unique_preserve(touched), unique_preserve(rejected)


def check_unified_patch(root: Path, patch_text: str) -> tuple[bool, str]:
    cp = subprocess.run(
        [
            "git",
            "-C",
            str(root),
            "apply",
            "--check",
            "--whitespace=nowarn",
            "--recount",
            "--unidiff-zero",
            "-",
        ],
        input=patch_text,
        text=True,
        capture_output=True,
    )

    if cp.returncode == 0:
        return True, ""

    output = ((cp.stderr or "").strip() or (cp.stdout or "").strip())
    if not output:
        output = "git apply --check failed."
    return False, output


def apply_unified_patch(root: Path, patch_text: str) -> tuple[bool, str]:
    cp = subprocess.run(
        [
            "git",
            "-C",
            str(root),
            "apply",
            "--whitespace=nowarn",
            "--recount",
            "--unidiff-zero",
            "-",
        ],
        input=patch_text,
        text=True,
        capture_output=True,
    )

    if cp.returncode == 0:
        return True, ""

    output = ((cp.stderr or "").strip() or (cp.stdout or "").strip())
    if not output:
        output = "git apply failed."
    return False, output


def read_text_snapshot(path: Path) -> str | None:
    if not path.exists():
        return None

    try:
        return path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        try:
            return path.read_text(encoding="latin-1")
        except Exception:
            return None
    except Exception:
        return None


def backup_files(root: Path, rel_paths: list[str]) -> dict[str, str | None]:
    backup: dict[str, str | None] = {}
    for rel in rel_paths:
        p = root / rel
        backup[rel] = read_text_snapshot(p)
    return backup


def restore_files(root: Path, backup: dict[str, str | None]) -> None:
    for rel, content in backup.items():
        p = root / rel
        try:
            if content is None:
                if p.exists():
                    p.unlink()
            else:
                p.parent.mkdir(parents=True, exist_ok=True)
                p.write_text(content, encoding="utf-8")
        except Exception as exc:
            print(c(f"Unable to restore {rel}: {exc}", RED), file=sys.stderr)


def extend_backup(root: Path, backup: dict[str, str | None], rel_paths: list[str]) -> None:
    for rel in rel_paths:
        if rel not in backup:
            backup[rel] = read_text_snapshot(root / rel)


def compute_changed_files(root: Path, backup: dict[str, str | None]) -> list[str]:
    changed: list[str] = []

    for rel, original in backup.items():
        current = read_text_snapshot(root / rel)
        if current != original:
            changed.append(rel)

    return sorted(changed)


def build_session_diff(root: Path, backup: dict[str, str | None], rel_paths: list[str]) -> str:
    if not rel_paths:
        return ""

    chunks: list[str] = []

    for rel in rel_paths:
        before = backup.get(rel)
        after = read_text_snapshot(root / rel)

        before_lines = [] if before is None else before.splitlines(keepends=True)
        after_lines = [] if after is None else after.splitlines(keepends=True)

        diff = "".join(
            difflib.unified_diff(
                before_lines,
                after_lines,
                fromfile=f"a/{rel}",
                tofile=f"b/{rel}",
                lineterm="\n",
            )
        )
        if diff.strip():
            chunks.append(diff)

    text = "\n\n".join(chunks).strip()
    if len(text) > MAX_SUMMARY_DIFF_CHARS:
        text = text[:MAX_SUMMARY_DIFF_CHARS].rstrip() + "\n...[DIFF TRUNCATED]...\n"
    return text


def write_files(root: Path, files_map: Dict[str, str]) -> tuple[list[str], list[str]]:
    written: list[str] = []
    rejected: list[str] = []

    for rel, content in files_map.items():
        if not is_valid_relpath(rel):
            rejected.append(rel)
            continue

        dest = root / rel
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(content, encoding="utf-8")
        written.append(rel)

    return written, rejected


def git_add_written_files(written: list[str]) -> None:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if files:
        run(["git", "add", "--", *files], check=False)


def git_reset_written_files(written: list[str]) -> None:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if files:
        run(["git", "reset", "--", *files], check=False)


def has_staged_changes() -> bool:
    cp = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        text=True,
        capture_output=True,
    )
    return cp.returncode != 0


def has_any_changes_excluding_internal_files() -> bool:
    cp = run(["git", "status", "--porcelain"], check=False)
    for line in cp.stdout.splitlines():
        if any(internal in line for internal in INTERNAL_STATE_FILES):
            continue
        return True
    return False


def detect_file_kind(path: Path) -> str | None:
    suffix = path.suffix.lower()

    if suffix == ".py":
        return "python"
    if suffix == ".php":
        return "php"
    if suffix in {".js", ".mjs", ".cjs"}:
        return "javascript"
    if suffix in {".sh", ".bash"}:
        return "bash"

    if path.name in {"bashrc", "profile", ".bashrc", ".profile"}:
        return "bash"

    return None


def tool_exists(name: str) -> bool:
    cp = run(["sh", "-c", f"command -v {shlex.quote(name)}"], check=False)
    return cp.returncode == 0 and bool((cp.stdout or "").strip())


def validate_python(path: Path) -> tuple[bool, str]:
    if not tool_exists("python3"):
        return False, "python3 not found on the system"
    cp = run(["python3", "-m", "py_compile", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_php(path: Path) -> tuple[bool, str]:
    if not tool_exists("php"):
        return False, "php not found on the system"
    cp = run(["php", "-l", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_javascript(path: Path) -> tuple[bool, str]:
    if not tool_exists("node"):
        return False, "node not found on the system"
    cp = run(["node", "--check", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_bash(path: Path) -> tuple[bool, str]:
    if not tool_exists("bash"):
        return False, "bash not found on the system"
    cp = run(["bash", "-n", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_file(path: Path) -> tuple[str | None, bool, str]:
    kind = detect_file_kind(path)
    if kind is None:
        return None, True, "skip"

    if kind == "python":
        ok, msg = validate_python(path)
    elif kind == "php":
        ok, msg = validate_php(path)
    elif kind == "javascript":
        ok, msg = validate_javascript(path)
    elif kind == "bash":
        ok, msg = validate_bash(path)
    else:
        return None, True, "skip"

    return kind, ok, msg or "ok"


def validate_written_files(root: Path, written: list[str]) -> tuple[bool, list[str], list[str]]:
    reports: list[str] = []
    failures: list[str] = []

    for rel in written:
        if rel in INTERNAL_STATE_FILES:
            continue

        path = root / rel
        if not path.exists():
            continue

        kind, ok, msg = validate_file(path)

        if kind is None:
            continue

        report = f"{rel} ({kind}): {msg}"
        reports.append(report)

        if not ok:
            failures.append(report)

    return len(failures) == 0, reports, failures


def has_python_tests(root: Path) -> bool:
    if (root / "tests").is_dir():
        return True
    if any(root.glob("test_*.py")) or any(root.glob("*_test.py")):
        return True

    pyproject = root / "pyproject.toml"
    if pyproject.exists():
        try:
            content = pyproject.read_text(encoding="utf-8")
            if "[tool.pytest" in content:
                return True
        except Exception:
            pass

    return (root / "pytest.ini").exists()


def python_module_available(module_name: str) -> bool:
    if not tool_exists("python3"):
        return False

    cp = run(["python3", "-c", f"import {module_name}"], check=False)
    return cp.returncode == 0


def default_python_test_command(root: Path) -> str:
    if (root / "tests").is_dir():
        return "python3 -m unittest discover -s tests -p 'test_*.py' -q"
    return "python3 -m unittest discover -s . -p 'test_*.py' -q"


def detect_test_command(root: Path) -> tuple[str | None, str | None]:
    explicit = os.getenv("OLLAMA_CODE_TEST_COMMAND", "").strip()
    if explicit:
        return explicit, None

    if has_python_tests(root):
        if tool_exists("python3"):
            if python_module_available("pytest"):
                return "python3 -m pytest -q", None
            return default_python_test_command(root), None
        return None, "Python tests detected but python3 is not available."

    package_json = root / "package.json"
    if package_json.exists():
        for command in ("pnpm test", "npm test", "yarn test"):
            if tool_exists(command.split()[0]):
                return command, None
        return None, "package.json found but npm/pnpm/yarn is not available."

    return None, None


def truncate_validation_output(text: str, max_chars: int = MAX_TEST_OUTPUT_CHARS) -> str:
    cleaned = text.strip()
    if len(cleaned) <= max_chars:
        return cleaned

    head = max_chars // 2
    tail = max(1, max_chars - head - len("\n...[OUTPUT TRUNCATED]...\n"))
    return (
        cleaned[:head].rstrip()
        + "\n...[OUTPUT TRUNCATED]...\n"
        + cleaned[-tail:].lstrip()
    )


def run_project_tests(root: Path) -> tuple[bool, list[str], list[str]]:
    command, reason = detect_test_command(root)

    if command is None:
        if reason:
            return False, [f"tests: {reason}"], [f"tests: {reason}"]
        return True, [], []

    try:
        cp = run(
            command,
            shell=True,
            check=False,
            timeout=TEST_RUN_TIMEOUT_SECONDS,
        )
    except subprocess.TimeoutExpired:
        timeout_msg = (
            f"tests ({command}) timed out after {TEST_RUN_TIMEOUT_SECONDS}s"
        )
        return False, [timeout_msg], [timeout_msg]

    output = ((cp.stdout or "") + ("\n" if cp.stdout and cp.stderr else "") + (cp.stderr or ""))
    output = truncate_validation_output(output)

    status = "ok" if cp.returncode == 0 else f"failed (exit {cp.returncode})"
    report_lines = [f"tests ({command}): {status}"]
    if output:
        report_lines.append(output)
    report = "\n".join(report_lines).strip()

    if cp.returncode == 0:
        return True, [report], []
    return False, [report], [report]


def build_generated_readme_instructions(
    request: str,
    changed_files: list[str],
    test_command: str | None,
) -> str:
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    files = unique_preserve([f for f in changed_files if f not in INTERNAL_STATE_FILES])
    if not files:
        files = ["(no file changes detected)"]

    lines = [
        "## Generated Code Instructions",
        "",
        f"- Generated at: `{timestamp}`",
        "- Original request: recorded in `.ollama-code-last-request.txt` and request history.",
        "",
        "### Changed Files",
    ]
    lines.extend(f"- `{path}`" for path in files)

    lines.extend(
        [
            "",
            "### Validation And Test Flow",
            "- Syntax checks run automatically based on file type.",
            "- If checks fail, changes are rolled back and a corrective pass is executed.",
        ]
    )

    if test_command:
        lines.append(f"- Test command detected: `{test_command}`")
    else:
        lines.append("- Test command detected: none (configure `OLLAMA_CODE_TEST_COMMAND` if needed).")

    lines.extend(
        [
            "",
            "### Suggested Review Checklist",
            "1. Review the changed files listed above.",
            "2. Run the detected test command and verify expected behavior.",
            "3. Confirm edge cases and error handling for modified paths.",
        ]
    )

    return "\n".join(lines).rstrip()


def upsert_generated_readme_section(existing_readme: str, section_text: str) -> str:
    block = (
        f"{GENERATED_README_START}\n"
        f"{section_text.rstrip()}\n"
        f"{GENERATED_README_END}"
    )

    existing = existing_readme.rstrip()
    pattern = re.compile(
        re.escape(GENERATED_README_START) + r".*?" + re.escape(GENERATED_README_END),
        re.DOTALL,
    )

    if existing and pattern.search(existing):
        updated = pattern.sub(block, existing)
        return updated.rstrip() + "\n"

    if existing:
        return existing + "\n\n" + block + "\n"

    return "# README\n\n" + block + "\n"


def generate_readme_instructions_for_changes(
    root: Path,
    request: str,
    changed_files: list[str],
    backup: dict[str, str | None] | None = None,
) -> tuple[bool, str | None]:
    files = unique_preserve([f for f in changed_files if f not in INTERNAL_STATE_FILES])
    if not files:
        return False, None

    readme_rel = "README.md"
    readme_path = root / readme_rel
    existing_readme = read_text_snapshot(readme_path) or ""
    test_command, _ = detect_test_command(root)
    instructions = build_generated_readme_instructions(
        request=request,
        changed_files=files,
        test_command=test_command,
    )
    updated_readme = upsert_generated_readme_section(existing_readme, instructions)

    if updated_readme == existing_readme:
        return False, None

    if backup is not None:
        extend_backup(root, backup, [readme_rel])

    readme_path.write_text(updated_readme, encoding="utf-8")
    print(c("README.md updated with generated code instructions.", CYAN))
    return True, readme_rel


def apply_pass(
    root: Path,
    project_text: str,
    request: str,
    ollama_url: str,
    model: str | None,
    plan_text: str = "",
    request_history: str = "",
    review_text: str = "",
    validation_text: str = "",
    session_diff: str = "",
    backup: dict[str, str | None] | None = None,
) -> AppliedPassResult:
    objective = "deliver a complete first implementation that matches the request"
    if review_text.strip():
        objective = "fix the issues identified in the review"
    elif validation_text.strip() and "ERRORS" in validation_text:
        objective = "fix the syntax errors and validation failures"

    prompt = build_code_prompt(
        project_text=project_text,
        request=request,
        objective=objective,
        plan_text=plan_text,
        request_history=request_history,
        review_text=review_text,
        validation_text=validation_text,
        session_diff=session_diff,
    )

    response = call_ollama(prompt, ollama_url, model, plan_mode=False)
    save_last_response(root, response)

    result = AppliedPassResult(
        response=response,
        valid_response=bool(response.strip()),
    )

    if not response.strip():
        result.no_changes = True
        return result

    if response.strip() == "NO_CHANGES":
        result.no_changes = True
        return result

    patch_blocks = parse_patch_blocks(response)
    wrote_from_patch = False
    if patch_blocks:
        patch_text = "\n".join(block.rstrip("\n") for block in patch_blocks).strip()
        if patch_text:
            patch_text += "\n"

        rel_paths, rejected = extract_patch_paths(patch_text)
        result.rejected = rejected

        if rejected:
            print(c(f"\n❌ Patch rejected: invalid paths: {', '.join(rejected)}", RED))
            result.valid_response = False
            return result

        if not rel_paths:
            result.valid_response = False
            return result

        patch_ok, patch_error = check_unified_patch(root, patch_text)
        if not patch_ok:
            print(c(f"\n❌ Patch check failed: {preview_text(patch_error, max_chars=300)}", RED))
            result.valid_response = False
            return result

        restore_snapshot = backup if backup is not None else backup_files(root, rel_paths)
        if backup is not None:
            extend_backup(root, backup, rel_paths)

        applied, patch_error = apply_unified_patch(root, patch_text)
        if not applied:
            print(c(f"\n❌ Patch apply failed: {preview_text(patch_error, max_chars=300)}", RED))
            result.valid_response = False
            return result

        result.written = rel_paths
        wrote_from_patch = True
    else:
        files_map = parse_file_blocks(response)
        result.files_map = files_map

        if not files_map:
            result.valid_response = False
            return result

        rel_paths = list(files_map.keys())
        restore_snapshot = backup if backup is not None else backup_files(root, rel_paths)
        if backup is not None:
            extend_backup(root, backup, rel_paths)

        written, rejected = write_files(root, files_map)
        result.written = written
        result.rejected = rejected

    if result.written or wrote_from_patch:
        changed = compute_changed_files(root, restore_snapshot)
        result.changed_files = changed
        if not changed and not result.rejected:
            result.no_changes = True

        valid, reports, failures = validate_written_files(root, changed or result.written)
        result.validation_reports = reports
        result.validation_failures = failures

        tests_ok = True
        test_reports: list[str] = []
        test_failures: list[str] = []
        if valid and changed:
            tests_ok, test_reports, test_failures = run_project_tests(root)

        result.test_reports = test_reports
        result.test_failures = test_failures
        result.validation_ok = valid and tests_ok

        if not result.validation_ok:
            print(c("\n❌ Validation/tests failed. Rolling back changes.", RED))
            for failure in failures:
                print(c(f"  - {failure}", YELLOW))
            for failure in test_failures:
                print(c(f"  - {preview_text(failure, max_chars=300)}", YELLOW))
            restore_files(root, restore_snapshot)
            result.changed_files = compute_changed_files(root, restore_snapshot)

    return result


def run_five_pass_engine(
    root: Path,
    project_text: str,
    request: str,
    ollama_url: str,
    model: str | None,
    request_history: str = "",
    backup: dict[str, str | None] | None = None,
) -> tuple[bool, list[str]]:
    print(c("\n🔄 Starting five-pass engine...", BOLD + CYAN))

    backup_map = backup if backup is not None else {}
    all_written: list[str] = []

    plan_text = ""
    plan_prompt = build_plan_prompt(project_text, request, request_history)
    plan_text = call_ollama(plan_prompt, ollama_url, model, plan_mode=True)
    plan_text = clean_plan_output(plan_text)
    if plan_text:
        print(c("\n📋 Plan generated.", GREEN))

    draft_result = apply_pass(
        root=root,
        project_text=project_text,
        request=request,
        ollama_url=ollama_url,
        model=model,
        plan_text=plan_text,
        request_history=request_history,
        backup=backup_map,
    )

    all_written.extend(draft_result.changed_files)

    if not draft_result.valid_response or draft_result.no_changes:
        print(c("\n⚠️ Draft pass did not produce changes.", YELLOW))
        return draft_result.validation_ok, unique_preserve(all_written)

    review_project_text, _ = collect_project_context(root)

    session_diff = build_session_diff(root, backup_map, draft_result.changed_files)

    validation_text = ""
    if (
        draft_result.validation_reports
        or draft_result.validation_failures
        or draft_result.test_reports
        or draft_result.test_failures
    ):
        validation_text = build_validation_feedback(
            draft_result.validation_ok,
            draft_result.validation_reports,
            draft_result.validation_failures,
            test_reports=draft_result.test_reports,
            test_failures=draft_result.test_failures,
        )

    review_prompt = build_review_prompt(
        project_text=review_project_text,
        request=request,
        plan_text=plan_text,
        request_history=request_history,
        validation_text=validation_text,
        session_diff=session_diff,
    )

    review_text = call_ollama(review_prompt, ollama_url, model, plan_mode=False)
    review_text = clean_plan_output(review_text)

    print(c("\n🔍 Review completed.", GREEN))

    fix_result = apply_pass(
        root=root,
        project_text=review_project_text,
        request=request,
        ollama_url=ollama_url,
        model=model,
        plan_text=plan_text,
        request_history=request_history,
        review_text=review_text,
        validation_text=validation_text,
        session_diff=session_diff,
        backup=backup_map,
    )

    all_written.extend(fix_result.changed_files)

    polish_project_text, _ = collect_project_context(root)
    polish_session_diff = build_session_diff(root, backup_map, unique_preserve(all_written))

    polish_result = apply_pass(
        root=root,
        project_text=polish_project_text,
        request=request,
        ollama_url=ollama_url,
        model=model,
        plan_text=plan_text,
        request_history=request_history,
        session_diff=polish_session_diff,
        backup=backup_map,
    )

    all_written.extend(polish_result.changed_files)

    print(c("\n✅ Five-pass engine completed.", GREEN))

    return polish_result.validation_ok, unique_preserve(all_written)


def review_verdict_ok(review_text: str) -> bool:
    for line in review_text.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        if stripped.upper().startswith("VERDICT:"):
            verdict = stripped.split(":", 1)[1].strip().upper()
            return verdict == "OK"
    return False


def enforce_functional_guardrail(
    root: Path,
    request: str,
    ollama_url: str,
    model: str | None,
    request_history: str,
    backup: dict[str, str | None],
    written: list[str],
    plan_text: str = "",
) -> tuple[bool, list[str]]:
    changed = unique_preserve(written)
    if not changed:
        return True, changed

    for attempt in range(FUNCTIONAL_GUARDRAIL_MAX_FIXES + 1):
        review_project_text, _ = collect_project_context(root)
        session_diff = build_session_diff(root, backup, changed)
        review_prompt = build_review_prompt(
            project_text=review_project_text,
            request=request,
            plan_text=plan_text,
            request_history=request_history,
            session_diff=session_diff,
        )
        review_text = clean_plan_output(call_ollama(review_prompt, ollama_url, model, plan_mode=False))

        if review_verdict_ok(review_text):
            print(c("\n✅ Functional guardrail: request verified.", GREEN))
            return True, changed

        if attempt >= FUNCTIONAL_GUARDRAIL_MAX_FIXES:
            break

        print(c(
            (
                f"\n⚠️ Functional guardrail found gaps (fix pass {attempt + 1}/"
                f"{FUNCTIONAL_GUARDRAIL_MAX_FIXES}). Reworking..."
            ),
            YELLOW,
        ))

        fix_result = apply_pass(
            root=root,
            project_text=review_project_text,
            request=request,
            ollama_url=ollama_url,
            model=model,
            plan_text=plan_text,
            request_history=request_history,
            review_text=review_text,
            session_diff=session_diff,
            backup=backup,
        )

        changed = unique_preserve(compute_changed_files(root, backup))

        if not fix_result.validation_ok:
            return False, changed

    print(c(
        "\n❌ Functional guardrail could not verify the request after multiple fix passes. Rolling back.",
        RED,
    ))
    restore_files(root, backup)
    return False, compute_changed_files(root, backup)


def make_commit_message(
    root: Path,
    request: str,
    written: list[str],
    ollama_url: str,
    model: str | None,
) -> str:
    if not written:
        return "ollama-code: no changes"

    diff_text = ""
    cp = run(["git", "diff", "--", *written], check=False)
    if cp.stdout:
        diff_text = cp.stdout

    if len(diff_text) > MAX_SUMMARY_DIFF_CHARS:
        diff_text = diff_text[:MAX_SUMMARY_DIFF_CHARS].rstrip() + "\n...[DIFF TRUNCATED]...\n"

    summary_prompt = build_change_summary_prompt(request, diff_text)
    summary = call_ollama(summary_prompt, ollama_url, model, plan_mode=False)

    if summary.strip():
        lines = summary.strip().splitlines()
        first_line = lines[0].strip()
        if first_line.startswith("SUMMARY:"):
            first_line = first_line[len("SUMMARY:"):].strip()
        if len(first_line) > 72:
            first_line = first_line[:69] + "..."
        body_lines = []
        for line in lines[1:]:
            s = line.strip()
            if s.startswith("DETAILS:"):
                continue
            if s.startswith("-"):
                body_lines.append(s)
        if body_lines:
            return first_line + "\n\n" + "\n".join(body_lines)
        return first_line

    short_request = preview_text(request, max_chars=60)
    return f"ollama-code: {short_request}"


def create_commit(
    root: Path,
    request: str,
    written: list[str],
    ollama_url: str,
    model: str | None,
) -> bool:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not files:
        return False

    if not has_any_changes_excluding_internal_files():
        return False

    git_add_written_files(written)

    if not has_staged_changes():
        return False

    message = make_commit_message(root, request, written, ollama_url, model)
    cp = run(["git", "commit", "-m", message], check=False)

    if cp.returncode == 0:
        print(c(f"\n✅ Commit created: {preview_text(message, max_chars=80)}", GREEN))
        return True
    else:
        print(c("\n⚠️ Commit failed.", YELLOW))
        if cp.stderr:
            print(cp.stderr, file=sys.stderr)
        git_reset_written_files(written)
        return False


def process_request(
    root: Path,
    request: str,
    ollama_url: str,
    model: str | None,
    plan_mode: bool,
    dry_run: bool,
    auto_commit: bool,
    five_pass_engine: bool,
    auto_readme: bool,
) -> bool:
    save_last_request(root, request)

    request_history = build_request_history_context(root)
    request_summary = summarize_request_for_history(request, ollama_url, model)
    print(c(f"Request summary: {request_summary}", CYAN))
    append_request_history(root, request_summary)

    project_text, stats = collect_project_context(root)
    show_context_summary(stats)

    backup: dict[str, str | None] = {}
    written: list[str] = []
    validation_ok = True

    if five_pass_engine:
        validation_ok, written = run_five_pass_engine(
            root=root,
            project_text=project_text,
            request=request,
            ollama_url=ollama_url,
            model=model,
            request_history=request_history,
            backup=backup,
        )
    else:
        result = apply_pass(
            root=root,
            project_text=project_text,
            request=request,
            ollama_url=ollama_url,
            model=model,
            plan_text="" if not plan_mode else call_ollama(
                build_plan_prompt(project_text, request, request_history),
                ollama_url,
                model,
                plan_mode=True,
            ),
            request_history=request_history,
            backup=backup,
        )
        written = result.changed_files
        validation_ok = result.validation_ok

        if (
            not result.validation_ok
            and result.valid_response
            and not result.no_changes
        ):
            print(c("\n🔁 Running corrective pass from validation/test feedback...", YELLOW))
            validation_text = build_validation_feedback(
                result.validation_ok,
                result.validation_reports,
                result.validation_failures,
                test_reports=result.test_reports,
                test_failures=result.test_failures,
            )
            refreshed_project_text, _ = collect_project_context(root)
            correction_result = apply_pass(
                root=root,
                project_text=refreshed_project_text,
                request=request,
                ollama_url=ollama_url,
                model=model,
                plan_text="",
                request_history=request_history,
                validation_text=validation_text,
                backup=backup,
            )
            validation_ok = correction_result.validation_ok
            written = compute_changed_files(root, backup)

    if validation_ok and written:
        validation_ok, written = enforce_functional_guardrail(
            root=root,
            request=request,
            ollama_url=ollama_url,
            model=model,
            request_history=request_history,
            backup=backup,
            written=written,
            plan_text="",
        )

    if validation_ok and written and auto_readme:
        readme_changed, readme_rel = generate_readme_instructions_for_changes(
            root=root,
            request=request,
            changed_files=written,
            backup=backup,
        )
        if readme_changed and readme_rel:
            written = unique_preserve(written + [readme_rel])

    if dry_run:
        print(c("\n🧪 DRY RUN MODE - Restoring original files...", YELLOW))
        restore_files(root, backup)
        print(c("Original files restored.", GREEN))
    else:
        if written:
            print(c(f"\n✨ Wrote {len(written)} file(s):", GREEN))
            for f in written:
                print(f"  - {f}")

            if validation_ok:
                print(c("\n✅ Validation and tests passed.", GREEN))
            else:
                print(c("\n❌ Validation and/or tests failed. Changes were rolled back.", RED))

            if auto_commit and validation_ok and written:
                create_commit(
                    root,
                    request,
                    written,
                    ollama_url=ollama_url,
                    model=model,
                )

    if DEFAULT_SHOW_DIFF and not dry_run and written:
        show_written_files_diff(written, backup, root)

    return validation_ok


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Terminal coding agent powered by local Ollama models"
    )
    parser.add_argument(
        "--ollama-url",
        dest="ollama_url",
        default=None,
        help="Custom Ollama endpoint (default: OLLAMA_HOST or http://127.0.0.1:11434)",
    )
    parser.add_argument(
        "--plan",
        dest="plan_mode",
        action="store_true",
        default=None,
        help="Ask Ollama for a plan before generating code",
    )
    parser.add_argument(
        "--dry-run",
        dest="dry_run",
        action="store_true",
        default=None,
        help="Show changes but restore the working tree afterward",
    )
    parser.add_argument(
        "--no-commit",
        dest="auto_commit",
        action="store_false",
        default=None,
        help="Disable automatic Git commits",
    )
    parser.add_argument(
        "--no-engine",
        dest="five_pass_engine",
        action="store_false",
        default=None,
        help="Disable the five-pass engine",
    )
    parser.add_argument(
        "--no-readme",
        dest="auto_readme",
        action="store_false",
        default=None,
        help="Disable automatic README instruction generation",
    )

    args = parser.parse_args()
    root = ensure_git_repo()

    config = load_config(root)
    model = normalize_model_value(config.get("model"))
    fallback_model = normalize_model_value(config.get("fallback_model"))
    set_configured_fallback_model(fallback_model)

    configured_ollama_url = normalize_ollama_url_value(config.get("ollama_url"))
    if args.ollama_url:
        ollama_url = default_ollama_url(args.ollama_url)
    elif configured_ollama_url:
        ollama_url = configured_ollama_url
    else:
        ollama_url = default_ollama_url()

    plan_mode = resolve_runtime_bool_setting(args.plan_mode, config.get("plan_mode"), DEFAULT_PLAN_MODE)
    dry_run = resolve_runtime_bool_setting(args.dry_run, config.get("dry_run"), DEFAULT_DRY_RUN)
    auto_commit = resolve_runtime_bool_setting(args.auto_commit, config.get("auto_commit"), DEFAULT_AUTO_COMMIT)
    five_pass_engine = resolve_runtime_bool_setting(
        args.five_pass_engine,
        config.get("five_pass_engine"),
        DEFAULT_FIVE_PASS_ENGINE,
    )
    auto_readme = resolve_runtime_bool_setting(args.auto_readme, config.get("auto_readme"), DEFAULT_AUTO_README)

    setup_readline()

    print(c("Welcome to ollama-code!", BOLD + GREEN))
    print(c(f"Working directory: {root}", MUTED))
    print(c(f"Ollama endpoint: {ollama_url}", MUTED))
    show_model_status(model, ollama_url)
    print()

    completer = SlashCommandCompleter(config, ollama_url)

    while True:
        try:
            request = prompt_input("ollama-code> ", CYAN, completer=completer).strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not request:
            continue

        if request.startswith("/"):
            parts = request.split(None, 1)
            command = parts[0].lower()
            arg = parts[1] if len(parts) > 1 else ""

            if command == "/f":
                list_files(root)
            elif command == "/s":
                run_shell_command(arg if arg else None)
            elif command == "/ollama-url":
                if arg:
                    ollama_url = default_ollama_url(arg)
                    config["ollama_url"] = ollama_url
                    save_config(root, config)
                    completer.ollama_url = ollama_url
                    print(c(f"Ollama endpoint set to: {ollama_url}", GREEN))
                else:
                    print(c(f"Current Ollama endpoint: {ollama_url}", CYAN))                
            elif command == "/diff":
                show_git_diff()
            elif command == "/model":
                if arg:
                    ok, selected = resolve_model_choice(
                        arg,
                        discover_ollama_models(ollama_url),
                        allow_custom=True,
                    )
                    if ok:
                        model = selected
                        config["model"] = model
                        save_config(root, config)
                        print(c(f"Model set to: {format_model_name(model)}", GREEN))
                    else:
                        print(c("Invalid model.", RED))
                else:
                    ok, selected = prompt_model_selection(ollama_url, model)
                    if ok:
                        model = selected
                        config["model"] = model
                        save_config(root, config)
                        if model:
                            print(c(f"Model set to: {model}", GREEN))
                        else:
                            print(c("Model reset to automatic.", GREEN))
            elif command == "/fallback-model":
                if arg:
                    ok, selected = resolve_model_choice(
                        arg,
                        discover_ollama_models(ollama_url),
                        allow_custom=True,
                    )
                    if ok:
                        fallback_model = selected
                        config["fallback_model"] = fallback_model
                        set_configured_fallback_model(fallback_model)
                        save_config(root, config)
                        print(c(f"Fallback model set to: {format_fallback_model_name(fallback_model)}", GREEN))
                    else:
                        print(c("Invalid fallback model.", RED))
                else:
                    ok, selected = prompt_fallback_model_selection(ollama_url, fallback_model)
                    if ok:
                        fallback_model = selected
                        config["fallback_model"] = fallback_model
                        set_configured_fallback_model(fallback_model)
                        save_config(root, config)
                        if fallback_model:
                            print(c(f"Fallback model set to: {fallback_model}", GREEN))
                        else:
                            print(c("Fallback model reset to automatic.", GREEN))
            elif command == "/plan":
                if arg.lower() == "on":
                    plan_mode = True
                    print(c("Planning mode: ON", GREEN))
                elif arg.lower() == "off":
                    plan_mode = False
                    print(c("Planning mode: OFF", GREEN))
                else:
                    plan_mode = not plan_mode
                    print(c(f"Planning mode: {'ON' if plan_mode else 'OFF'}", GREEN))
                config["plan_mode"] = plan_mode
                save_config(root, config)
            elif command == "/dry":
                if arg.lower() == "on":
                    dry_run = True
                    print(c("Dry-run mode: ON", GREEN))
                elif arg.lower() == "off":
                    dry_run = False
                    print(c("Dry-run mode: OFF", GREEN))
                else:
                    dry_run = not dry_run
                    print(c(f"Dry-run mode: {'ON' if dry_run else 'OFF'}", GREEN))
                config["dry_run"] = dry_run
                save_config(root, config)
            elif command == "/commit":
                if arg.lower() == "on":
                    auto_commit = True
                    print(c("Auto-commit: ON", GREEN))
                elif arg.lower() == "off":
                    auto_commit = False
                    print(c("Auto-commit: OFF", GREEN))
                else:
                    auto_commit = not auto_commit
                    print(c(f"Auto-commit: {'ON' if auto_commit else 'OFF'}", GREEN))
                config["auto_commit"] = auto_commit
                save_config(root, config)
            elif command == "/engine":
                if arg.lower() == "on":
                    five_pass_engine = True
                    print(c("Five-pass engine: ON", GREEN))
                elif arg.lower() == "off":
                    five_pass_engine = False
                    print(c("Five-pass engine: OFF", GREEN))
                else:
                    five_pass_engine = not five_pass_engine
                    print(c(f"Five-pass engine: {'ON' if five_pass_engine else 'OFF'}", GREEN))
                config["five_pass_engine"] = five_pass_engine
                save_config(root, config)
            elif command == "/readme":
                if arg.lower() == "on":
                    auto_readme = True
                    print(c("README instructions: ON", GREEN))
                elif arg.lower() == "off":
                    auto_readme = False
                    print(c("README instructions: OFF", GREEN))
                else:
                    auto_readme = not auto_readme
                    print(c(f"README instructions: {'ON' if auto_readme else 'OFF'}", GREEN))
                config["auto_readme"] = auto_readme
                save_config(root, config)
            elif command == "/retry":
                last_request = load_last_request(root)
                if last_request is None:
                    entries = parse_request_history_entries(root)
                    if entries:
                        _, last_request = entries[-1]

                if last_request:
                    print(c(f"Retrying: {preview_text(last_request)}", CYAN))
                    process_request(
                        root=root,
                        request=last_request,
                        ollama_url=ollama_url,
                        model=model,
                        plan_mode=plan_mode,
                        dry_run=dry_run,
                        auto_commit=auto_commit,
                        five_pass_engine=five_pass_engine,
                        auto_readme=auto_readme,
                    )
                else:
                    print(c("No previous request to retry.", YELLOW))
            elif command == "/last":
                p = first_existing_state_path(root, LAST_RESPONSE_FILE, LEGACY_LAST_RESPONSE_FILE)
                if p.exists():
                    print(c(f"--- {p.name} ---\n", BOLD + BLUE))
                    print(p.read_text(encoding="utf-8"))
                else:
                    print(c("No saved response.", YELLOW))
            elif command == "/history":
                show_request_history(root)
            elif command == "/q":
                print(c("Goodbye!", GREEN))
                break
            else:
                print(c(f"Unknown command: {command}", YELLOW))
                print(c("Type /q to quit or see available commands.", MUTED))
            continue

        process_request(
            root=root,
            request=request,
            ollama_url=ollama_url,
            model=model,
            plan_mode=plan_mode,
            dry_run=dry_run,
            auto_commit=auto_commit,
            five_pass_engine=five_pass_engine,
            auto_readme=auto_readme,
        )


if __name__ == "__main__":
    main()
