def summarize_items(items: list[str], max_items: int = 3) -> str:
    if not items:
        return ""

    visible = items[:max_items]
    suffix = ""
    if len(items) > max_items:
        suffix = f", +{len(items) - max_items} altri"

    return ", ".join(visible) + suffix


def format_count(value: int) -> str:
    return f"{value:,}".replace(",", ".")


def safe_int(value: object) -> int:
    try:
        parsed = int(value)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        return 0
    return max(parsed, 0)


def format_duration_ns(value: int) -> str:
    if value <= 0:
        return "0s"

    seconds = value / 1_000_000_000
    if seconds < 10:
        return f"{seconds:.1f}s"
    if seconds < 60:
        return f"{seconds:.0f}s"

    minutes, seconds = divmod(int(round(seconds)), 60)
    if minutes < 60:
        return f"{minutes}m{seconds:02d}s"

    hours, minutes = divmod(minutes, 60)
    return f"{hours}h{minutes:02d}m"


def cloud_usage_duration_ns(snapshot: UsageSnapshot | None) -> int:
    if snapshot is None:
        return 0

    component_total = (
        snapshot.load_duration_ns
        + snapshot.prompt_duration_ns
        + snapshot.completion_duration_ns
    )
    if component_total > 0:
        return component_total
    return snapshot.total_duration_ns


