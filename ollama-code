def run_shell_command(arg: str | None = None) -> None:
    cmd = (arg or "").strip()
    if not cmd:
        cmd = input(cprompt("shell> ", YELLOW)).strip()

    if not cmd:
        print(c("No command.", YELLOW))
        return

    print(c(f"$ {cmd}", CYAN) + "\n")
    cp = run(cmd, shell=True, check=False)
    if cp.stdout:
        print(cp.stdout, end="" if cp.stdout.endswith("\n") else "\n")
    if cp.stderr:
        print(cp.stderr, end="" if cp.stderr.endswith("\n") else "\n", file=sys.stderr)
    print(c(f"\n[exit {cp.returncode}]", MUTED))


