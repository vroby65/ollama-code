        print(c(f"Impossibile leggere {p.name}: {exc}", RED), file=sys.stderr)
        return
    print(c(f"--- {p.name} ---\n", BOLD + BLUE))
    print(text.rstrip())


def show_text_block(title: str, text: str) -> None:
    print(c(f"{title}\n", BOLD + BLUE))
    print(text.rstrip())
    print()


def parse_toggle_command(request: str, command: str, current: bool) -> bool | None:
    parts = request.split()
    if not parts or parts[0] != command:
        return None

    if len(parts) == 1:
        return not current

    option = parts[1].lower()
    if option in {"on", "true", "1"}:
        return True
    if option in {"off", "false", "0"}:
        return False
    return None


