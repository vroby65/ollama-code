def is_valid_relpath(name: str) -> bool:
    if not name.strip():
        return False
    p = Path(name)
    if p.is_absolute():
        return False
    if ".." in p.parts:
        return False
    if ".git" in p.parts:
        return False
    if p.name in INTERNAL_STATE_FILES:
        return False
    return True


def skip_reason_for_path(path: Path) -> str | None:
    if path.name in INTERNAL_STATE_FILES:
        return "internal_state"
    if path.is_symlink():
        return "symlink"
    if any(part in EXCLUDED_DIRS for part in path.parts):
        return "excluded_dir"
    if any(part in BACKUP_DIRS for part in path.parts):
        return "backup_dir"
    if path.suffix.lower() in BINARY_SUFFIXES:
        return "binary_suffix"
    try:
        if path.stat().st_size > MAX_FILE_CHARS * 4:
            return "too_large"
    except Exception:
        return "stat_error"
    return None


def should_skip_file(path: Path) -> bool:
    return skip_reason_for_path(path) is not None


def is_probably_binary(path: Path) -> bool:
    if path.suffix.lower() in BINARY_SUFFIXES:
        return True
    try:
        data = path.read_bytes()[:4096]
    except Exception:
        return True
    return b"\x00" in data


def read_file_safely(path: Path) -> tuple[str, bool]:
    if is_probably_binary(path):
        return "[FILE NON TESTUALE O BINARIO]", False

    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        try:
            text = path.read_text(encoding="latin-1")
        except Exception:
            return "[FILE NON TESTUALE O NON LEGGIBILE]", False
    except Exception:
        return "[FILE NON LEGGIBILE]", False

    truncated = False
    if len(text) > MAX_FILE_CHARS:
        text = text[:MAX_FILE_CHARS] + "\n...[TRONCATO]...\n"
        truncated = True
    return text, truncated


def bump_stat(stats: dict[str, int], key: str) -> None:
    stats[key] = stats.get(key, 0) + 1


def add_skip_example(store: dict[str, list[str]], reason: str, rel_path: str) -> None:
    examples = store.setdefault(reason, [])
    if len(examples) < 3:
        examples.append(rel_path)


def summarize_items(items: list[str], max_items: int = 3) -> str:
    if not items:
        return ""

    visible = items[:max_items]
    suffix = ""
    if len(items) > max_items:
        suffix = f", +{len(items) - max_items} altri"

    return ", ".join(visible) + suffix


def format_count(value: int) -> str:
    return f"{value:,}".replace(",", ".")


def iter_project_files(root: Path) -> list[Path]:
    files, _, _ = scan_project_files(root)
    return files


def scan_project_files(root: Path) -> tuple[list[Path], dict[str, int], dict[str, list[str]]]:
    files = []
    skipped_counts: dict[str, int] = {}
    skipped_examples: dict[str, list[str]] = {}

    for path in root.rglob("*"):
        if not path.is_file():
            continue

        reason = skip_reason_for_path(path)
        if reason is not None:
            rel = str(path.relative_to(root))
            bump_stat(skipped_counts, reason)
            add_skip_example(skipped_examples, reason, rel)
            continue

        files.append(path)
    return sorted(files, key=lambda p: str(p.relative_to(root))), skipped_counts, skipped_examples


def collect_project_context(root: Path) -> tuple[str, ProjectContextStats]:
    chunks = []
    total = 0
    files, skipped_counts, skipped_examples = scan_project_files(root)
    stats = ProjectContextStats(
        skipped_counts=skipped_counts,
        skipped_examples=skipped_examples,
    )

    for path in files:
        rel = str(path.relative_to(root))
        content, truncated = read_file_safely(path)
        chunk = f"===FILE: {rel}===\n{content}\n===END===\n\n"

        if total + len(chunk) > MAX_PROMPT_CHARS:
            remaining = MAX_PROMPT_CHARS - total
            if remaining > 200:
                chunk = chunk[:remaining] + "\n...[CONTESTO TRONCATO]...\n"
                chunks.append(chunk)
                total += len(chunk)
            stats.context_truncated = True
            break

        chunks.append(chunk)
        total += len(chunk)
        stats.included_files.append(rel)
        if truncated:
            stats.truncated_files.append(rel)

    stats.total_chars = total
    return "".join(chunks).rstrip(), stats


def first_existing_state_path(root: Path, current_name: str, *legacy_names: str) -> Path:
    candidates = [root / current_name, *((root / name) for name in legacy_names)]
    for path in candidates:
        if path.exists():
            return path
    return candidates[0]


def append_request_history(root: Path, request: str) -> None:
    p = root / REQUEST_HISTORY_FILE
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    entry = (
        f"TIME: {timestamp}\n"
        f"TEXT:\n{request.rstrip()}\n"
        f"{REQUEST_SEPARATOR}"
    )
    with p.open("a", encoding="utf-8") as f:
        f.write(entry)


def parse_request_history_entries(root: Path) -> list[tuple[str, str]]:
    p = first_existing_state_path(root, REQUEST_HISTORY_FILE, LEGACY_REQUEST_HISTORY_FILE)
    if not p.exists():
        return []

    try:
        raw = p.read_text(encoding="utf-8")
    except Exception:
        return []

    blocks = [b.strip() for b in raw.split(REQUEST_SEPARATOR) if b.strip()]
    entries: list[tuple[str, str]] = []

    for block in blocks:
        if not block.startswith("TIME: "):
            continue

        lines = block.splitlines()
        if not lines:
            continue

        timestamp = lines[0][len("TIME: "):].strip()

        if len(lines) >= 2 and lines[1].strip() == "TEXT:":
            text = "\n".join(lines[2:]).strip()
        else:
            text = "\n".join(lines[1:]).strip()

        if text:
            entries.append((timestamp, text))

    return entries


def one_line_summary(text: str, max_chars: int = MAX_SUMMARY_ITEM_CHARS) -> str:
    s = " ".join(text.split())
    if len(s) <= max_chars:
        return s
    return s[:max_chars].rstrip() + "..."


def build_request_history_context(root: Path) -> str:
    entries = parse_request_history_entries(root)
    if not entries:
        return ""

    last_timestamp, last_text = entries[-1]
    older = entries[:-1]

    parts: list[str] = []

    if older:
        recent_older = older[-MAX_HISTORY_SUMMARY_ITEMS:]
        parts.append("STORIA RIASSUNTA DELLE RICHIESTE PRECEDENTI:")
        for ts, text in recent_older:
            parts.append(f"- [{ts}] {one_line_summary(text)}")

    parts.append("")
    parts.append("ULTIMA RICHIESTA PRECEDENTE COMPLETA:")
    parts.append(f"[{last_timestamp}]")
    parts.append(last_text)

    result = "\n".join(parts).strip()

    if len(result) > MAX_HISTORY_CHARS:
        result = result[-MAX_HISTORY_CHARS:]
        nl = result.find("\n")
        if nl != -1:
            result = result[nl + 1:].lstrip()

    return result


def show_request_history(root: Path) -> None:
    entries = parse_request_history_entries(root)
    if not entries:
        print(c("Nessuna storia richieste disponibile.", YELLOW))
        return

    history_path = first_existing_state_path(root, REQUEST_HISTORY_FILE, LEGACY_REQUEST_HISTORY_FILE)
    print(c(f"--- {history_path.name} ---\n", BOLD + BLUE))
    for ts, text in entries:
        print(c(f"[{ts}]", CYAN))
        print(text)
        print()


def preview_text(text: str, max_chars: int = 280) -> str:
    normalized = " ".join(text.split())
    if len(normalized) <= max_chars:
        return normalized
    return normalized[:max_chars].rstrip() + "..."


def show_context_summary(stats: ProjectContextStats) -> None:
    included = len(stats.included_files)
    print(c(
        f"Contesto progetto pronto: {included} file inclusi, {format_count(stats.total_chars)} caratteri.",
        CYAN,
    ))

    if stats.included_files:
        print(c(f"File inclusi: {summarize_items(stats.included_files, max_items=6)}", MUTED))

    if stats.truncated_files:
        print(c(
            f"File troncati a {format_count(MAX_FILE_CHARS)} caratteri: {summarize_items(stats.truncated_files)}",
            YELLOW,
        ))

    for reason in sorted(stats.skipped_counts):
        count = stats.skipped_counts[reason]
        label = SKIP_REASON_LABELS.get(reason, reason)
        examples = summarize_items(stats.skipped_examples.get(reason, []))
        if examples:
            print(c(f"Saltati {count} {label}: {examples}", MUTED))
        else:
            print(c(f"Saltati {count} {label}.", MUTED))

    if stats.context_truncated:
        print(c(
            f"Contesto totale troncato a circa {format_count(MAX_PROMPT_CHARS)} caratteri.",
            YELLOW,
        ))


def build_runtime_config() -> dict[str, str | None]:
    return {
        "model": DEFAULT_MODEL,
    }


def normalize_model_value(value: str | None) -> str | None:
    if value is None:
        return None

    normalized = str(value).strip()
    if not normalized:
        return None

    if normalized.lower() in {"default", "none", "null", "reset"}:
        return None

    return normalized


def default_model_choice() -> str | None:
    return normalize_model_value(os.getenv("OLLAMA_MODEL"))


def get_user_config_path() -> Path:
    return Path.home() / USER_CONFIG_FILE


def load_config_file(path: Path) -> dict[str, str | None] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        print(c(f"Impossibile leggere {path}: {exc}", YELLOW), file=sys.stderr)
        return None

    if not isinstance(data, dict):
        print(c(f"{path} non contiene un oggetto JSON valido.", YELLOW), file=sys.stderr)
        return None

    config = build_runtime_config()

    config["model"] = normalize_model_value(data.get("model"))
    return config


def load_config(root: Path) -> dict[str, str | None]:
    config = build_runtime_config()
    for path in (
        get_user_config_path(),
        Path.home() / LEGACY_USER_CONFIG_FILE,
        root / LEGACY_PROJECT_CONFIG_FILE,
    ):
        if not path.exists():
            continue

        loaded = load_config_file(path)
        if loaded is not None:
            config = loaded
            break

    return config


