    if ANSI is None:
        return None

    usage = _SESSION_USAGE
    if not usage.last_target_was_cloud:
        return None

    model_label = usage.last_resolved_model or "automatic"
    snapshot = usage.last_cloud_usage

    if snapshot is None:
        if usage.cloud_calls > 0:
            text = (
                f" cloud {model_label}"
                " | current model: no usage yet"
                f" | session usage {format_duration_ns(usage.cloud_usage_duration_ns)}"
                f" | {usage.cloud_calls} calls "
            )
        else:
            text = f" cloud {model_label} | usage: no data yet "
        return ANSI(cansi(text, MUTED))

    last_usage = cloud_usage_duration_ns(snapshot)
    text = (
        f" cloud {snapshot.model or model_label}"
        f" | last usage {format_duration_ns(last_usage)}"
        f" | session usage {format_duration_ns(usage.cloud_usage_duration_ns)}"
        f" | {usage.cloud_calls} calls "
    )
    return ANSI(cansi(text, CYAN))


def unique_preserve(values: list[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []

    for value in values:
        normalized = str(value).strip()
        if not normalized:
            continue

        key = normalized.lower()
        if key in seen:
            continue

        seen.add(key)
        result.append(normalized)

    return result


def fetch_json(url: str, headers: dict[str, str] | None = None) -> object | None:
    data, _ = request_json(url, headers=headers)
    return data


def build_ollama_headers(ollama_url: str | None = None) -> dict[str, str] | None:
    if not is_ollama_cloud_url(ollama_url):
        return None

    api_key = os.getenv("OLLAMA_API_KEY", "").strip()
    if not api_key:
        return None

    return {"Authorization": f"Bearer {api_key}"}


def build_ollama_api_url(ollama_url: str | None, endpoint: str) -> str:
    base_url = default_ollama_url(ollama_url)
    parsed = urllib.parse.urlparse(base_url)
    base_path = parsed.path.rstrip("/")
    endpoint_path = endpoint if endpoint.startswith("/") else f"/{endpoint}"

    if base_path.endswith("/api"):
        path = base_path + endpoint_path
    else:
        path = f"{base_path}/api{endpoint_path}" if base_path else f"/api{endpoint_path}"

    return urllib.parse.urlunparse(parsed._replace(path=path))


def request_json(
    url: str,
    payload: object | None = None,
    headers: dict[str, str] | None = None,
    timeout: int = MODEL_DISCOVERY_TIMEOUT_SECONDS,
) -> tuple[object | None, str | None]:
    body: bytes | None = None
    if payload is not None:
        body = json.dumps(payload, ensure_ascii=True).encode("utf-8")

    req = urllib.request.Request(url, data=body)
    req.add_header("Accept", "application/json")
    req.add_header("User-Agent", "ollama-code/1.0")

    if body is not None:
        req.add_header("Content-Type", "application/json")

    if headers:
        for name, value in headers.items():
            req.add_header(name, value)

    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            charset = response.headers.get_content_charset() or "utf-8"
            raw_text = response.read().decode(charset)
    except urllib.error.HTTPError as exc:
        try:
            charset = exc.headers.get_content_charset() or "utf-8"
            raw_error = exc.read().decode(charset)
        except Exception:
            raw_error = str(exc)

        try:
            parsed_error = json.loads(raw_error)
        except Exception:
            parsed_error = None

        if isinstance(parsed_error, dict) and parsed_error.get("error"):
            return None, str(parsed_error.get("error"))
        return None, raw_error or str(exc)
    except (OSError, TimeoutError, urllib.error.URLError) as exc:
        return None, str(exc)

    try:
        return json.loads(raw_text), None
    except json.JSONDecodeError:
        return None, raw_text or "Invalid JSON response"


def parse_num_ctx_parameter(parameters: object) -> int | None:
    if not isinstance(parameters, str):
        return None

    match = re.search(r"\bnum_ctx(?:\s+|=)(\d+)\b", parameters)
    if not match:
        return None

    value = safe_int(match.group(1))
    return value or None


def extract_model_info_context_length(model_info: object) -> int | None:
    if not isinstance(model_info, dict):
        return None

    candidates: list[int] = []
    for raw_key, raw_value in model_info.items():
        key = str(raw_key).lower()
        if "context_length" not in key and "context_window" not in key:
            continue

        value = safe_int(raw_value)
        if value > 0:
            candidates.append(value)

    if not candidates:
        return None
    return max(candidates)


def discover_running_model_context_length(
    model: str,
    ollama_url: str | None = None,
) -> int | None:
    base_url = default_ollama_url(ollama_url)
    data = fetch_json(build_ollama_api_url(base_url, "/ps"), headers=build_ollama_headers(base_url))
    if not isinstance(data, dict):
        return None

    items = data.get("models")
    if not isinstance(items, list):
        return None

    for item in items:
        if not isinstance(item, dict):
            continue

        name = normalize_model_value(item.get("name"))
        if not name or name.lower() != model.lower():
            continue

        context_length = safe_int(item.get("context_length"))
        if context_length > 0:
            return context_length

    return None


def fetch_model_details(model: str, ollama_url: str | None = None) -> dict[str, object] | None:
    base_url = default_ollama_url(ollama_url)
    data, error = request_json(
        build_ollama_api_url(base_url, "/show"),
        payload={"model": model},
        headers=build_ollama_headers(base_url),
        timeout=MODEL_DISCOVERY_TIMEOUT_SECONDS,
    )
    if error is not None or not isinstance(data, dict):
        return None
    return data


def resolve_model_context_info(
    model: str | None,
    ollama_url: str | None = None,
) -> ModelContextInfo:
    active_model = resolve_active_model(model, ollama_url)
    if not active_model:
        prompt_budget = min(
            MAX_PROMPT_CHARS,
            int(DEFAULT_CONTEXT_WINDOW_TOKENS * APPROX_CHARS_PER_TOKEN * PROMPT_CONTEXT_USAGE_RATIO),
        )
        return ModelContextInfo(prompt_budget_chars=max(MIN_PROJECT_CONTEXT_CHARS, prompt_budget))

    running_context = discover_running_model_context_length(active_model, ollama_url)
    details = fetch_model_details(active_model, ollama_url) or {}
    configured_num_ctx = parse_num_ctx_parameter(details.get("parameters"))
    max_context = extract_model_info_context_length(details.get("model_info"))

    source = "default"
    context_window_tokens = running_context
    if context_window_tokens:
        source = "api-ps"
    elif configured_num_ctx:
        context_window_tokens = configured_num_ctx
        source = "api-show-parameters"
    else:
        context_window_tokens = DEFAULT_CONTEXT_WINDOW_TOKENS
        if max_context and max_context < context_window_tokens:
            context_window_tokens = max_context
            source = "api-show-model-info"

    if max_context:
        context_window_tokens = min(context_window_tokens, max_context)

    prompt_budget_chars = int(context_window_tokens * APPROX_CHARS_PER_TOKEN * PROMPT_CONTEXT_USAGE_RATIO)
    prompt_budget_chars = max(MIN_PROJECT_CONTEXT_CHARS, min(MAX_PROMPT_CHARS, prompt_budget_chars))

    return ModelContextInfo(
        model=active_model,
        context_window_tokens=context_window_tokens,
        max_context_tokens=max_context,
        source=source,
        prompt_budget_chars=prompt_budget_chars,
    )


def collect_context_for_prompt(
    root: Path,
    model: str | None,
    ollama_url: str | None,
    prompt_factory,
) -> tuple[str, ProjectContextStats, ModelContextInfo]:
    context_info = resolve_model_context_info(model, ollama_url)
    empty_prompt = prompt_factory("")
    available_for_project = context_info.prompt_budget_chars - len(empty_prompt)
    project_budget = max(0, min(MAX_PROMPT_CHARS, available_for_project))
    project_text, stats = collect_project_context(root, max_chars=project_budget)
    return project_text, stats, context_info


def discover_ollama_models(ollama_url: str | None = None) -> list[str]:
    url = default_ollama_url(ollama_url)
    data = fetch_json(build_ollama_api_url(url, "/tags"), headers=build_ollama_headers(url))
    models: list[str] = []

    if isinstance(data, dict):
        items = data.get("models")
        if isinstance(items, list):
            for item in items:
                if not isinstance(item, dict):
                    continue

                name = str(item.get("name", "")).strip()
                if name:
                    models.append(name)

    if models:
        return unique_preserve(models)

    if is_ollama_cloud_url(url):
        return []

    if tool_exists("ollama"):
        cp = run(["ollama", "list"], check=False, timeout=MODEL_DISCOVERY_TIMEOUT_SECONDS)
        if cp.returncode == 0:
            for idx, line in enumerate(cp.stdout.splitlines()):
                if idx == 0 or not line.strip():
                    continue
                models.append(line.split()[0])

    return unique_preserve(models)


def discover_model_choices(
    ollama_url: str | None,
    current_model: str | None,
) -> tuple[list[str], str | None, bool]:
    discovered = discover_ollama_models(ollama_url)
    env_model = default_model_choice()
    note: str | None = None

    if not discovered:
        if is_ollama_cloud_url(ollama_url):
            note = (
                "No models discovered from the Ollama cloud endpoint. "
                "Set OLLAMA_API_KEY and verify the endpoint."
            )
        else:
            note = (
                "Ollama is not responding or is not exposing installed models. "
                "You can enter a model name manually or set OLLAMA_MODEL."
            )

    combined = unique_preserve(
        discovered
        + ([env_model] if env_model else [])
        + ([current_model] if current_model else [])
        + OLLAMA_PREFERRED_MODELS
    )

    return combined, note, True


def resolve_model_choice(
    raw: str,
    models: list[str],
    allow_custom: bool,
) -> tuple[bool, str | None]:
    choice = raw.strip()
    if not choice:
        return False, None

    if choice.lower() in {"0", "default", "none", "null", "reset"}:
        return True, None

    if choice.isdigit():
        index = int(choice) - 1
        if 0 <= index < len(models):
            return True, models[index]
        return False, None

    for model in models:
        if model.lower() == choice.lower():
            return True, model

    if allow_custom:
        return True, normalize_model_value(choice)

    return False, None


def prompt_model_selection(
    ollama_url: str | None,
    current_model: str | None,
    title: str = "Available Ollama models:",
    default_label: str | None = None,
    default_tag: str = "automatic",
    prompt_label: str = "model",
    include_env_tag: bool = True,
) -> tuple[bool, str | None]:
    models, note, allow_custom = discover_model_choices(ollama_url, current_model)
    model_choices = unique_preserve(["default"] + models)
    env_model = default_model_choice() if include_env_tag else None
    completion_menu_available = Completion is not None and get_prompt_session() is not None

    if default_label is None:
        default_label = format_model_name(None)

    if completion_menu_available:
        print(c(title, BOLD + BLUE))
        print(c(f"Default: {default_label}", MUTED))
        if note:
            print(c(note, MUTED))
        print(c("Selection menu opens automatically. Enter confirms. Empty input cancels.", MUTED))

        while True:
            choice = prompt_input(
                f"{prompt_label}> ",
                YELLOW,
                completer=ChoiceCompleter(model_choices, display_meta="model"),
                open_completion_menu=True,
            ).strip()
            if not choice:
                print(c("Model selection canceled.", YELLOW))
                return False, None

            ok, selected = resolve_model_choice(choice, models, allow_custom)
            if ok:
                return True, selected

            print(c("Invalid model. Try again or press enter to cancel.", RED))

    print(c(title, BOLD + BLUE))

    default_tags: list[str] = [default_tag]
    if current_model is None:
        default_tags.append("current")
    print(f" 0. {default_label} ({', '.join(default_tags)})")

    for idx, model in enumerate(models, start=1):
        tags: list[str] = []
        if model == current_model:
            tags.append("current")
        if env_model and model == env_model:
            tags.append("OLLAMA_MODEL")

        suffix = f" ({', '.join(tags)})" if tags else ""
        print(f" {idx}. {model}{suffix}")

    if note:
        print(c(note, MUTED))

    print(c("Completion menu unavailable: type number/name/default. Press enter to cancel.", MUTED))

    while True:
        choice = input(cprompt(f"{prompt_label}> ", YELLOW)).strip()
        if not choice:
            print(c("Model selection canceled.", YELLOW))
            return False, None

        ok, selected = resolve_model_choice(choice, models, allow_custom)
        if ok:
            return True, selected

        print(c("Invalid model. Try again or press enter to cancel.", RED))


