    for line in cp.stdout.splitlines():
        if any(internal in line for internal in INTERNAL_STATE_FILES):
            continue
        return True
    return False


def detect_file_kind(path: Path) -> str | None:
    suffix = path.suffix.lower()

    if suffix == ".py":
        return "python"
    if suffix == ".php":
        return "php"
    if suffix in {".js", ".mjs", ".cjs"}:
        return "javascript"
    if suffix in {".sh", ".bash"}:
        return "bash"

    if path.name in {"bashrc", "profile", ".bashrc", ".profile"}:
        return "bash"

    return None


def tool_exists(name: str) -> bool:
    cp = run(["sh", "-c", f"command -v {shlex.quote(name)}"], check=False)
    return cp.returncode == 0 and bool((cp.stdout or "").strip())


def validate_python(path: Path) -> tuple[bool, str]:
    if not tool_exists("python3"):
        return False, "python3 not found on the system"
    cp = run(["python3", "-m", "py_compile", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_php(path: Path) -> tuple[bool, str]:
    if not tool_exists("php"):
        return False, "php not found on the system"
    cp = run(["php", "-l", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_javascript(path: Path) -> tuple[bool, str]:
    if not tool_exists("node"):
        return False, "node not found on the system"
    cp = run(["node", "--check", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_bash(path: Path) -> tuple[bool, str]:
    if not tool_exists("bash"):
        return False, "bash not found on the system"
    cp = run(["bash", "-n", str(path)], check=False)
    output = (cp.stdout or "") + (cp.stderr or "")
    return cp.returncode == 0, output.strip()


def validate_file(path: Path) -> tuple[str | None, bool, str]:
    kind = detect_file_kind(path)
    if kind is None:
        return None, True, "skip"

    if kind == "python":
        ok, msg = validate_python(path)
    elif kind == "php":
        ok, msg = validate_php(path)
    elif kind == "javascript":
        ok, msg = validate_javascript(path)
    elif kind == "bash":
        ok, msg = validate_bash(path)
    else:
        return None, True, "skip"

    return kind, ok, msg or "ok"


def validate_written_files(root: Path, written: list[str]) -> tuple[bool, list[str], list[str]]:
    reports: list[str] = []
    failures: list[str] = []

    for rel in written:
        if rel in INTERNAL_STATE_FILES:
            continue

        full = root / rel
        kind, ok, msg = validate_file(full)

        if kind is None:
            continue

        label = f"{rel} [{kind}]"
        if ok:
            reports.append(f"{label}: OK")
        else:
            failure_text = msg.strip() or "unknown error"
            reports.append(f"{label}: ERROR")
            failures.append(f"{label}\n{failure_text}")

    return len(failures) == 0, reports, failures


def show_validation_results(
    reports: list[str],
    ok: bool,
    failures: list[str] | None = None,
) -> None:
    print(c("\n--- SYNTAX VALIDATION ---\n", BOLD + BLUE))

    if reports:
        for row in reports:
            color = GREEN if row.endswith("OK") else RED
            print(c(row, color))
    else:
        print(c("No validatable files among the modified files.", YELLOW))

    print(c(
        f"Validation completed: {'OK' if ok else 'ERRORS'}",
        GREEN if ok else RED,
    ))

    if not ok and failures:
        print(c("\n--- VALIDATION ERRORS ---\n", BOLD + RED), file=sys.stderr)
        for err in failures:
            print(err, file=sys.stderr)
            print(file=sys.stderr)


def apply_code_response(
    root: Path,
    response: str,
    session_backup: dict[str, str | None],
) -> AppliedPassResult:
    result = AppliedPassResult(response=response)

    if response.strip() == "NO_CHANGES":
        result.no_changes = True
        result.changed_files = compute_changed_files(root, session_backup)
        ok, reports, failures = validate_written_files(root, result.changed_files)
        result.validation_ok = ok
        result.validation_reports = reports
        result.validation_failures = failures
        return result

    files_map = parse_file_blocks(response)
    result.files_map = files_map

    if not files_map:
        result.valid_response = False
        return result

    candidate_paths = [rel for rel in files_map if is_valid_relpath(rel)]
    extend_backup(root, session_backup, candidate_paths)

    written, rejected = write_files(root, files_map)
    result.written = written
    result.rejected = rejected
    result.changed_files = compute_changed_files(root, session_backup)

    ok, reports, failures = validate_written_files(root, result.changed_files)
    result.validation_ok = ok
    result.validation_reports = reports
    result.validation_failures = failures
    return result


def build_report(
    request: str,
    written: list[str],
    rejected: list[str],
    plan_text: str = "",
    validation_reports: list[str] | None = None,
) -> str:
    git_add_written_files(written)
    visible_written = [f for f in written if f not in INTERNAL_STATE_FILES]

    if visible_written:
        stats_cp = run(["git", "diff", "--cached", "--stat", "--", *visible_written], check=False)
        summary_cp = run(["git", "diff", "--cached", "--summary", "--", *visible_written], check=False)
    else:
        stats_cp = run(["git", "diff", "--cached", "--stat"], check=False)
        summary_cp = run(["git", "diff", "--cached", "--summary"], check=False)

    pieces = [f"Request: {request}"]

    if plan_text.strip():
        pieces.append("Plan:\n" + plan_text.strip())

    if visible_written:
        pieces.append("Files written: " + ", ".join(visible_written))
    else:
        pieces.append("Files written: none")

    if rejected:
        pieces.append("Rejected paths: " + ", ".join(rejected))

    if validation_reports:
        pieces.append("Validation:\n" + "\n".join(validation_reports))

    stat_text = stats_cp.stdout.strip()
    summary_text = summary_cp.stdout.strip()

    if stat_text:
        pieces.append("Stat:\n" + stat_text)
    if summary_text:
        pieces.append("Summary:\n" + summary_text)

    return "\n\n".join(pieces).strip()


def build_commit_subject(request: str) -> str:
    msg = f"ollama-code: {request.strip().replace(chr(10), ' ')}"
    if len(msg) > 72:
        msg = msg[:72].rstrip()
    return msg


def has_staged_changes_for_files(written: list[str]) -> bool:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not files:
        return False

    cp = subprocess.run(
        ["git", "diff", "--cached", "--quiet", "--", *files],
        text=True,
        capture_output=True,
    )
    return cp.returncode != 0


def commit_written_files(written: list[str], request: str) -> bool:
    git_add_written_files(written)

    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not has_staged_changes_for_files(written):
        print(c("Nothing to commit.", YELLOW))
        return False

    subject = build_commit_subject(request)
    cp = run(["git", "commit", "--only", "-m", subject, "--", *files], check=False)

    if cp.stdout:
        print(cp.stdout, end="" if cp.stdout.endswith("\n") else "\n")
    if cp.stderr:
        print(cp.stderr, end="" if cp.stderr.endswith("\n") else "\n", file=sys.stderr)

    if cp.returncode == 0:
        print(c("Commit completed.", GREEN))
    else:
        print(c("Commit failed.", RED), file=sys.stderr)

    return cp.returncode == 0


def get_diff_text_for_summary(root: Path, written: list[str], use_last_commit: bool) -> str:
    files = [f for f in written if f not in INTERNAL_STATE_FILES]
    if not files:
        return ""

    if use_last_commit:
        cp = run(
            ["git", "show", "--format=", "--stat", "--summary", "--patch", "HEAD", "--", *files],
            check=False,
        )
    else:
        cp = run(
            ["git", "diff", "--cached", "--stat", "--summary", "--patch", "--", *files],
            check=False,
        )

    text = (cp.stdout or "").strip()
    if not text:
        return ""

    if len(text) > MAX_SUMMARY_DIFF_CHARS:
        text = text[:MAX_SUMMARY_DIFF_CHARS].rstrip() + "\n...[DIFF TRUNCATED]...\n"

    return text


def generate_change_summary(
    root: Path,
    ollama_url: str,
    request: str,
    written: list[str],
    use_last_commit: bool,
    model: str | None,
) -> str:
    diff_text = get_diff_text_for_summary(root, written, use_last_commit=use_last_commit)
    if not diff_text:
        return ""

    prompt = build_change_summary_prompt(request, diff_text)
    return call_ollama(prompt, ollama_url, model, plan_mode=True).strip()


