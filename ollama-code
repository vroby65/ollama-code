def next_available_path(path: Path, suffix: str) -> Path:
    candidate = path.with_name(f"{path.name}{suffix}")
    index = 1
    while candidate.exists():
        candidate = path.with_name(f"{path.name}{suffix}.{index}")
        index += 1
    return candidate


def ensure_user_state_dir() -> Path | None:
    state_dir = get_user_state_dir()

    if state_dir.exists() and state_dir.is_file():
        backup_path = next_available_path(state_dir, ".legacy")
        try:
            state_dir.rename(backup_path)
            print(
                c(
                    f"Migrated legacy user config file {state_dir} to {backup_path}.",
                    YELLOW,
                ),
                file=sys.stderr,
            )
        except Exception as exc:
            print(c(f"Unable to migrate legacy user config file {state_dir}: {exc}", RED), file=sys.stderr)
            return None

    try:
        state_dir.mkdir(parents=True, exist_ok=True)
    except Exception as exc:
        print(c(f"Unable to create user state directory {state_dir}: {exc}", RED), file=sys.stderr)
        return None

    return state_dir


def setup_readline() -> None:
    readline.parse_and_bind("tab: complete")
    readline.parse_and_bind("set editing-mode emacs")
    readline.parse_and_bind('"\\e[A": previous-history')
    readline.parse_and_bind('"\\e[B": next-history')
    readline.parse_and_bind('"\\e[C": forward-char')
    readline.parse_and_bind('"\\e[D": backward-char')
    readline.parse_and_bind('"\\C-a": beginning-of-line')
    readline.parse_and_bind('"\\C-e": end-of-line')

    history_path: Path | None = None
    state_dir = ensure_user_state_dir()
    if state_dir is not None:
        history_path = state_dir / READLINE_HISTORY_FILE

    read_candidates: list[Path] = []
    if history_path is not None:
        read_candidates.append(history_path)
    read_candidates.extend(Path.home() / name for name in LEGACY_READLINE_HISTORY_FILES)

    for candidate in read_candidates:
        try:
            readline.read_history_file(str(candidate))
            break
        except FileNotFoundError:
            continue
        except Exception:
            continue

    def save_history() -> None:
        if history_path is None:
            return
        try:
            history_path.parent.mkdir(parents=True, exist_ok=True)
            readline.write_history_file(str(history_path))
        except Exception:
            pass

    atexit.register(save_history)


def run(cmd, check=False, capture=True, shell=False, env=None, timeout=None):
    return subprocess.run(
        cmd,
        check=check,
        text=True,
        capture_output=capture,
        shell=shell,
        env=env,
        timeout=timeout,
    )


def ensure_git_repo() -> Path:
    cwd = Path.cwd().resolve()
    if not (cwd / ".git").exists():
        cp = run(["git", "init"], check=False)
        if cp.returncode != 0:
            print(c("Error during git init", RED), file=sys.stderr)
            if cp.stderr:
                print(cp.stderr, file=sys.stderr)
            sys.exit(1)
        print(c("Git repository initialized.", GREEN))

    try:
        cp = run(["git", "rev-parse", "--show-toplevel"], check=True)
        return Path(cp.stdout.strip()).resolve()
    except subprocess.CalledProcessError:
        return cwd


